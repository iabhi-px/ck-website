---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Fixed 4 filter categories
const filterTags = ['tutorial', 'engineering', 'architecture', 'performance'];
---

<BaseLayout title="Blog — CodeKarma" description="Articles, tutorials, and updates from the CodeKarma team.">
  <section class="relative bg-white pt-44 lg:pt-[240px] pb-20 overflow-hidden">
    <!-- Vertical gridlines (matching homepage) -->
    <div class="hidden md:block absolute inset-0 mx-auto max-w-7xl px-10 lg:px-[88px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="absolute left-0 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, #fafafa, #e5e5e5);"></div>
        <div class="absolute right-0 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, #fafafa, #e5e5e5);"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-5 md:px-10 lg:px-[88px]">
      <!-- Section header -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-16 mb-16">
        <div>
          <h1 class="text-[32px] sm:text-[40px] md:text-[48px] tracking-tight leading-[1.1] font-semibold bg-gradient-to-b from-[#3b4049] via-[#2a2e35] via-[50%] to-[#0f0f0f] bg-clip-text text-transparent lg:pl-12">
            Articles & Updates
          </h1>
        </div>
        <div class="flex flex-col justify-start lg:py-[12px] lg:pr-12">
          <p class="text-gray-600 leading-[1.5] max-w-lg font-[410] text-lg">
            Engineering insights, product updates, and deep dives from the CodeKarma team.
          </p>
        </div>
      </div>

      <!-- Filter tabs -->
      <div class="blog-filter-bar mt-10 mb-0 lg:pl-12 md:border-b border-gray-200 pb-0" style="margin-bottom: -1px;">
        <div class="flex flex-wrap gap-3">
          <button
            class="blog-filter-tab active"
            data-filter="all"
          >
            All
          </button>
          {filterTags.map((tag) => (
            <button
              class="blog-filter-tab"
              data-filter={tag}
            >
              {tag.charAt(0).toUpperCase() + tag.slice(1)}
            </button>
          ))}
        </div>
      </div>

      <!-- Posts grid — 2-column cards -->
      <div class="blog-grid mt-10 lg:pl-12">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            publishedAt={post.data.publishedAt}
            slug={post.id}
            tags={post.data.tags}
            coverImage={post.data.coverImage}
          />
        ))}
      </div>

      <!-- Empty state -->
      <div class="blog-empty hidden py-20 text-center">
        <p class="text-gray-400 text-lg font-normal">No posts found for this category.</p>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .blog-filter-bar {
    overflow-x: auto;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .blog-filter-bar::-webkit-scrollbar {
    display: none;
  }

  .blog-filter-tab {
    padding: 10px 28px;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.01em;
    color: #666;
    background: #fafafa;
    border: 1px solid #e5e5e5;
    border-radius: 0;
    cursor: pointer;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .blog-filter-tab:hover {
    color: #333;
    background: #f0f0f0;
    border-color: #d0d0d0;
  }

  .blog-filter-tab.active {
    color: #fff;
    background: #1a1a1a;
    border-color: #1a1a1a;
  }

  .blog-filter-tab.active:hover {
    background: #2a2a2a;
    border-color: #2a2a2a;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .blog-filter-tab {
      padding: 8px 18px;
      font-size: 12px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.blog-filter-tab');
    const cards = document.querySelectorAll<HTMLAnchorElement>('.blog-grid > a');
    const emptyState = document.querySelector('.blog-empty');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t) => t.classList.remove('active'));
        tab.classList.add('active');

        const filter = tab.dataset.filter;
        let visibleCount = 0;

        cards.forEach((card) => {
          const tags = card.dataset.tags ? card.dataset.tags.split(',') : [];
          if (filter === 'all' || tags.includes(filter)) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        if (emptyState) {
          emptyState.classList.toggle('hidden', visibleCount > 0);
        }
      });
    });
  });
</script>
