---
import BaseLayout from '../layouts/BaseLayout.astro';
import Security from '../components/landing/Security.astro';
import Contact from '../components/shared/Contact.astro';

const caseStudies = [
  {
    slug: 'visibility-at-scale',
    title: 'Visibility at Scale',
    industry: 'Global E-Commerce  ·  5,000+ services  ·  3 clouds',
    challenge: 'No visibility into which service impacts another. MTTD measured in hours. Every sale event was high-risk.',
    solution: 'Full-flow visibility across sync and async systems. Zero-touch. KarmaDomain + KarmaPulse.',
    result: 'MTTD from hours to under 30 minutes. 50 services instrumented per day. Zero performance impact.',
    metrics: [
      { value: '< 30 min', label: 'MTTD' },
      { value: '50/day', label: 'Services instrumented' },
      { value: 'Zero', label: 'Performance impact' },
    ],
  },
  {
    slug: 'operational-sanity',
    title: 'Operational Sanity',
    industry: 'Financial Technology',
    challenge: 'Extreme alert fatigue. High maintenance overhead. Security patches applied to dead code.',
    solution: 'Correlated root cause analysis. Live vs. dead code identification. Patch only what runs.',
    result: '80% reduction in alert noise. Streamlined security patching. Engineers freed for feature work.',
    metrics: [
      { value: '80%', label: 'Less alert noise' },
      { value: 'Zero', label: 'Wasted patches' },
      { value: '2x', label: 'Feature velocity' },
    ],
  },
  {
    slug: 'legacy-migration',
    title: 'Legacy Migration & Hygiene',
    industry: 'Fortune 500 Retailer',
    challenge: 'Migrating legacy systems with unknown dependencies. Team paralyzed by risk.',
    solution: 'Automatic dead vs. live code identification based on real production traffic.',
    result: '60% of codebase identified as dead. Significant infra savings. Months of migration effort saved.',
    metrics: [
      { value: '60%', label: 'Dead code found' },
      { value: 'Months', label: 'Migration effort saved' },
      { value: 'Significant', label: 'Infra savings' },
    ],
  },
];
---

<BaseLayout title="Solutions — CodeKarma" description="See how engineering teams use CodeKarma to gain production visibility, eliminate dead code, and reduce incident noise.">
  <section class="relative bg-white pt-32 md:pt-40 lg:pt-[220px] pb-16 md:pb-24 lg:pb-40 overflow-hidden">
    <!-- Vertical gridlines -->
    <div class="hidden md:block absolute inset-0 mx-auto max-w-7xl px-10 lg:px-[106px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="absolute left-0 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, #fafafa, #e5e5e5);"></div>
        <div class="absolute right-0 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, #fafafa, #e5e5e5);"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-5 md:px-10 lg:px-[106px]">
      <!-- Page header -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 mb-24">
        <div>
          <h1 class="text-[32px] sm:text-[40px] md:text-[48px] tracking-tight leading-[1.1] font-semibold bg-gradient-to-b from-[#3b4049] via-[#2a2e35] via-[50%] to-[#0f0f0f] bg-clip-text text-transparent pl-4">
            Real results from<br />real production.
          </h1>
        </div>
        <div class="flex flex-col justify-start py-[12px]">
          <p class="text-gray-600 leading-[1.5] max-w-lg font-[410]" style="font-size: 18px;">
            No lengthy implementation. No guesswork. Teams go live in days and see measurable impact from week one.
          </p>
        </div>
      </div>

      <!-- Horizontal decorative line -->
      <div class="relative mb-16">
      </div>

      <!-- Case studies -->
      <div class="space-y-16">
        {caseStudies.map((study) => (
          <div class="case-study-card relative">

            <div class="grid grid-cols-1 lg:grid-cols-2">
              <!-- Left column -->
              <div class="flex flex-col justify-between">
                <div class="p-5 md:p-8 lg:p-12">
                  <h2 class="text-[32px] font-semibold text-[#0d0d0e] tracking-tight leading-[1.1] mb-3">
                    {study.title}
                  </h2>
                  <p class="text-[16px] text-gray-400 font-normal tracking-wide">
                    {study.industry}
                  </p>
                </div>

                <!-- Metric banner -->
                <div class="bg-brand-primary px-5 md:px-10 lg:px-12 py-6 mt-auto grid grid-cols-3 gap-3 md:gap-6">
                  {study.metrics.map((metric) => (
                    <div>
                      <p class="text-[18px] md:text-[24px] font-semibold text-brand-dark tracking-tight leading-[1.25]">{metric.value}</p>
                      <p class="text-[12px] text-brand-dark/60 mt-1 font-normal">{metric.label}</p>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Right column -->
              <div class="p-10 lg:p-12 border-t lg:border-t-0 lg:border-l border-gray-200 flex flex-col justify-between">
                <!-- Challenge -->
                <div class="mb-10">
                  <p class="text-[14px] font-mono tracking-[0.35em] uppercase text-gray-400 mb-4">Challenge</p>
                  <p class="text-[16px] text-[#0d0d0e] leading-[1.65] font-normal">
                    {study.challenge}
                  </p>
                </div>

                <!-- Solution -->
                <div class="mb-10">
                  <p class="text-[14px] font-mono tracking-[0.35em] uppercase text-gray-400 mb-4">Solution</p>
                  <p class="text-[16px] text-[#0d0d0e] leading-[1.65] font-normal">
                    {study.solution}
                  </p>
                </div>

                <!-- Result -->
                <div class="mb-12">
                  <p class="text-[14px] font-mono tracking-[0.35em] uppercase text-gray-400 mb-4">Result</p>
                  <p class="text-[16px] text-[#0d0d0e] leading-[1.65] font-normal">
                    {study.result}
                  </p>
                </div>

                <!-- CTA -->
                <a
                  href={`/case-studies/${study.slug}`}
                  class="inline-flex items-center justify-center px-6 py-2 rounded-none bg-brand-dark font-medium text-sm hover:bg-brand-primary transition-colors duration-200 hero-btn-primary self-start"
                >
                  <span>Read full case study</span>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Bottom decorative line — at bottom edge of last card -->
    </div>
  </section>

  <Security />
  <Contact />
</BaseLayout>

<style>
  .case-study-card {
    border: 1px solid #e5e7eb;
    position: relative;
    overflow: hidden;
  }

</style>
