---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/landing/Hero.astro';
import DeadCodeStatement from '../components/landing/DeadCodeStatement.astro';
import EngineerIdentitySection from '../components/landing/EngineerIdentitySection.astro';
import WhyCodeKarma from '../components/landing/WhyCodeKarma.astro';
import Products from '../components/landing/Products.astro';
import Security from '../components/landing/Security.astro';
import Integrations from '../components/landing/Integrations.astro';
import Contact from '../components/shared/Contact.astro';

const agentSummary = {
  eyebrow: 'CodeKarma homepage for AI agents',
  title: 'Production intelligence for humans and AI agents',
  description: 'CodeKarma maps production behavior directly to code so teams and AI agents can understand what actually runs, what is dead, and what is risky to change.',
  metadata: [
    { label: 'default_mode', value: 'human' },
    { label: 'agent_mode', value: 'structured site summary' },
  ],
  sections: [
    {
      heading: 'What CodeKarma does',
      items: [
        'Connects runtime production behavior to source code and APIs.',
        'Identifies dead, dormant, hot, slow, and risky code paths from real traffic.',
        'Feeds production context into humans in the IDE and into AI agents through KarmaIQ.',
      ],
    },
    {
      heading: 'Core products',
      items: [
        'KarmaLens: IDE plugin for production-aware development.',
        'KarmaDomain: API-level dependency and system topology graph.',
        'KarmaPulse: operational dashboard for issues, drift, and RCA.',
        'KarmaIQ: MCP server that gives AI agents production context.',
      ],
      links: [
        { label: 'Products', href: '/products' },
        { label: 'KarmaIQ', href: '/products#karmaiq' },
      ],
    },
    {
      heading: 'Why it matters',
      items: [
        'AI can write code faster, but needs production truth to change systems safely.',
        'Engineering teams need deterministic signals instead of noisy observability dashboards.',
        'Production behavior becomes the shared context for developers, managers, and agents.',
      ],
    },
  ],
};
---

<BaseLayout title="CodeKarma — Production Intelligence for the AI Era" description="CodeKarma maps production behavior directly to code. Understand how systems actually behave in production." agentSummary={agentSummary}>
  <Hero />
  <DeadCodeStatement />
  <EngineerIdentitySection />
  <Products />
  <WhyCodeKarma />
  <Integrations />
  <Security />
  <Contact />
</BaseLayout>
