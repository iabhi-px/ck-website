---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/shared/Contact.astro';
import InvestorDialKit from '../components/InvestorDialKit';

import accelLogo from '../assets/images/investors/accel.png';
import prosusLogo from '../assets/images/investors/prosus.png';
import xeedLogo from '../assets/images/investors/xeed-ventures.png';
import senseaiLogo from '../assets/images/investors/senseai-ventures.png';
import stargazerLogo from '../assets/images/investors/stargazer-ventures.png';

import amazonLogo from '../assets/images/company-logos/amazon.png';
import flipkartLogo from '../assets/images/company-logos/flipkart.png';

const principles = [
  {
    title: 'Production is truth',
    description: 'Logs, traces, and metrics tell you what happened. Production intelligence tells you why — and what to do next.',
    icon: 'custom-bars',
  },
  {
    title: 'Zero overhead, full fidelity',
    description: 'With 100% of your request monitored yet no performance cost and no blind spots.',
    icon: 'custom-graph',
  },
  {
    title: 'Code-level clarity',
    description: 'Runtime behavior mapped directly to the code that produced it. Not dashboards — understanding.',
    icon: 'custom-chip',
  },
  {
    title: 'AI-native from day one',
    description: 'Built for a world where AI agents write and evolve code. Production intelligence is the feedback loop they need.',
    icon: 'custom-ai',
  },
];

const founders = [
  { name: 'Anantharam Vanchi Prakash', title: 'Co-Founder & CEO', photo: '/images/team/anantharam.png', logos: [{ src: amazonLogo, alt: 'Amazon', height: 20 }, { src: flipkartLogo, alt: 'Flipkart', height: 20 }, { src: '/assets/Logos/Logo with name (LR)/Colored (for light bg).svg', alt: 'CodeKarma', height: 22, isSvg: true }], linkedin: 'https://www.linkedin.com/in/anantharam-vanchi-prakash/' },
  { name: 'Priyanka Nahata', title: 'Co-Founder & CTO', photo: '/images/team/priyanka.png', logos: [{ src: flipkartLogo, alt: 'Flipkart', height: 20 }, { src: '/assets/Logos/Logo with name (LR)/Colored (for light bg).svg', alt: 'CodeKarma', height: 22, isSvg: true }], linkedin: 'https://www.linkedin.com/in/priyankanahata/' },
];

const pressItems = [
  { outlet: 'Inc42', title: 'Former Amazon Executive\'s Startup CodeKarma Bags $2.5 Mn', href: 'https://inc42.com/buzz/former-amazon-executives-startup-codekarma-bags-2-5-mn/' },
  { outlet: 'Inc42', title: '30 Startups To Watch: Startups That Caught Our Eyes In August 2025', href: 'https://inc42.com/startups/30-startups-to-watch-startups-that-caught-our-eye-in-august-2025/' },
  { outlet: 'Tech In Asia', title: 'Prosus leads $2.5M round for Indian software platform CodeKarma', href: 'https://www.techinasia.com/news/prosus-leads-2-5m-round-for-indian-software-platform-codekarma' },
  { outlet: 'Entrepreneur India', title: 'Developer Productivity Startup CodeKarma Raises USD 2.5 Mn Round', href: 'https://india.entrepreneur.com/news-and-trends/codekarma-mangopoint-and-nprep-raise-early-stage-funding/495598' },
  { outlet: 'YourStory', title: 'India\'s AI advantage: How Prosus is betting on its portfolio with Arivihan and CodeKarma', href: 'https://yourstory.com/2025/09/indias-ai-advantage-prosus-betting-portfolio-arivihan-codekarma' },
];

const investors = [
  { name: 'Accel', logo: accelLogo },
  { name: 'Prosus', logo: prosusLogo },
  { name: 'Xeed Ventures', logo: xeedLogo },
  { name: 'SenseAI Ventures', logo: senseaiLogo },
  { name: 'Stargazer Ventures', logo: stargazerLogo },
];
---

<BaseLayout title="About — CodeKarma" description="Meet the team behind CodeKarma. Learn about our mission to bring production intelligence to every engineering team.">
  <section class="relative bg-white pt-44 lg:pt-[240px] pb-0 overflow-hidden">
    <!-- Vertical gridlines -->
    <div class="hidden md:block absolute inset-0 mx-auto max-w-7xl px-10 lg:px-[88px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="absolute left-0 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, #fafafa, #e5e5e5);"></div>
        <div class="absolute right-0 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, #fafafa, #e5e5e5);"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-5 md:px-10 lg:px-[88px]">

      <!-- WHAT WE STAND FOR -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-16 mb-20 md:mb-40">
        <!-- Left: Headline -->
        <div>
          <h1 class="text-[40px] md:text-[48px] tracking-tight leading-[1.1] font-semibold bg-gradient-to-b from-[#3b4049] via-[#2a2e35] via-[50%] to-[#0f0f0f] bg-clip-text text-transparent lg:pl-12">
            <span class="font-semibold">What we stand for</span>
          </h1>
        </div>

        <!-- Right: Description -->
        <div class="flex flex-col justify-start lg:py-[12px] lg:pr-12">
          <p class="text-gray-600 leading-[1.4] md:leading-[1.5] max-w-lg font-[410] text-[18px] md:text-lg">
            The future of software engineering isn't about writing code faster. It's about understanding systems deeply enough to evolve them with confidence. As AI rewrites how software gets built, production truth becomes the most valuable signal in the stack.
          </p>
        </div>
      </div>

      <!-- OUR PRINCIPLES -->
      <div class="mb-20 md:mb-40">
        <div class="max-w-3xl mb-8 md:mb-16">
          <p class="text-sm font-mono tracking-[0.3em] uppercase lg:pl-12 text-brand-dark/40 mb-4 md:mb-5">Our Principles</p>
          <h2 class="lg:pl-12 text-3xl sm:text-4xl tracking-tight leading-[1.1] font-semibold bg-gradient-to-b from-[#3b4049] via-[#2a2e35] via-[50%] to-[#0f0f0f] bg-clip-text text-transparent">
            How we think
          </h2>
        </div>

        <div class="relative">
          <div class="grid grid-cols-2 border border-gray-200">
            {principles.map((item, index) => (
              <div class={`principle-cell p-5 md:p-8 lg:p-10 ${index % 2 === 0 ? 'border-r border-gray-200' : ''} ${index < 2 ? 'border-b border-gray-200' : ''}`}>
                <div class="principle-icon flex items-center justify-center w-12 h-12 rounded-full bg-[#fafafa] mb-5">
                  {item.icon === 'custom-bars' ? (
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                      <path d="M10 14V20H14V14" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M18 10V20H22V10" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M2 18V20H6V18" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M4.01001 16L4.00001 16" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M12.01 12L12 12" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M2.01001 8L2.00001 8" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M4.01001 6L4.00001 6" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M6.01001 4L6.00001 4" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M8.01001 6L8.00001 6" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M10.01 8L10 8" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M12.01 6L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M14.01 4L14 4" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M20.01 8L20 8" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                    </svg>
                  ) : item.icon === 'custom-chip' ? (
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                      <path d="M12 16.01V16" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M16 16.01V16" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M8 16.01V16" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M7 3H6" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M17 3H18" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M7 21H6" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M17 21H18" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M2 12H1" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M22 12H23" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M4 10V5" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M20 10V5" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M4 19V14" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M20 19V14" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                    </svg>
                  ) : item.icon === 'custom-graph' ? (
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                      <path d="M18.01 21L18 21" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M6.01001 21L6.00001 21" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M20.01 19L20 19" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M16.01 19L16 19" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M8.01001 19L8.00001 19" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M4.01001 19L4.00001 19" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M14 13L14 15L12 15" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M20.01 12L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M4.01001 12L4.00001 12" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M10 13V11H12" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M22 9L22 17" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M8.01001 9L8.00001 9" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M2 9L2 17" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M20.01 7L20 7" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M6.01001 7L6.00001 7" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M18.01 5L18 5" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M12.01 5L12 5" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M4.01001 5L4.00001 5" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M8 3L16 3" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                    </svg>
                  ) : item.icon === 'custom-ai' ? (
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                      <path d="M17 7V7.01" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M13 7V7.01" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M13 11V11.01" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M17 11V11.01" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M15 13V17" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M15 1V5" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M11.005 8.995L9.005 8.995" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M21.005 8.995L19.005 8.995" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M9.01001 17L9.00001 17" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M3.01001 6L3.00001 6" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M5.01001 17L5.00001 17" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M7 13L7 15" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                      <path d="M7 19L7 21" stroke="currentColor" stroke-width="2" stroke-linecap="square" fill="none" />
                    </svg>
                  ) : (
                    <i class={`${item.icon} text-2xl text-brand-dark/60`}></i>
                  )}
                </div>
                <h3 class="text-[20px] font-semibold text-brand-dark mb-3 leading-[1.2]">{item.title}</h3>
                <p class="text-base text-gray-600 leading-[1.5] font-[410]">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- INVESTORS -->
      <div class="mb-20 md:mb-40">
        <div class="max-w-3xl mb-8 md:mb-16">
          <p class="text-sm font-mono tracking-[0.3em] uppercase lg:pl-12 text-brand-dark/40 mb-4 md:mb-5">Investors</p>
          <h2 class="lg:pl-12 text-3xl sm:text-4xl tracking-tight leading-[1.1] font-semibold bg-gradient-to-b from-[#3b4049] via-[#2a2e35] via-[50%] to-[#0f0f0f] bg-clip-text text-transparent">
            Backed by the best
          </h2>
        </div>

        <div class="relative">
          <div class="grid grid-cols-2 md:grid-cols-4 border border-gray-200">
            <div class="investor-cell flex items-center justify-center border-r border-gray-200 max-md:border-b" data-investor-cell="Accel" style="padding-top: 32px; padding-bottom: 40px; padding-left: 32px; padding-right: 32px;">
              <Image src={accelLogo} alt="Accel" class="investor-logo object-contain max-md:!h-[32px]" data-investor="Accel" style="height: 72px; max-width: 140px; width: auto;" />
            </div>
            <div class="investor-cell flex items-center justify-center border-r border-gray-200 max-md:border-b" data-investor-cell="Prosus" style="padding-top: 46px; padding-bottom: 36px; padding-left: 32px; padding-right: 32px;">
              <Image src={prosusLogo} alt="Prosus" class="investor-logo object-contain max-md:!h-[32px]" data-investor="Prosus" style="height: 64px; max-width: 168px; width: auto;" />
            </div>
            <div class="investor-cell flex items-center justify-center max-md:border-b border-r border-gray-200" data-investor-cell="Xeed Ventures" style="padding-top: 0px; padding-bottom: 0px; padding-left: 32px; padding-right: 32px;">
              <Image src={xeedLogo} alt="Xeed Ventures" class="investor-logo object-contain max-md:!h-[96px]" data-investor="Xeed Ventures" style="height: 136px; max-width: 140px; width: auto;" />
            </div>
            <div class="investor-cell flex flex-col items-center justify-center !p-0" data-investor-cell="SenseAI+Stargazer">
              <div class="investor-logo-wrapper flex items-center justify-center flex-1 w-full py-4 px-4 lg:px-5">
                <Image src={senseaiLogo} alt="SenseAI Ventures" class="investor-logo object-contain max-md:!h-[32px]" data-investor="SenseAI Ventures" style="height: 44px; max-width: 152px; width: auto;" />
              </div>
              <div class="w-full h-px bg-gray-200"></div>
              <div class="investor-logo-wrapper flex items-center justify-center flex-1 w-full py-4 px-4 lg:px-5">
                <Image src={stargazerLogo} alt="Stargazer Ventures" class="investor-logo object-contain max-md:!h-[24px]" data-investor="Stargazer Ventures" style="height: 36px; max-width: 140px; width: auto;" />
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- <InvestorDialKit client:load /> -->

      <!-- TEAM — FOUNDERS -->
      <div class="mb-20 md:mb-40">
        <div class="max-w-3xl mb-8 md:mb-16">
          <p class="text-sm font-mono tracking-[0.3em] uppercase lg:pl-12 text-brand-dark/40 mb-4 md:mb-5">Team</p>
          <h2 class="lg:pl-12 text-3xl sm:text-4xl tracking-tight leading-[1.1] font-semibold bg-gradient-to-b from-[#3b4049] via-[#2a2e35] via-[50%] to-[#0f0f0f] bg-clip-text text-transparent">
            Founders
          </h2>
        </div>

        <div class="relative">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-0 border border-gray-200">
            {founders.map((founder, index) => (
              <div class={`founder-card relative overflow-hidden p-5 pt-6 md:p-8 lg:p-10 ${index === 0 ? 'sm:border-r border-b sm:border-b-0 border-gray-200' : ''}`}>
                {founder.photo ? (
                  <div class="w-full aspect-square bg-gray-100 mb-6 overflow-hidden">
                    <img src={founder.photo} alt={founder.name} class="w-full h-full object-cover" />
                  </div>
                ) : (
                  <div class="w-full aspect-square bg-gray-100 mb-6 flex items-center justify-center">
                    <span class="text-sm text-gray-400 font-mono">Photo</span>
                  </div>
                )}
                <div class="flex items-center justify-between">
                  <div>
                    <h3 class="text-[20px] md:text-lg font-semibold text-brand-dark mb-1">{founder.name}</h3>
                    <p class="text-[15px] md:text-base text-gray-600 font-[410]">{founder.title}</p>
                  </div>
                  <a href={founder.linkedin} target="_blank" rel="noopener noreferrer" class="text-brand-dark flex-shrink-0 ml-4 linkedin-icon">
                    <i class="ph ph-linkedin-logo" style="font-size: 28px;"></i>
                    <i class="ph-fill ph-linkedin-logo" style="font-size: 28px;"></i>
                  </a>
                </div>
                <div class="w-full h-px bg-gray-200 mt-4 md:hidden"></div>
                {founder.logos && (
                  <div class={`flex flex-wrap items-center gap-3 mt-4 md:mt-4 pt-0 md:pt-4 ${index === 0 ? 'md:-ml-2' : ''}`}>
                    {founder.logos.map((logo: { src: any; alt: string; height?: number; isSvg?: boolean }, i: number) => (
                      <>
                        {logo.isSvg ? (
                          <img src={logo.src} alt={logo.alt} class="w-auto object-contain" style={`height: ${logo.height || 28}px;`} />
                        ) : (
                          <Image src={logo.src} alt={logo.alt} class="w-auto object-contain" style={`height: ${logo.height || 28}px;`} />
                        )}
                        {i < founder.logos.length - 1 && <span class="text-brand-dark text-sm">→</span>}
                      </>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- IN THE PRESS -->
      <div class="mb-8 md:mb-[72px]">
        <div class="max-w-3xl mb-8 md:mb-16">
          <p class="text-sm font-mono tracking-[0.3em] uppercase lg:pl-12 text-brand-dark/40 mb-4 md:mb-5">In The Press</p>
          <h2 class="lg:pl-12 text-3xl sm:text-4xl tracking-tight leading-[1.1] font-semibold bg-gradient-to-b from-[#3b4049] via-[#2a2e35] via-[50%] to-[#0f0f0f] bg-clip-text text-transparent">
            What they're saying
          </h2>
        </div>

        <div class="relative">
          <div class="border border-gray-200 divide-y divide-gray-200">
            {pressItems.map((item) => (
              <a href={item.href} target="_blank" rel="noopener noreferrer" class="group flex items-center justify-between p-5 md:p-8 lg:p-10 hover:bg-brand-primary transition-colors duration-200">
                <div>
                  <p class="text-sm font-mono tracking-[0.2em] uppercase text-brand-dark/40 group-hover:text-brand-dark/60 mb-2">{item.outlet}</p>
                  <h3 class="text-lg font-semibold text-brand-dark group-hover:text-brand-dark transition-colors">{item.title}</h3>
                </div>
                <i class="ph ph-arrow-up-right text-xl text-gray-400 group-hover:text-brand-dark transition-colors flex-shrink-0 ml-4 md:ml-8"></i>
              </a>
            ))}
          </div>
        </div>
      </div>


      </div>
    </div>
  </section>

  <Contact />
</BaseLayout>

<style>
  @media (min-width: 1024px) {
    .principle-cell {
      transition: background-color 0.2s ease;
    }
    .principle-cell:hover {
      background-color: #fafafa;
    }
    .principle-icon {
      transition: transform 0.3s ease;
    }
    .principle-cell:hover .principle-icon {
      transform: scale(2);
    }

    .founder-card {
      transition: background-color 0.2s ease;
    }
    .founder-card:hover {
      background-color: #fafafa;
    }
  }

  .linkedin-icon .ph-fill {
    display: none;
  }
  .linkedin-icon .ph {
    display: inline;
  }
  .linkedin-icon:hover .ph {
    display: none;
  }
  .linkedin-icon:hover .ph-fill {
    display: inline;
    color: #0A66C2;
  }
</style>
