---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/shared/Contact.astro';

const karmaPulseFeatures = [
  { title: 'API health dashboard', desc: 'Failing, slow, or drifting APIs, prioritized by impact' },
  { title: 'Dead code hotspots', desc: 'Services with maximum dormant code, safe to retire' },
  { title: 'Error drift tracking', desc: 'Week-over-week regression detection' },
  { title: 'Deployment error analysis', desc: 'Errors correlated to specific deploys' },
  { title: 'KarmaPulse AI', desc: 'Automated RCA with BYOK model support' },
  { title: 'Real test coverage', desc: 'Which tests exercise production-relevant paths' },
];

const karmaLensFeatures = [
  { title: 'Dead & dormant code identification', desc: 'Deterministic, based on real traffic' },
  { title: 'Method call frequency', desc: 'Distinguish hot paths from rarely-used code' },
  { title: 'API call frequency', desc: 'Which endpoints are live vs. effectively dead' },
  { title: 'Performance hotspots', desc: 'High latency or error methods, flagged in-editor' },
  { title: 'Execution path tracking', desc: 'How code actually runs in production' },
];

const karmaDomainFeatures = [
  { title: 'API-level dependency graph', desc: 'Deeper than any observability tool' },
  { title: 'Fan-out analysis', desc: 'Blast radius of any service, instantly' },
  { title: 'Multi-hop tracing', desc: 'Across queues, threads, sync and async systems' },
  { title: 'Golden signals & distributions', desc: 'Not just averages' },
  { title: 'System evolution timeline', desc: 'Detect architectural drift over time' },
  { title: 'Deterministic fan-out mapping', desc: 'Every downstream call, every query' },
];

const karmaIQFeatures = [
  { title: 'Blended multi-level view', desc: 'Service → API → method, seamlessly' },
  { title: 'Code understanding & debugging', desc: 'Real production context for any codebase' },
  { title: 'Deterministic RCA', desc: '100% data, not hallucinations' },
  { title: 'MTTR reduction', desc: 'Trace failures across services and methods in minutes' },
  { title: 'BYOK model support', desc: 'Use your own LLM keys' },
];
---

<BaseLayout title="Products — CodeKarma" description="Explore CodeKarma's production intelligence platform: KarmaPulse, KarmaLens, KarmaDomain, and KarmaIQ.">

  <!-- HERO -->
  <section class="relative bg-white pt-44 lg:pt-[240px] pb-0 md:pb-10 overflow-hidden">
    <!-- Vertical gridlines -->
    <div class="hidden md:block absolute inset-0 mx-auto max-w-7xl px-10 lg:px-[88px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="absolute left-0 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, #fafafa, #e5e5e5);"></div>
        <div class="absolute right-0 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, #fafafa, #e5e5e5);"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-5 md:px-10 lg:px-[88px]">
      <!-- Hero heading -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-16 mb-0 md:mb-20">
        <div>
          <h1 class="text-[32px] sm:text-[40px] md:text-[48px] tracking-tight leading-[1.1] font-semibold lg:pl-12 bg-gradient-to-b from-[#3b4049] via-[#2a2e35] via-[50%] to-[#0f0f0f] bg-clip-text text-transparent">
            <span>The Production Context Engine</span>
          </h1>
        </div>
        <div class="flex flex-col justify-start lg:py-[12px] lg:pr-12">
          <p class="lg:pl-12 text-gray-600 leading-[1.5] max-w-lg font-[410] text-lg">
            One source of truth. Zero-touch instrumentation. Insights for humans and AI agents. Four products for four personas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- KARMALENS (light) -->
  <section id="karmalens" class="relative bg-white pt-16 lg:pt-20 pb-16 md:pb-28 lg:pb-36 overflow-hidden">
    <!-- Vertical gridlines -->
    <div class="hidden md:block absolute inset-0 mx-auto max-w-7xl px-10 lg:px-[88px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="absolute left-0 top-0 bottom-0 w-px bg-gray-200"></div>
        <div class="absolute right-0 top-0 bottom-0 w-px bg-gray-200"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-5 md:px-10 lg:px-[88px]">
      <!-- Header -->
      <div class="max-w-3xl mb-12">
        <p class="lg:pl-12 text-sm font-mono tracking-[0.3em] uppercase text-brand-dark/40 mb-5">For Developers</p>
        <h2 class="lg:pl-12 text-[28px] md:text-[36px] tracking-tight leading-[1.1] font-semibold bg-gradient-to-b from-[#3b4049] via-[#2a2e35] via-[50%] to-[#0f0f0f] bg-clip-text text-transparent mb-4">
          KarmaLens
        </h2>
        <p class="lg:pl-12 text-lg text-brand-dark font-[410] mb-6">Production intelligence, right where you code.</p>
        <p class="lg:pl-12 text-gray-600 leading-[1.5] font-[410] text-lg mb-6">
          Brings production truth into your IDE. See dead and dormant code, method frequency, performance hotspots, and execution paths — overlaid on your code. 100% of traffic. Not sampled.
        </p>
        <div class="lg:pl-12 flex flex-wrap items-center gap-2">
          <span class="text-[11px] font-mono tracking-[0.2em] uppercase text-gray-400 mr-1">Supported</span>
          <span class="text-xs font-mono text-gray-600 border border-gray-200 px-3 py-1">JetBrains (IntelliJ)</span>
          <span class="text-xs font-mono text-gray-600 border border-gray-200 px-3 py-1">VS Code</span>
        </div>
      </div>

      <!-- Full-width visual -->
      <div class="relative mb-16">
        <div class="w-full aspect-[16/9] overflow-hidden border rounded-none" style="border-color: #2a2a2a;">
          <video
            class="karmalens-product-video w-full h-full object-cover"
            controls
            muted
            loop
            playsinline
            preload="metadata"
          >
            <source src="/assets/Videos/karmalens.webm" type="video/webm" />
            <source src="/assets/Videos/karmalens.mp4" type="video/mp4" />
          </video>
        </div>
      </div>

      <!-- Feature tiles -->
      <div class="relative">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border border-gray-200">
          {karmaLensFeatures.map((f, i) => (
            <div class={`p-6 lg:p-8 ${(i % 3 !== 2) ? 'lg:border-r border-gray-200' : ''} ${i < 3 ? 'border-b border-gray-200' : ''} ${(i % 2 === 0 && i < 4) ? 'sm:border-r sm:max-lg:border-r' : ''} ${i < 4 ? 'sm:max-lg:border-b' : ''}`}>
              <h4 class="text-[16px] font-semibold text-brand-dark mb-2">{f.title}</h4>
              <p class="text-[16px] text-gray-600 leading-[1.5] font-[410]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- KARMADOMAIN (dark) -->
  <section id="karmadomain" class="dark-section relative bg-brand-dark py-16 md:py-28 lg:py-36 overflow-hidden">
    <!-- Vertical gridlines -->
    <div class="hidden md:block absolute inset-0 mx-auto max-w-7xl px-10 lg:px-[88px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="absolute left-0 top-0 bottom-0 w-px bg-white/10"></div>
        <div class="absolute right-0 top-0 bottom-0 w-px bg-white/10"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-5 md:px-10 lg:px-[88px]">
      <!-- Header -->
      <div class="max-w-3xl mb-12">
        <p class="lg:pl-12 text-sm font-mono tracking-[0.3em] uppercase text-brand-primary mb-5">For Architects & Platform Teams</p>
        <h2 class="lg:pl-12 text-[28px] md:text-[36px] tracking-tight leading-[1.1] font-semibold text-white mb-4">
          KarmaDomain
        </h2>
        <p class="lg:pl-12 text-lg text-white/80 font-[410] mb-6">See how your software actually connects and behaves.</p>
        <p class="lg:pl-12 text-white/50 leading-[1.5] font-[410] text-lg">
          The live graph of your production systems. Microservices, APIs, databases — connected in real time. Unlike traditional tools that show service-to-service, KarmaDomain shows API-to-API level dependencies. Every connection based on 100% production traffic.
        </p>
      </div>

      <!-- Full-width visual -->
      <div class="relative mb-16">
        <div class="w-full aspect-[16/9] overflow-hidden border rounded-none" style="border-color: #2a2a2a;">
          <video
            class="karmadomain-product-video w-full h-full object-cover"
            controls
            muted
            loop
            playsinline
            preload="metadata"
          >
            <source src="/assets/Videos/karmadomain.webm" type="video/webm" />
            <source src="/assets/Videos/karmadomain.mp4" type="video/mp4" />
          </video>
        </div>
      </div>

      <!-- Feature tiles -->
      <div class="relative">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border border-white/10">
          {karmaDomainFeatures.map((f, i) => (
            <div class={`p-6 lg:p-8 ${(i % 3 !== 2) ? 'lg:border-r border-white/10' : ''} ${i < 3 ? 'border-b border-white/10' : ''} ${(i % 2 === 0 && i < 4) ? 'sm:border-r sm:max-lg:border-r' : ''} ${i < 4 ? 'sm:max-lg:border-b' : ''}`}>
              <h4 class="text-[16px] font-semibold text-white mb-2">{f.title}</h4>
              <p class="text-[16px] text-white/50 leading-[1.5] font-[410]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- KARMAPULSE (light) -->
  <section id="karmapulse" class="relative bg-white py-16 md:py-28 lg:py-36 overflow-hidden">
    <!-- Vertical gridlines -->
    <div class="hidden md:block absolute inset-0 mx-auto max-w-7xl px-10 lg:px-[88px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="absolute left-0 top-0 bottom-0 w-px bg-gray-200"></div>
        <div class="absolute right-0 top-0 bottom-0 w-px bg-gray-200"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-5 md:px-10 lg:px-[88px]">
      <!-- Header -->
      <div class="max-w-3xl mb-12">
        <p class="lg:pl-12 text-sm font-mono tracking-[0.3em] uppercase text-brand-dark/40 mb-5">For Engineering Leadership</p>
        <h2 class="lg:pl-12 text-[28px] md:text-[36px] tracking-tight leading-[1.1] font-semibold bg-gradient-to-b from-[#3b4049] via-[#2a2e35] via-[50%] to-[#0f0f0f] bg-clip-text text-transparent mb-4">
          KarmaPulse
        </h2>
        <p class="lg:pl-12 text-lg text-brand-dark font-[410] mb-6">Know what needs attention. Act with confidence.</p>
        <p class="lg:pl-12 text-gray-600 leading-[1.5] font-[410] text-lg">
          The operational command center for your engineering org. KarmaPulse surfaces the most important issues and the specific actions to fix them.
        </p>
      </div>

      <!-- Full-width visual -->
      <div class="relative mb-16">
        <div class="w-full aspect-[16/9] overflow-hidden border rounded-none bg-gray-100 flex items-center justify-center" style="border-color: #e5e5e5;">
          <span class="text-sm text-gray-400 font-mono">KarmaPulse Screenshot</span>
        </div>
      </div>

      <!-- Feature tiles -->
      <div class="relative">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border border-gray-200">
          {karmaPulseFeatures.map((f, i) => (
            <div class={`p-6 lg:p-8 ${(i % 3 !== 2) ? 'lg:border-r border-gray-200' : ''} ${i < 3 ? 'border-b border-gray-200' : ''} ${(i % 2 === 0 && i < 4) ? 'sm:border-r sm:max-lg:border-r' : ''} ${i < 4 ? 'sm:max-lg:border-b' : ''}`}>
              <h4 class="text-[16px] font-semibold text-brand-dark mb-2">{f.title}</h4>
              <p class="text-[16px] text-gray-600 leading-[1.5] font-[410]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- KARMAIQ (dark) -->
  <section id="karmaiq" class="dark-section relative bg-brand-dark py-16 md:py-28 lg:py-36 overflow-hidden">
    <!-- Vertical gridlines -->
    <div class="hidden md:block absolute inset-0 mx-auto max-w-7xl px-10 lg:px-[88px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="absolute left-0 top-0 bottom-0 w-px bg-white/10"></div>
        <div class="absolute right-0 top-0 bottom-0 w-px bg-white/10"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-5 md:px-10 lg:px-[88px]">
      <!-- Header -->
      <div class="max-w-3xl mb-12">
        <p class="lg:pl-12 text-sm font-mono tracking-[0.3em] uppercase text-brand-primary mb-5">For AI Agents</p>
        <h2 class="lg:pl-12 text-[28px] md:text-[36px] tracking-tight leading-[1.1] font-semibold text-white mb-4">
          KarmaIQ
        </h2>
        <p class="lg:pl-12 text-lg text-white/80 font-[410] mb-6">Give your AI agents the ground truth from production.</p>
        <p class="lg:pl-12 text-white/50 leading-[1.5] font-[410] text-lg mb-6">
          MCP server that provides production context to AI coding agents. A blended view from service-to-service, to API-to-API, to method-to-method. Trace entire requests across multiple services. Debug issues. Reduce MTTR. Ground AI-generated code in reality.
        </p>
        <div class="lg:pl-12 flex flex-wrap items-center gap-2">
          <span class="text-[11px] font-mono tracking-[0.2em] uppercase text-white/30 mr-1">Works with</span>
          <span class="text-xs font-mono text-white/70 border border-white/20 px-3 py-1">Cursor</span>
          <span class="text-xs font-mono text-white/70 border border-white/20 px-3 py-1">Windsurf</span>
          <span class="text-xs font-mono text-white/70 border border-white/20 px-3 py-1">GitHub Copilot</span>
          <span class="text-xs font-mono text-white/70 border border-white/20 px-3 py-1">Claude</span>
          <span class="text-xs font-mono text-white/70 border border-white/20 px-3 py-1">Custom agents</span>
        </div>
      </div>

      <!-- Full-width visual -->
      <div class="relative mb-16">
        <div class="w-full aspect-[16/9] overflow-hidden border rounded-none flex items-center justify-center" style="border-color: #2a2a2a; background: rgba(255,255,255,0.05);">
          <span class="text-sm text-white/30 font-mono">KarmaIQ MCP Diagram</span>
        </div>
      </div>

      <!-- Feature tiles -->
      <div class="relative">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border border-white/10">
          {karmaIQFeatures.map((f, i) => (
            <div class={`p-6 lg:p-8 ${(i % 3 !== 2) ? 'lg:border-r border-white/10' : ''} ${i < 3 ? 'border-b border-white/10' : ''} ${(i % 2 === 0 && i < 4) ? 'sm:border-r sm:max-lg:border-r' : ''} ${i < 4 ? 'sm:max-lg:border-b' : ''}`}>
              <h4 class="text-[16px] font-semibold text-white mb-2">{f.title}</h4>
              <p class="text-[16px] text-white/50 leading-[1.5] font-[410]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Contact />

</BaseLayout>

<script>
  function initProductPageVideos() {
    const videos = document.querySelectorAll<HTMLVideoElement>('.karmalens-product-video, .karmadomain-product-video');
    if (!videos.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const video = entry.target as HTMLVideoElement;
          if (entry.isIntersecting) {
            video.play();
          } else {
            video.pause();
          }
        });
      },
      { threshold: 0.3 }
    );

    videos.forEach((video) => observer.observe(video));
  }

  document.addEventListener('DOMContentLoaded', initProductPageVideos);

  // Navbar dark/light switching based on visible section
  function initNavbarTheme() {
    const darkSections = document.querySelectorAll<HTMLElement>('.dark-section');
    const navbar = document.getElementById('navbar');
    if (!navbar || !darkSections.length) return;

    let darkCount = 0;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            darkCount++;
          } else {
            darkCount = Math.max(0, darkCount - 1);
          }
        });

        if (darkCount > 0) {
          navbar.classList.add('navbar-dark');
        } else {
          navbar.classList.remove('navbar-dark');
        }
      },
      {
        rootMargin: '-50% 0px -50% 0px',
        threshold: 0,
      }
    );

    darkSections.forEach((section) => observer.observe(section));
  }

  document.addEventListener('DOMContentLoaded', () => {
    const navbar = document.getElementById('navbar');
    if (!document.querySelector('.dark-section')) {
      navbar?.classList.remove('navbar-dark');
    }
    initNavbarTheme();
  });
</script>

<style>
  /* Mobile: add bottom border on stacked feature tiles and reduce padding */
  @media (max-width: 639px) {
    .grid.grid-cols-1.sm\:grid-cols-2 > div {
      border-bottom: 1px solid #e5e7eb;
      padding: 1rem;
    }
    .grid.grid-cols-1.sm\:grid-cols-2 > div:last-child {
      border-bottom: none;
    }
    /* Dark sections */
    .dark-section .grid.grid-cols-1.sm\:grid-cols-2 > div {
      border-bottom-color: rgba(255, 255, 255, 0.1);
    }
  }
</style>
