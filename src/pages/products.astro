---
import BaseLayout from '../layouts/BaseLayout.astro';
import Security from '../components/landing/Security.astro';

const karmaPulseFeatures = [
  { title: 'API health dashboard', desc: 'Failing, slow, or drifting APIs, prioritized by impact' },
  { title: 'Dead code hotspots', desc: 'Services with maximum dormant code, safe to retire' },
  { title: 'Error drift tracking', desc: 'Week-over-week regression detection' },
  { title: 'Deployment error analysis', desc: 'Errors correlated to specific deploys' },
  { title: 'KarmaPulse AI', desc: 'Automated RCA with BYOK model support' },
  { title: 'Real test coverage', desc: 'Which tests exercise production-relevant paths' },
];

const karmaLensFeatures = [
  { title: 'Dead & dormant code identification', desc: 'Deterministic, based on real traffic' },
  { title: 'Method call frequency', desc: 'Distinguish hot paths from rarely-used code' },
  { title: 'API call frequency', desc: 'Which endpoints are live vs. effectively dead' },
  { title: 'Performance hotspots', desc: 'High latency or error methods, flagged in-editor' },
  { title: 'Execution path tracking', desc: 'How code actually runs in production' },
];

const karmaDomainFeatures = [
  { title: 'API-level dependency graph', desc: 'Deeper than any observability tool' },
  { title: 'Fan-out analysis', desc: 'Blast radius of any service, instantly' },
  { title: 'Multi-hop tracing', desc: 'Across queues, threads, sync and async systems' },
  { title: 'Golden signals & distributions', desc: 'Not just averages' },
  { title: 'System evolution timeline', desc: 'Detect architectural drift over time' },
  { title: 'Deterministic fan-out mapping', desc: 'Every downstream call, every query' },
];

const karmaIQFeatures = [
  { title: 'Blended multi-level view', desc: 'Service → API → method, seamlessly' },
  { title: 'Code understanding & debugging', desc: 'Real production context for any codebase' },
  { title: 'Deterministic RCA', desc: '100% data, not hallucinations' },
  { title: 'MTTR reduction', desc: 'Trace failures across services and methods in minutes' },
  { title: 'BYOK model support', desc: 'Use your own LLM keys' },
];
---

<BaseLayout title="Products — CodeKarma" description="Explore CodeKarma's production intelligence platform: KarmaPulse, KarmaLens, KarmaDomain, and KarmaIQ.">

<div id="products-page" class="products-bg">
  <!-- HERO -->
  <section class="relative pt-[220px] pb-0 overflow-hidden">
    <!-- Vertical gridlines -->
    <div class="absolute inset-0 mx-auto max-w-7xl px-[106px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="ts-border absolute left-0 top-0 bottom-0 w-px"></div>
        <div class="ts-border absolute right-0 top-0 bottom-0 w-px"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-[106px]">
      <!-- Hero heading -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 mb-20">
        <div>
          <h1 class="ts-heading text-[48px] tracking-tight leading-[1.1] font-semibold pl-4">
            <span>The Production Context Engine</span>
          </h1>
        </div>
        <div class="flex flex-col justify-start py-[12px]">
          <p class="ts-desc leading-[1.5] max-w-lg font-[410]" style="font-size: 18px;">
            One source of truth. Zero-touch instrumentation. Insights for humans and AI agents. Four products for four personas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- KARMAPULSE -->
  <section id="karmapulse" class="relative pt-40 pb-40 overflow-hidden">
    <!-- Vertical gridlines -->
    <div class="absolute inset-0 mx-auto max-w-7xl px-[106px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="ts-border absolute left-0 top-0 bottom-0 w-px"></div>
        <div class="ts-border absolute right-0 top-0 bottom-0 w-px"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-[106px]">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 mb-16">
        <!-- Text left -->
        <div>
          <p class="ts-muted text-sm font-mono tracking-[0.3em] uppercase mb-5">For Engineering Leadership</p>
          <h2 class="ts-heading pl-4 text-3xl sm:text-4xl tracking-tight leading-[1.1] font-semibold mb-4">
            KarmaPulse
          </h2>
          <p class="ts-text text-lg font-[410] mb-6">Know what needs attention. Act with confidence.</p>
          <p class="ts-desc leading-[1.5] font-[410]" style="font-size: 18px;">
            The operational command center for your engineering org. KarmaPulse surfaces the most important issues and the specific actions to fix them.
          </p>
        </div>
        <!-- Visual right -->
        <div class="ts-card flex items-center justify-center aspect-[4/3]">
          <span class="ts-muted text-sm font-mono">KarmaPulse Screenshot</span>
        </div>
      </div>

      <!-- Feature tiles -->
      <div class="relative">
        <div class="ts-tile-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {karmaPulseFeatures.map((f, i) => (
            <div class={`ts-tile p-6 lg:p-8 ${(i % 3 !== 2) ? 'lg:border-r' : ''} ${i < 3 ? 'border-b' : ''} ${(i % 2 === 0 && i < 4) ? 'sm:border-r sm:max-lg:border-r' : ''} ${i < 4 ? 'sm:max-lg:border-b' : ''}`}>
              <h4 class="ts-heading text-[16px] font-semibold mb-2">{f.title}</h4>
              <p class="ts-desc text-[16px] leading-[1.5] font-[410]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- KARMALENS (scroll-to-dark) -->
  <section id="karmalens" class="theme-section relative pt-40 pb-40 overflow-hidden" data-theme="dark">
    <!-- Vertical gridlines -->
    <div class="absolute inset-0 mx-auto max-w-7xl px-[106px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="absolute left-0 top-0 bottom-0 w-px ts-border"></div>
        <div class="absolute right-0 top-0 bottom-0 w-px ts-border"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-[106px]">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 mb-16">
        <!-- Visual left -->
        <div class="ts-card flex items-center justify-center aspect-[4/3] order-2 lg:order-1">
          <span class="ts-muted text-sm font-mono">KarmaLens IDE Screenshot</span>
        </div>
        <!-- Text right -->
        <div class="order-1 lg:order-2">
          <p class="theme-trigger text-sm font-mono tracking-[0.3em] uppercase text-brand-primary mb-5">For Developers</p>
          <h2 class="ts-heading pl-4 text-3xl sm:text-4xl tracking-tight leading-[1.1] font-semibold mb-4">
            KarmaLens
          </h2>
          <p class="ts-text text-lg font-[410] mb-6">Production intelligence, right where you code.</p>
          <p class="ts-desc leading-[1.5] font-[410] mb-8" style="font-size: 18px;">
            Brings production truth into your IDE. See dead and dormant code, method frequency, performance hotspots, and execution paths — overlaid on your code. 100% of traffic. Not sampled.
          </p>
          <div class="flex flex-wrap items-center gap-2">
            <span class="ts-muted text-[11px] font-mono tracking-[0.2em] uppercase mr-1">Supported</span>
            <span class="ts-tag text-xs font-mono px-3 py-1">JetBrains (IntelliJ)</span>
            <span class="ts-tag text-xs font-mono px-3 py-1">VS Code</span>
          </div>
        </div>
      </div>

      <!-- Feature tiles -->
      <div class="relative">
        <div class="ts-tile-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {karmaLensFeatures.map((f, i) => (
            <div class={`ts-tile p-6 lg:p-8 ${(i % 3 !== 2) ? 'lg:border-r' : ''} ${i < 3 ? 'border-b' : ''} ${(i % 2 === 0 && i < 4) ? 'sm:border-r sm:max-lg:border-r' : ''} ${i < 4 ? 'sm:max-lg:border-b' : ''}`}>
              <h4 class="ts-heading text-[16px] font-semibold mb-2">{f.title}</h4>
              <p class="ts-desc text-[16px] leading-[1.5] font-[410]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- KARMADOMAIN -->
  <section id="karmadomain" class="relative pt-40 pb-40 overflow-hidden">
    <!-- Vertical gridlines -->
    <div class="absolute inset-0 mx-auto max-w-7xl px-[106px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="ts-border absolute left-0 top-0 bottom-0 w-px"></div>
        <div class="ts-border absolute right-0 top-0 bottom-0 w-px"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-[106px]">
      <!-- Header -->
      <div class="max-w-3xl mb-12">
        <p class="ts-muted text-sm font-mono tracking-[0.3em] uppercase mb-5">For Architects & Platform Teams</p>
        <h2 class="ts-heading pl-4 text-3xl sm:text-4xl tracking-tight leading-[1.1] font-semibold mb-4">
          KarmaDomain
        </h2>
        <p class="ts-text text-lg font-[410] mb-6">See how your software actually connects and behaves.</p>
        <p class="ts-desc leading-[1.5] font-[410]" style="font-size: 18px;">
          The live graph of your production systems. Microservices, APIs, databases — connected in real time. Unlike traditional tools that show service-to-service, KarmaDomain shows API-to-API level dependencies. Every connection based on 100% production traffic.
        </p>
      </div>

      <!-- Full-width visual -->
      <div class="relative mb-16">
        <div class="ts-card w-full aspect-[21/9] flex items-center justify-center">
          <span class="ts-muted text-sm font-mono">KarmaDomain Topology Graph</span>
        </div>
      </div>

      <!-- Feature tiles -->
      <div class="relative">
        <div class="ts-tile-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {karmaDomainFeatures.map((f, i) => (
            <div class={`ts-tile p-6 lg:p-8 ${(i % 3 !== 2) ? 'lg:border-r' : ''} ${i < 3 ? 'border-b' : ''} ${(i % 2 === 0 && i < 4) ? 'sm:border-r sm:max-lg:border-r' : ''} ${i < 4 ? 'sm:max-lg:border-b' : ''}`}>
              <h4 class="ts-heading text-[16px] font-semibold mb-2">{f.title}</h4>
              <p class="ts-desc text-[16px] leading-[1.5] font-[410]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- KARMAIQ (scroll-to-dark) -->
  <section id="karmaiq" class="theme-section relative pt-40 pb-40 overflow-hidden" data-theme="dark">
    <!-- Vertical gridlines -->
    <div class="absolute inset-0 mx-auto max-w-7xl px-[106px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="absolute left-0 top-0 bottom-0 w-px ts-border"></div>
        <div class="absolute right-0 top-0 bottom-0 w-px ts-border"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-[106px]">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 mb-16">
        <!-- Text left -->
        <div>
          <p class="theme-trigger text-sm font-mono tracking-[0.3em] uppercase text-brand-primary mb-5">For AI Agents</p>
          <h2 class="ts-heading pl-4 text-3xl sm:text-4xl tracking-tight leading-[1.1] font-semibold mb-4">
            KarmaIQ
          </h2>
          <p class="ts-text text-lg font-[410] mb-6">Give your AI agents the ground truth from production.</p>
          <p class="ts-desc leading-[1.5] font-[410] mb-8" style="font-size: 18px;">
            MCP server that provides production context to AI coding agents. A blended view from service-to-service, to API-to-API, to method-to-method. Trace entire requests across multiple services. Debug issues. Reduce MTTR. Ground AI-generated code in reality.
          </p>
          <div class="flex flex-wrap items-center gap-2">
            <span class="ts-muted text-[11px] font-mono tracking-[0.2em] uppercase mr-1">Works with</span>
            <span class="ts-tag text-xs font-mono px-3 py-1">Cursor</span>
            <span class="ts-tag text-xs font-mono px-3 py-1">Windsurf</span>
            <span class="ts-tag text-xs font-mono px-3 py-1">GitHub Copilot</span>
            <span class="ts-tag text-xs font-mono px-3 py-1">Claude</span>
            <span class="ts-tag text-xs font-mono px-3 py-1">Custom agents</span>
          </div>
        </div>
        <!-- Visual right -->
        <div class="ts-card flex items-center justify-center aspect-[4/3]">
          <span class="ts-muted text-sm font-mono">KarmaIQ MCP Diagram</span>
        </div>
      </div>

      <!-- Feature tiles -->
      <div class="relative">
        <div class="ts-tile-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {karmaIQFeatures.map((f, i) => (
            <div class={`ts-tile p-6 lg:p-8 ${(i % 3 !== 2) ? 'lg:border-r' : ''} ${i < 3 ? 'border-b' : ''} ${(i % 2 === 0 && i < 4) ? 'sm:border-r sm:max-lg:border-r' : ''} ${i < 4 ? 'sm:max-lg:border-b' : ''}`}>
              <h4 class="ts-heading text-[16px] font-semibold mb-2">{f.title}</h4>
              <p class="ts-desc text-[16px] leading-[1.5] font-[410]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <Security />

</div><!-- end #products-page -->

<style>
  /* Make main transparent so wrapper bg shows through */
  :global(main):has(.products-bg) {
    background-color: transparent !important;
  }

  .products-bg {
    background-color: #ffffff;
    transition: background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .products-bg.is-dark {
    background-color: #0f0f0f;
  }

  /* Text colors that follow the page transition */
  .products-bg .ts-heading { color: #0f0f0f; transition: color 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
  .products-bg.is-dark .ts-heading { color: #ffffff; }

  .products-bg .ts-text { color: #1f2937; transition: color 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
  .products-bg.is-dark .ts-text { color: rgba(255,255,255,0.8); }

  .products-bg .ts-desc { color: #6b7280; transition: color 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
  .products-bg.is-dark .ts-desc { color: rgba(255,255,255,0.5); }

  .products-bg .ts-muted { color: #9ca3af; transition: color 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
  .products-bg.is-dark .ts-muted { color: rgba(255,255,255,0.3); }

  .products-bg .ts-tag {
    color: #4b5563;
    border: 1px solid #e5e7eb;
    transition: color 0.5s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .products-bg.is-dark .ts-tag {
    color: rgba(255,255,255,0.7);
    border-color: rgba(255,255,255,0.2);
  }

  .products-bg .ts-card {
    background-color: #f3f4f6;
    border: 1px solid #e5e7eb;
    transition: background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .products-bg.is-dark .ts-card {
    background-color: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.1);
  }

  .products-bg .ts-border {
    background-color: #e5e7eb;
    transition: background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .products-bg.is-dark .ts-border { background-color: rgba(255,255,255,0.1); }

  .products-bg .ts-tile-grid {
    border: 1px solid #e5e7eb;
    transition: border-color 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .products-bg.is-dark .ts-tile-grid { border-color: rgba(255,255,255,0.1); }

  .products-bg .ts-tile {
    border-color: #e5e7eb;
    transition: border-color 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .products-bg.is-dark .ts-tile { border-color: rgba(255,255,255,0.1); }

  .products-bg .ts-line {
    background-color: #e5e5e5;
    transition: background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .products-bg.is-dark .ts-line {
    background-color: #2a2a2a;
  }
</style>

<script>
  function initThemeSections() {
    const wrapper = document.getElementById('products-page');
    const triggers = document.querySelectorAll<HTMLElement>('.theme-section[data-theme="dark"] .theme-trigger');
    if (!wrapper || !triggers.length) return;

    let darkCount = 0;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            darkCount++;
          } else {
            darkCount = Math.max(0, darkCount - 1);
          }
        });

        const navbar = document.getElementById('navbar');
        if (darkCount > 0) {
          wrapper.classList.add('is-dark');
          navbar?.classList.add('navbar-dark');
        } else {
          wrapper.classList.remove('is-dark');
          navbar?.classList.remove('navbar-dark');
        }
      },
      {
        rootMargin: '25% 0px 0px 0px',
        threshold: 0,
      }
    );

    triggers.forEach((trigger) => observer.observe(trigger));
  }

  document.addEventListener('astro:page-load', () => {
    // Reset navbar to light when not on products page
    const navbar = document.getElementById('navbar');
    if (!document.getElementById('products-page')) {
      navbar?.classList.remove('navbar-dark');
    }
    initThemeSections();
  });
</script>

</BaseLayout>
