---
const footerLinks = [
  {
    title: 'Product',
    links: [
      { label: 'KarmaPulse', href: '#' },
      { label: 'KarmaLens', href: '#' },
      { label: 'KarmaDomain', href: '#' },
      { label: 'KarmaIQ', href: '#' },
      { label: 'Integrations', href: '#' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About Us', href: '#' },
      { label: 'Team', href: '#' },
      { label: 'Investors', href: '#' },
      { label: 'Press', href: '#' },
      { label: 'Careers', href: '#' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Terms', href: '#' },
      { label: 'Privacy Policy', href: '#' },
      { label: 'Security', href: '#' },
      { label: 'Cookie Policy', href: '#' },
    ],
  },
  {
    title: 'Connect',
    links: [
      { label: 'LinkedIn', href: '#', icon: 'ph ph-linkedin-logo' },
      { label: 'X', href: '#', icon: 'ph ph-x-logo' },
      { label: 'GitHub', href: '#', icon: 'ph ph-github-logo' },
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-dark fixed bottom-0 left-0 right-0 z-0 overflow-hidden">
  <div class="mx-auto max-w-7xl px-[106px] pt-32 pb-32 relative z-10">
    <!-- Top: Logo + tagline on left, links on right -->
    <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_3fr] gap-12 lg:gap-16">
      <!-- Left: Logo + tagline -->
      <div>
        <a href="/">
          <img src="/assets/Logos/Logo with name (LR)/Colored (for dark bg).svg" alt="CodeKarma" class="w-auto mb-6" style="height: 36px;" />
        </a>
        <p class="text-lg text-gray-400 leading-relaxed font-[410]">
          Production Intelligence<br />for the AI Era
        </p>
        <p class="text-sm text-gray-500 mt-6">
          &copy; {currentYear} CodeKarma Technologies Pvt. Ltd.<br />All rights reserved.
        </p>
      </div>

      <!-- Right: Link columns -->
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        {footerLinks.map((group) => (
          <div>
            <h3 class="text-sm font-semibold text-white mb-6">{group.title}</h3>
            <ul class="space-y-3">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-gray-400 hover:text-white transition-colors inline-flex items-center gap-2"
                  >
                    {link.icon && <i class={`${link.icon} text-base`}></i>}
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

  </div>

  <!-- Large background text -->
  <div class="absolute bottom-0 left-0 right-0 overflow-hidden pointer-events-none select-none" aria-hidden="true">
    <p class="text-[12vw] font-semibold text-white/[0.03] leading-none tracking-tight whitespace-nowrap text-center" style="transform: translateY(25%);">
      CODEKARMA
    </p>
  </div>
</footer>
