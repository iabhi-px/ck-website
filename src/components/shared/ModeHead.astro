<script is:inline>
  (function () {
    var root = document.documentElement;

    function getMode() {
      return new URLSearchParams(window.location.search).get('mode') === 'agent' ? 'agent' : 'human';
    }

    function clearHumanScrollState() {
      root.classList.remove('products-tab-native-snap');
      if (document.body) {
        document.body.classList.remove('products-tab-native-snap');
      }
    }

    function isAgentMode() {
      return root.getAttribute('data-ck-mode') === 'agent';
    }

    function releaseAgentScroll(event) {
      if (!isAgentMode()) return;
      clearHumanScrollState();
      event.stopImmediatePropagation();
    }

    root.setAttribute('data-ck-mode', getMode());
    if (isAgentMode()) clearHumanScrollState();

    window.addEventListener('wheel', releaseAgentScroll, { capture: true, passive: true });
    window.addEventListener('touchstart', releaseAgentScroll, { capture: true, passive: true });
    window.addEventListener('touchmove', releaseAgentScroll, { capture: true, passive: true });
    window.addEventListener('ck:modechange', function () {
      if (isAgentMode()) clearHumanScrollState();
    });
  })();
</script>

<style is:global>
  html[data-ck-mode="agent"] {
    background: #0b0b0c;
    color-scheme: dark;
    scroll-behavior: auto !important;
    scroll-snap-type: none !important;
  }

  html[data-ck-mode="agent"] body {
    background: #0b0b0c !important;
    color: #f5f5f0 !important;
    font-family: "Geist Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace !important;
    padding-bottom: 0 !important;
    scroll-behavior: auto !important;
    scroll-snap-type: none !important;
    overscroll-behavior-y: auto;
  }

  html[data-ck-mode="agent"] *,
  html[data-ck-mode="agent"] *::before,
  html[data-ck-mode="agent"] *::after {
    scroll-snap-align: none !important;
    scroll-snap-stop: normal !important;
  }

  html[data-ck-mode="human"] .ck-agent-shell {
    display: none !important;
  }

  html[data-ck-mode="agent"] .ck-human-site,
  html[data-ck-mode="agent"] #mobile-cta-bar,
  html[data-ck-mode="agent"] #mobile-sheet,
  html[data-ck-mode="agent"] #mobile-sheet-overlay {
    display: none !important;
  }
</style>
