---
const items = [
  {
    label: 'BYOC',
    description: 'All data stays in your cloud. Your perimeter. Your control.',
    icon: 'custom-byoc',
  },
  {
    label: 'SaaS',
    description: 'Managed by CodeKarma. Enterprise-grade. No infra overhead.',
    icon: 'custom-saas',
  },
  {
    label: 'SOC 2 Type 2',
    description: 'Independently audited. Continuously compliant.',
    icon: 'custom-soc2',
  },
  {
    label: 'No data captured',
    description: 'No PII. No payloads. No request bodies. Behavioral telemetry only.',
    icon: 'custom-nodata',
  },
];
---

<section id="security-section" class="relative bg-white pt-20 pb-40">
  <!-- Vertical gridlines -->
  <div class="absolute inset-0 mx-auto max-w-7xl px-[106px] pointer-events-none z-0" aria-hidden="true">
    <div class="relative h-full">
      <div class="absolute left-0 top-0 bottom-0 w-px bg-gray-200"></div>
      <div class="absolute right-0 top-0 bottom-0 w-px bg-gray-200"></div>
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-[106px]">
    <!-- Two-column layout: Title left, Grid right -->
    <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] border border-gray-200">
      <!-- Left: Section header -->
      <div class="p-8 lg:p-10 flex flex-col justify-center border-b lg:border-b-0 lg:border-r border-gray-200 bg-brand-dark">
        <p class="text-sm font-mono tracking-[0.3em] uppercase text-brand-primary mb-5">Security</p>
        <h2 class="text-[40px] sm:text-[48px] tracking-tight text-white leading-[1.1] font-semibold mb-8">
          Security first.<br />Always.
        </h2>
        <a
          href="/solutions"
          class="inline-flex items-center gap-2 text-white font-medium text-lg hover:opacity-70 transition-opacity duration-200"
        >
          Learn more
          <i class="ph ph-arrow-right text-[18px]"></i>
        </a>
      </div>

      <!-- Right: 2x2 grid -->
      <div class="security-grid">
        {items.map((item, index) => (
