<style>
  .security-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
  }

  .security-cell {
    position: relative;
    transition: background-color 0.2s ease;
  }

  .security-cell:hover {
    background-color: #fafafa;
  }

  .security-cell .flex.items-center.justify-center {
    transition: transform 0.3s ease;
  }

  .security-cell:hover .flex.items-center.justify-center:not(.soc2-icon) {
    transform: scale(2);
  }

  .security-cell .flex-1 svg * {
    transition: stroke-width 0.3s ease;
  }

  .security-cell:hover .flex-1 svg circle:first-child {
    stroke-width: 2 !important;
  }

  .security-cell:hover .flex-1 svg circle:nth-child(2) {
    stroke-width: 1.5 !important;
  }

  .security-cell:hover .flex-1 svg line {
    stroke-width: 1.5 !important;
  }

  @media (max-width: 768px) {
    .security-grid {
      grid-template-columns: 1fr;
    }
    .security-cell {
      border-right: none !important;
      border-bottom: 1px solid #e5e5e5;
    }
    .security-cell:last-child {
      border-bottom: none;
    }
  }
</style>
