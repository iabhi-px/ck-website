---
type DeadStage = 1 | 2 | 3;
type HighlightStage = 'feature' | 'physical';

type CodeLine = {
  text: string;
  deadStage?: DeadStage;
  highlightStage?: HighlightStage;
  metricsBefore?: string;
};

const codeLineStart = 72;
const codeLines: CodeLine[] = [
  { text: '@Override', deadStage: 1 },
  { text: 'public Order getOrderById(Long orderId) {', deadStage: 1 },
  { text: '    // Find order', deadStage: 1 },
  { text: '    Order order = mockOrders.stream()', deadStage: 1 },
  { text: '            .filter(o -> o.getId().equals(orderId))', deadStage: 1 },
  { text: '            .findFirst()', deadStage: 1 },
  { text: '            .orElse(createMockOrder(orderId));', deadStage: 1 },
  { text: '' },
  { text: '    String orderType = order.getType();', deadStage: 1 },
  { text: '' },
  { text: '    // Branch based on order type with different latencies and errors', deadStage: 1 },
  { text: '    switch (orderType) {', deadStage: 1 },
  { text: '        case "virtual":', deadStage: 1 },
  { text: '            processVirtualOrder(order);', deadStage: 1 },
  { text: '            break;', deadStage: 1 },
  { text: '        case "physical":', deadStage: 1, highlightStage: 'physical' },
  { text: '            try {', deadStage: 1, highlightStage: 'physical' },
  { text: '                processPhysicalOrder(order);', deadStage: 1, highlightStage: 'physical' },
  { text: '            } catch (Exception e) {', deadStage: 1, highlightStage: 'physical' },
  {
    text: '                System.out.println("Physical order processing failed: " + e.getMessage());',
    deadStage: 1,
    highlightStage: 'physical',
  },
  { text: '                fallbackOrderHandler(order);', deadStage: 1, highlightStage: 'physical' },
  { text: '            }', deadStage: 1, highlightStage: 'physical' },
  { text: '            break;', deadStage: 1, highlightStage: 'physical' },
  { text: '        default:', deadStage: 1 },
  { text: '            handleUnknownOrder(order);', deadStage: 1 },
  { text: '    }', deadStage: 1 },
  { text: '' },
  { text: '    OrderUtil.enrichOrder(order);', deadStage: 1 },
  { text: '    return order;', deadStage: 1 },
  { text: '}', deadStage: 1 },
  { text: '' },
  { text: 'private void processVirtualOrder(Order order) {', deadStage: 1, highlightStage: 'feature' },
  {
    text: '    System.out.println("Processing virtual order: " + order.getId());',
    deadStage: 1,
    highlightStage: 'feature',
  },
  { text: '    generateLicense(order);', deadStage: 1, highlightStage: 'feature' },
  { text: '    sendUserEmail(order);', deadStage: 1, highlightStage: 'feature' },
  { text: '    createAuditLog(order, "virtual_processed");', deadStage: 1, highlightStage: 'feature' },
  { text: '    order.setStatus("COMPLETED");', deadStage: 1, highlightStage: 'feature' },
  { text: '}', deadStage: 1, highlightStage: 'feature' },
  { text: '' },
  { text: 'private void processPhysicalOrder(Order order) {' },
  { text: '    System.out.println("Processing physical order: " + order.getId());' },
  { text: '    validateInventory(order);' },
  { text: '    estimateShipping(order);' },
  { text: '    dispatchToVendor(order);' },
  { text: '' },
  { text: '    // Simulate error for every 5th order' },
  { text: '    if (order.getId() % 5 == 0) {' },
  { text: '        throw new RuntimeException("Inventory service failure for order: " + order.getId());' },
  { text: '    }' },
  { text: '' },
  { text: '    order.setStatus("PROCESSING");' },
  { text: '}' },
];

function escapeHtml(value: string) {
  return value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#39;');
}

function highlightJava(value: string) {
  let html = escapeHtml(value);

  if (html.trim().startsWith('/**') || html.trim().startsWith('*') || html.trim().startsWith('//')) {
    return `<span class="tok-comment">${html}</span>`;
  }

  const strings: string[] = [];
  html = html.replace(/(&quot;[^&]*?&quot;)/g, (match) => {
    strings.push(`<span class="tok-string">${match}</span>`);
    return `__CODEKARMA_STRING_${strings.length - 1}__`;
  });

  html = html.replace(
    /\b(package|public|class|private|final|return|new|for|if|null|boolean|void|switch|case|break|default|try|catch|throw)\b/g,
    '<span class="tok-keyword">$1</span>'
  );
  html = html.replace(/(@[A-Za-z0-9_]+)/g, '<span class="tok-annotation">$1</span>');
  html = html.replace(
    /\b(Order|Long|String|OrderUtil|Exception|RuntimeException|System)\b/g,
    '<span class="tok-type">$1</span>'
  );
  html = html.replace(
    /\b(getOrderById|stream|filter|getId|equals|findFirst|orElse|createMockOrder|getType|processVirtualOrder|processPhysicalOrder|println|getMessage|fallbackOrderHandler|handleUnknownOrder|enrichOrder|generateLicense|sendUserEmail|createAuditLog|setStatus|validateInventory|estimateShipping|dispatchToVendor)\b/g,
    '<span class="tok-method">$1</span>'
  );
  html = html.replace(/__CODEKARMA_STRING_(\d+)__/g, (_, index) => strings[Number(index)] ?? '');

  return html;
}

function getLineStyle(line: CodeLine) {
  const strikeProgress = line.deadStage ? `--strike-progress:var(--strike-${line.deadStage});` : '';
  const highlightProgress = line.highlightStage
    ? [
        `--line-highlight:var(--${line.highlightStage}-highlight)`,
        `--line-highlight-rail:var(--${line.highlightStage}-highlight-rail)`,
        `--line-highlight-glow:var(--${line.highlightStage}-highlight-glow)`,
        `--line-highlight-zoom:var(--${line.highlightStage}-highlight-zoom)`,
      ].join(';')
    : '';
  const highlightOffset = line.highlightStage
    ? `--line-highlight-y:var(--${line.highlightStage}-highlight-y);`
    : '';

  return [
    `--line-chars:${Math.max(line.text.trimEnd().length, 1)}`,
    strikeProgress,
    highlightProgress,
    highlightOffset,
    'position:relative',
    'display:grid',
    'grid-template-columns:74px minmax(0,1fr)',
    'min-height:1.5em',
  ]
    .filter(Boolean)
    .join(';');
}
---

<section
  id="dead-code-statement"
  data-hide-navbar-on-scroll
  class="dead-code-section"
  style="position:relative;min-height:380vh;overflow:clip;background:#0f0f0f;--ide-dock:0;--ide-base-opacity:1;--ide-x:-26vw;--ide-y:clamp(96px,8vh,128px);--ide-scale:1;--copy-reveal:0;--copy-blur:10px;--copy-y:20px;--copy-top-offset:0px;--base-title:1;--base-title-y:0px;--base-title-blur:0px;--feature-title:0;--feature-title-y:20px;--feature-title-blur:10px;--physical-title:0;--physical-title-y:20px;--physical-title-blur:10px;--feature-annotation:0;--physical-annotation:0;--feature-annotation-top:50%;--feature-annotation-y:52%;--physical-annotation-y:58%;--conclusion-title:0;--conclusion-blur:10px;--conclusion-y:20px;--editor-left:24.44%;--editor-top:10.88%;--editor-width:71.05%;--editor-height:83.22%;--editor-radius:0px;--editor-inner-left:0px;--code-focus-scale:1;--code-focus-x:0px;--code-focus-y:0px;--annotation-target-x:0px;--strike-1:0;--strike-2:0;--strike-3:0;--feature-highlight:0;--feature-highlight-rail:0;--feature-highlight-glow:0;--feature-highlight-zoom:0;--physical-highlight:0;--physical-highlight-rail:0;--physical-highlight-glow:0;--physical-highlight-zoom:0;--feature-highlight-y:0;--physical-highlight-y:0"
>
  <div
    class="dead-code-sticky"
  >
    <div
      class="dead-code-layout"
    >
      <div class="dead-code-heading relative z-10 w-full text-left">
        <p class="dead-code-label text-sm font-mono tracking-[0.3em] uppercase text-white/40 mb-5">
          Do you know?
        </p>
        <h2
          class="dead-code-title text-[28px] sm:text-[40px] md:text-[48px] tracking-tight text-white leading-[1.1] font-semibold"
          aria-live="polite"
        >
          <span class="dead-code-title-swap dead-code-title-swap--base">
            More than half of your<br />code is dead or dormant
          </span>
          <span class="dead-code-title-swap dead-code-title-swap--feature">
            Retired features
          </span>
          <span class="dead-code-title-swap dead-code-title-swap--physical">
            Untaken paths
          </span>
          <span class="dead-code-title-swap dead-code-title-swap--service">
            Services nobody<br />calls anymore.
          </span>
        </h2>
      </div>
      <div class="dead-code-visual-slot">
      <div
        class="dead-code-frame"
      >
        <img
          src="/images/landing/karma-ide-base.svg"
          alt="IntelliJ-style IDE with CodeKarma dead-code insights"
          class="dead-code-ide-image"
          loading="eager"
          decoding="async"
          style="display:block;width:100%;height:100%;object-fit:contain;user-select:none"
        />

	      <div
		        class="dead-code-editor-overlay"
		        aria-label="Java code with dead sections highlighted on scroll"
		        style='position:absolute;left:var(--editor-left);top:var(--editor-top);width:var(--editor-width);height:var(--editor-height);z-index:2;overflow:hidden;border-top:1px solid rgba(72,78,86,.85);border-left:1px solid rgba(72,78,86,.75);border-radius:var(--editor-radius);background:#1f2024;color:#d9dde4;font-family:"JetBrains Mono","Geist Mono",ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace;font-weight:500;font-synthesis:none'
	      >
	        <span
	          aria-hidden="true"
	          class="dead-code-gutter-border"
	          style="position:absolute;top:0;bottom:0;left:calc(var(--editor-inner-left) + 74px);z-index:5;width:1px;background:rgba(72,78,86,.85)"
	        ></span>
        <div
	          class="dead-code-lines"
	          style="position:relative;z-index:1;padding-top:10px;font-size:13px;line-height:1.5;letter-spacing:0;font-weight:500"
        >
          {
            codeLines.map((line, index) => (
              <>
                {line.metricsBefore && (
                  <div
                    class="dead-code-metrics-row"
                  >
                    <span aria-hidden="true"></span>
                    <span
                      class="dead-code-metrics"
                    >
                      <img
                        src="/images/landing/ide-icon-16px.svg"
                        alt=""
                        aria-hidden="true"
                      />
                      <span>{line.metricsBefore}</span>
                    </span>
                  </div>
                )}
                <div
	                  class:list={[
	                    'dead-code-line',
	                    line.deadStage && 'dead-code-line--dead',
	                    line.deadStage && `dead-code-line--stage-${line.deadStage}`,
	                    line.highlightStage && 'dead-code-line--highlight',
	                  ]}
                  data-highlight-stage={line.highlightStage}
                  style={getLineStyle(line)}
                >
                  <span
                    class="dead-code-number"
                    style="position:relative;z-index:2;padding-right:18px;color:#69727d;text-align:right"
                  >
                    {codeLineStart + index}
                  </span>
                  <span
	                  class="dead-code-source"
	                  style="position:relative;z-index:2;display:block;min-width:0;overflow:hidden;padding-left:18px;color:#d9dde4;white-space:pre"
                  >
                    <span class="dead-code-text" set:html={highlightJava(line.text)} />
                  </span>
                </div>
              </>
            ))
          }
        </div>
      </div>
        <div class="dead-code-annotation dead-code-annotation--feature" aria-hidden="true">
          <span class="dead-code-annotation-label">Retired features</span>
          <span class="dead-code-annotation-rule"></span>
        </div>
        <div class="dead-code-annotation dead-code-annotation--physical" aria-hidden="true">
          <span class="dead-code-annotation-label">Untaken paths</span>
          <span class="dead-code-annotation-rule"></span>
        </div>
    </div>
    </div>
      <div class="dead-code-conclusion" aria-live="polite">
        <p class="dead-code-conclusion-label">
          Retired features.<br />Untaken paths.
        </p>
        <h2 class="dead-code-conclusion-title">
          Services nobody<br />call anymore.
        </h2>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .dead-code-section {
    position: relative;
				    min-height: 380vh;
    overflow: clip;
    background: #0f0f0f;
    --ide-dock: 0;
    --ide-base-opacity: 1;
    --ide-x: -26vw;
    --ide-y: clamp(96px, 8vh, 128px);
    --ide-scale: 1;
    --copy-reveal: 0;
	    --copy-blur: 10px;
	    --copy-y: 20px;
	    --copy-top-offset: 0px;
	    --base-title: 1;
	    --base-title-y: 0px;
	    --base-title-blur: 0px;
	    --feature-title: 0;
	    --feature-title-y: 20px;
	    --feature-title-blur: 10px;
	    --physical-title: 0;
	    --physical-title-y: 20px;
	    --physical-title-blur: 10px;
	    --service-title: 0;
	    --service-title-y: 20px;
	    --service-title-blur: 10px;
	    --feature-annotation: 0;
	    --physical-annotation: 0;
	    --feature-annotation-top: 50%;
	    --feature-annotation-y: 52%;
	    --physical-annotation-y: 58%;
	    --conclusion-title: 0;
	    --conclusion-blur: 10px;
	    --conclusion-y: 20px;
	    --editor-left: 24.44%;
	    --editor-top: 10.88%;
	    --editor-width: 71.05%;
	    --editor-height: 83.22%;
	    --editor-radius: 0px;
	    --editor-inner-left: 0px;
	    --code-focus-scale: 1;
	    --code-focus-x: 0px;
	    --code-focus-y: 0px;
	    --strike-1: 0;
	    --strike-2: 0;
	    --strike-3: 0;
	    --feature-highlight: 0;
	    --feature-highlight-rail: 0;
	    --feature-highlight-glow: 0;
	    --feature-highlight-zoom: 0;
	    --physical-highlight: 0;
	    --physical-highlight-rail: 0;
	    --physical-highlight-glow: 0;
	    --physical-highlight-zoom: 0;
	    --feature-highlight-y: 0;
	    --physical-highlight-y: 0;
	  }

  .dead-code-sticky {
    position: sticky;
    top: 0;
    display: flex;
    min-height: 100vh;
    min-height: 100svh;
    align-items: start;
    justify-content: center;
    overflow: hidden;
    padding: clamp(54px, 7vh, 78px) 0 22px;
  }

  .dead-code-layout {
    position: relative;
    z-index: 1;
    display: grid;
    width: min(96vw, 1760px);
    grid-template-columns: minmax(280px, 0.82fr) minmax(0, 2.18fr);
    align-items: start;
    gap: clamp(24px, 3.2vw, 48px);
  }

  .dead-code-visual-slot {
    position: relative;
    min-height: clamp(400px, 58vw, 720px);
    overflow: visible;
  }

  .dead-code-heading {
    width: 100%;
    padding-left: clamp(24px, 2.4vw, 48px);
    text-align: left;
    opacity: calc(var(--copy-reveal) * var(--base-title));
    filter: blur(var(--copy-blur));
    transform: translate3d(0, calc(var(--copy-top-offset) + var(--copy-y)), 0);
    will-change: transform, opacity, filter;
  }

	  .dead-code-title {
	    position: relative;
	    display: block;
	    max-width: 680px;
	    min-height: 2.2em;
	    text-wrap: balance;
	  }

	  .dead-code-title-swap {
	    position: absolute;
	    left: 0;
	    top: 0;
	    width: 100%;
	    opacity: 0;
	    filter: blur(10px);
	    transform: translateY(18px);
	    will-change: opacity, transform, filter;
	  }

	  .dead-code-title-swap--base {
	    opacity: var(--base-title);
	    filter: blur(var(--base-title-blur));
	    transform: translateY(var(--base-title-y));
	  }

	  .dead-code-title-swap--feature {
	    opacity: var(--feature-title);
	    filter: blur(var(--feature-title-blur));
	    transform: translateY(var(--feature-title-y));
	  }

	  .dead-code-title-swap--physical {
	    opacity: var(--physical-title);
	    filter: blur(var(--physical-title-blur));
	    transform: translateY(var(--physical-title-y));
	  }

	  .dead-code-title-swap--service {
	    opacity: var(--service-title);
	    filter: blur(var(--service-title-blur));
	    transform: translateY(var(--service-title-y));
	  }

	  .dead-code-conclusion {
	    position: absolute;
	    left: 0;
	    top: 0;
	    z-index: 6;
	    width: min(680px, max(280px, calc(38vw - 24px)));
	    padding-left: clamp(24px, 2.4vw, 48px);
	    color: #fff;
	    font-family: "Geist", system-ui, sans-serif;
	    opacity: var(--conclusion-title);
	    filter: blur(var(--conclusion-blur));
	    transform: translate3d(0, calc(var(--copy-top-offset) + var(--conclusion-y)), 0);
	    pointer-events: none;
	    will-change: opacity, transform, filter;
	  }

	  .dead-code-conclusion-label {
	    margin: 0 0 20px;
	    color: rgba(255, 255, 255, 0.4);
	    font-family: "Geist Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
	    font-size: 14px;
	    font-weight: 500;
	    letter-spacing: 0.3em;
	    line-height: 1.45;
	    text-transform: uppercase;
	  }

	  .dead-code-conclusion-title {
	    margin: 0;
	    max-width: 680px;
	    color: #fff;
	    font-size: 28px;
	    font-weight: 600;
	    letter-spacing: -0.025em;
	    line-height: 1.1;
	    text-align: left;
	    text-shadow: 0 0 18px rgba(0, 0, 0, 0.55);
	    text-wrap: balance;
	  }

	  .dead-code-annotation {
	    position: absolute;
	    left: -350px;
	    z-index: 5;
	    display: flex;
	    width: calc(var(--editor-left) + 450px + var(--annotation-target-x));
	    align-items: center;
	    gap: 14px;
	    color: #fff;
	    font-family: "Geist", system-ui, sans-serif;
	    font-size: 28px;
	    font-weight: 600;
	    letter-spacing: -0.025em;
	    line-height: 1.1;
	    pointer-events: none;
	    will-change: opacity, transform, filter;
	  }

	  .dead-code-annotation--feature {
	    top: var(--feature-annotation-top);
	    opacity: var(--feature-annotation);
	    filter: blur(calc((1 - var(--feature-annotation)) * 6px));
	    transform: translateX(calc((1 - var(--feature-annotation)) * -18px));
	  }

	  .dead-code-annotation--physical {
	    top: 56%;
	    opacity: var(--physical-annotation);
	    filter: blur(calc((1 - var(--physical-annotation)) * 6px));
	    transform: translateX(calc((1 - var(--physical-annotation)) * -18px));
	  }

	  .dead-code-annotation-label {
	    flex: 0 0 auto;
	    text-shadow: 0 0 18px rgba(0, 0, 0, 0.55);
	    white-space: nowrap;
	  }

	  @media (min-width: 640px) {
	    .dead-code-conclusion-title,
	    .dead-code-annotation {
	      font-size: 40px;
	    }
	  }

	  @media (min-width: 768px) {
	    .dead-code-conclusion-title,
	    .dead-code-annotation {
	      font-size: 48px;
	    }
	  }

	  .dead-code-annotation-rule {
	    position: relative;
	    display: block;
	    height: 1px;
	    flex: 1 1 auto;
	    background: linear-gradient(90deg, rgba(205, 255, 82, 0), rgba(205, 255, 82, 0.72));
	    transform-origin: right center;
	  }

	  .dead-code-annotation--feature .dead-code-annotation-rule {
	    transform: scaleX(var(--feature-annotation));
	  }

	  .dead-code-annotation--physical .dead-code-annotation-rule {
	    transform: scaleX(var(--physical-annotation));
	  }

	  .dead-code-annotation-rule::after {
	    content: "";
	    position: absolute;
	    right: -3px;
	    top: 50%;
	    width: 6px;
	    height: 6px;
	    border-radius: 999px;
	    background: #cdff52;
	    box-shadow: 0 0 14px rgba(205, 255, 82, 0.55);
	    transform: translateY(-50%);
	  }

  .dead-code-frame {
    position: absolute;
    left: 50%;
    top: 50%;
	    width: min(92vw, 1500px);
	    aspect-ratio: 1596 / 1020;
	    z-index: 1;
	    transform-origin: center center;
	    transform: translate3d(calc(-50% + var(--ide-x)), calc(-50% + var(--ide-y)), 0) scale(var(--ide-scale));
	    backface-visibility: hidden;
	    will-change: transform;
	  }

  .dead-code-ide-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: var(--ide-base-opacity);
    user-select: none;
    will-change: opacity;
  }

	  .dead-code-editor-overlay {
	    position: absolute;
	    left: var(--editor-left);
	    top: var(--editor-top);
	    width: var(--editor-width);
	    height: var(--editor-height);
	    box-sizing: border-box;
	    z-index: 2;
	    overflow: hidden;
	    border-top: 1px solid rgba(72, 78, 86, 0.85);
	    border-left: 1px solid rgba(72, 78, 86, 0.75);
	    border-radius: var(--editor-radius);
		    background: #1f2024;
		    color: #d9dde4;
		    font-family: "JetBrains Mono", "Geist Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
		      monospace;
		    font-weight: 500;
		    font-synthesis: none;
		    contain: layout paint style;
		    will-change: left, top, width, height, border-radius;
		  }

	  .dead-code-gutter-border {
	    position: absolute;
	    top: 0;
	    bottom: 0;
	    left: calc(var(--editor-inner-left) + 74px);
	    z-index: 5;
	    width: 1px;
	    background: rgba(72, 78, 86, 0.85);
	  }

	  .dead-code-lines {
	    position: relative;
	    z-index: 1;
	    box-sizing: border-box;
	    width: 100%;
	    padding-top: 10px;
	    padding-left: var(--editor-inner-left);
	    padding-right: var(--editor-inner-left);
	    font-size: 13px;
	    font-weight: 500;
	    line-height: 1.5;
	    letter-spacing: 0;
	    transform: translate3d(var(--code-focus-x), var(--code-focus-y), 0) scale(var(--code-focus-scale));
	    transform-origin: calc(var(--editor-inner-left) + 92px) 0;
	    backface-visibility: hidden;
	    will-change: transform;
	  }

	  .dead-code-line {
		    position: relative;
		    display: grid;
		    grid-template-columns: 74px minmax(0, 1fr);
			    min-height: 1.5em;
	    --strike-progress: 0;
	    --line-highlight: 0;
	    --line-highlight-rail: 0;
	    --line-highlight-glow: 0;
	    --line-highlight-zoom: 0;
	    --line-highlight-y: 0;
		  }

  .dead-code-number {
    position: relative;
