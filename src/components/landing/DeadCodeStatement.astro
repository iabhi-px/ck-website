<script>
  import gsap from 'gsap';

  function clamp(value: number, min = 0, max = 1) {
    return Math.min(Math.max(value, min), max);
  }

  function smoothStep(start: number, end: number, value: number) {
    const progress = clamp((value - start) / (end - start));
    return progress * progress * (3 - 2 * progress);
  }

  function heldReveal(
    enterStart: number,
    enterEnd: number,
    exitStart: number,
    exitEnd: number,
    value: number
  ) {
    return smoothStep(enterStart, enterEnd, value) * (1 - smoothStep(exitStart, exitEnd, value));
  }

  const featurePause = {
    enterStart: 0.69,
    enterEnd: 0.76,
    exitStart: 0.82,
    exitEnd: 0.875,
  };

  const physicalPause = {
    enterStart: 0.895,
    enterEnd: 0.93,
    exitStart: 0.975,
    exitEnd: 0.998,
  };

  const deadCodeScrollBindingVersion = 'target-step-carousel-v24';
  type DeadCodeWindow = Window & {
    __deadCodeScrollCleanup?: () => void;
    __ckStepScrollOwner?: string;
  };

  function initDeadCodeScroll() {
    const section = document.getElementById('dead-code-statement');
    if (!section) return;

    const deadCodeWindow = window as DeadCodeWindow;
    if (section.dataset.deadCodeScrollBound === deadCodeScrollBindingVersion) return;

    deadCodeWindow.__deadCodeScrollCleanup?.();

	    section.dataset.deadCodeScrollBound = deadCodeScrollBindingVersion;
		    const layout = section.querySelector<HTMLElement>('.dead-code-layout');
		    const visualSlot = section.querySelector<HTMLElement>('.dead-code-visual-slot');
		    const ideFrame = section.querySelector<HTMLElement>('.dead-code-frame');
		    const editorOverlay = section.querySelector<HTMLElement>('.dead-code-editor-overlay');
		    const codeLinesElement = section.querySelector<HTMLElement>('.dead-code-lines');
			    if (!layout || !visualSlot || !ideFrame || !editorOverlay || !codeLinesElement) return;

	    function getStageLines(stage: 'feature' | 'physical') {
	      return Array.from(
	        section!.querySelectorAll<HTMLElement>(`.dead-code-line[data-highlight-stage="${stage}"]`)
	      );
	    }

	    function getStageCenterY(stage: 'feature' | 'physical') {
	      const stageLines = getStageLines(stage);
	      const firstLine = stageLines[0];
	      const lastLine = stageLines[stageLines.length - 1];
	      if (!firstLine || !lastLine) return codeLinesElement.clientHeight * 0.5;

	      return firstLine.offsetTop + (lastLine.offsetTop + lastLine.offsetHeight - firstLine.offsetTop) / 2;
	    }

    const progressState = { value: 0 };
	    const animationCompleteAt = 0.8;
    const choreographySteps = [
      { name: 'ide', progress: 0 },
      { name: 'intro', progress: 0.48 },
      { name: 'feature', progress: 0.79 },
      { name: 'physical', progress: 0.94 },
      { name: 'conclusion', progress: 1 },
    ];

	    function renderScrollProgress(scrollProgress: number) {
	      render(scrollProgress / animationCompleteAt);
	    }

	    function render(sectionProgress: number) {
	      const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
	      sectionProgress = clamp(sectionProgress);
	      let dockProgress = smoothStep(0, 0.48, sectionProgress);
		      let copyReveal = smoothStep(0.08, 0.44, sectionProgress);
	      const isMobile = window.matchMedia('(max-width: 767px)').matches;
      const layoutRect = layout.getBoundingClientRect();
      const visualSlotRect = visualSlot.getBoundingClientRect();
      const frameWidth = Math.max(ideFrame.offsetWidth, 1);
      const layoutCenterX = layoutRect.left + layoutRect.width / 2;
      const visualSlotCenterX = visualSlotRect.left + visualSlotRect.width / 2;
      const startX = layoutCenterX - visualSlotCenterX;
      const dockWidth = Math.min(visualSlotRect.width * 1.08, layoutRect.width * 0.76);
      const dockScale = clamp(dockWidth / frameWidth, 0.64, 1);
      let ideX = startX * (1 - dockProgress);
      const startY = clamp(viewportHeight * 0.08, 96, 128);
      const dockY = clamp(viewportHeight * 0.005, 4, 12);
      let ideY = startY + (dockY - startY) * dockProgress;
      let ideScale = 1 + (dockScale - 1) * dockProgress;
      const ideHeight = ideFrame.offsetHeight * ideScale;
      const ideTopOffset = visualSlotRect.height / 2 - ideHeight / 2 + ideY;
      let copyTopOffset = (ideTopOffset + 30) * dockProgress;
      const editorExpand = dockProgress;
      const finalEditorInset = 6.25;
      let editorLeft = 24.44 * (1 - editorExpand) + finalEditorInset * editorExpand;
      let editorTop = 10.88 * (1 - editorExpand);
      let editorWidth = 71.05 + (100 - finalEditorInset * 2 - 71.05) * editorExpand;
      let editorHeight = 83.22 + (100 - 83.22) * editorExpand;
      let editorRadius = 9 * editorExpand;
      const finalEditorInnerLeft = clamp(window.innerWidth * 0.024, 30, 52);
      let editorInnerLeft = finalEditorInnerLeft * editorExpand;
		      let ideBaseOpacity = 1 - smoothStep(0.18, 0.44, sectionProgress);
		      let deadCut = copyReveal;
			      const baseTitleEnter = 1;
			      const baseTitleExit = smoothStep(0.62, 0.7, sectionProgress);
			      const featureTitleEnter = smoothStep(0.71, 0.79, sectionProgress);
			      const featureTitleExit = smoothStep(0.82, 0.9, sectionProgress);
			      const physicalTitleEnter = smoothStep(
			        physicalPause.enterStart,
			        physicalPause.enterEnd,
			        sectionProgress
			      );
			      const baseTitle = baseTitleEnter * (1 - baseTitleExit);
			      let featureTitle = 0;
			      let physicalTitle = 0;
			      let serviceTitle = 0;
			      const baseTitleY = -28 * baseTitleExit;
			      const featureTitleY = 20 * (1 - featureTitleEnter) - 28 * featureTitleExit;
			      const physicalTitleY = 20 * (1 - physicalTitleEnter);
			      let serviceTitleY = 20;
			      const baseTitleBlur = 4 * baseTitleExit;
			      const featureTitleBlur = 10 * (1 - featureTitleEnter) + 4 * featureTitleExit;
			      const physicalTitleBlur = 10 * (1 - physicalTitleEnter);
			      let serviceTitleBlur = 10;
			      let conclusionTitle = smoothStep(0.996, 0.999, sectionProgress);
			      let finalZoomOut = smoothStep(0.965, 0.995, sectionProgress);
								      let conclusionHighlight = smoothStep(0.996, 0.999, sectionProgress);
				      const featurePhase = heldReveal(
				        featurePause.enterStart,
				        featurePause.enterEnd,
				        featurePause.exitStart,
				        featurePause.exitEnd,
				        sectionProgress
				      );
				      const physicalPhase = heldReveal(
				        physicalPause.enterStart,
				        physicalPause.enterEnd,
				        physicalPause.exitStart,
				        physicalPause.exitEnd,
				        sectionProgress
				      );
				      const featureHighlightActive = featurePhase;
									      const physicalHighlightActive = physicalPhase;
			      let featureHighlight = Math.max(featureHighlightActive, conclusionHighlight);
			      let physicalHighlight = Math.max(physicalHighlightActive, conclusionHighlight);
				      let featureHighlightRail =
				        smoothStep(featurePause.enterStart, featurePause.enterEnd, sectionProgress) *
				        (1 - smoothStep(0.855, 0.89, sectionProgress));
				      let physicalHighlightRail =
				        smoothStep(physicalPause.enterStart, physicalPause.enterEnd, sectionProgress) *
				        (1 - smoothStep(0.99, 0.999, sectionProgress));
				      const featureHighlightGlowActive = featurePhase;
									      const physicalHighlightGlowActive = physicalPhase;
			      let featureHighlightGlow = Math.max(featureHighlightGlowActive, conclusionHighlight);
			      let physicalHighlightGlow = Math.max(physicalHighlightGlowActive, conclusionHighlight);
			      let featureHighlightZoom = featureHighlightGlow;
			      let physicalHighlightZoom = physicalHighlightGlow;
						      let featureAnnotation = featurePhase;
										      let physicalAnnotation = physicalPhase;
			      let featureAnnotationTop = 53;
			      let conclusionBlur = 10 * (1 - conclusionTitle);
			      let conclusionY = 20 * (1 - conclusionTitle);
					      let featureHighlightY = smoothStep(featurePause.enterStart, featurePause.enterEnd, sectionProgress);
								      let physicalHighlightY = smoothStep(
								        physicalPause.enterStart,
								        physicalPause.enterEnd,
								        sectionProgress
								      );
			      const codeFeatureFocus = featureHighlightGlowActive * (1 - finalZoomOut);
			      const codePhysicalFocus = physicalHighlightGlowActive * (1 - finalZoomOut);
			      const codeFocus = Math.max(codeFeatureFocus, codePhysicalFocus);
			      let codeFocusScale = 1 + codeFocus * 0.58;
			      let codeFocusX = codeFocus * 120;
			      let codeFocusY = codeFeatureFocus * -600 + codePhysicalFocus * -112;
			      let featureAnnotationY = '53%';
			      let physicalAnnotationY = '56%';

	      if (isMobile) {
	        dockProgress = smoothStep(0.04, 0.32, sectionProgress);
	        const mobileDeadCut = smoothStep(0.08, 0.24, sectionProgress);
	        copyReveal = 1;
	        deadCut = mobileDeadCut;
	        ideX = 0;
	        ideY = (1 - dockProgress) * 18;
	        ideScale = 0.975 + dockProgress * 0.025;
	        copyTopOffset = 0;
	        editorLeft = 0;
	        editorTop = 0;
	        editorWidth = 100;
	        editorHeight = 100;
	        editorRadius = 18;
	        editorInnerLeft = clamp(window.innerWidth * 0.018, 8, 14);
	        ideBaseOpacity = 0;
	        finalZoomOut = smoothStep(0.955, 0.995, sectionProgress);
	        conclusionTitle = smoothStep(0.99, 0.998, sectionProgress);
	        conclusionHighlight = smoothStep(0.99, 0.998, sectionProgress);
	        conclusionBlur = 10 * (1 - conclusionTitle);
	        conclusionY = 18 * (1 - conclusionTitle);

	        featureHighlight = Math.max(featureHighlightActive, conclusionHighlight);
	        physicalHighlight = Math.max(physicalHighlightActive, conclusionHighlight);
	        featureHighlightRail =
	          smoothStep(featurePause.enterStart, featurePause.enterEnd, sectionProgress) *
	          (1 - smoothStep(0.855, 0.89, sectionProgress));
	        physicalHighlightRail =
	          smoothStep(physicalPause.enterStart, physicalPause.enterEnd, sectionProgress) *
	          (1 - smoothStep(0.99, 0.999, sectionProgress));
	        featureHighlightGlow = Math.max(featurePhase, conclusionHighlight);
	        physicalHighlightGlow = Math.max(physicalPhase, conclusionHighlight);
	        featureHighlightZoom = featureHighlightGlow * 0.55;
	        physicalHighlightZoom = physicalHighlightGlow * 0.55;
	        featureAnnotation = featurePhase;
	        physicalAnnotation = physicalPhase;
	        featureTitle = featurePhase;
	        physicalTitle = physicalPhase;
	        serviceTitle = conclusionTitle;
	        serviceTitleY = 18 * (1 - conclusionTitle);
	        serviceTitleBlur = conclusionBlur;

	        const mobileFeatureFocus = featureHighlightGlowActive * (1 - finalZoomOut);
	        const mobilePhysicalFocus = physicalHighlightGlowActive * (1 - finalZoomOut);
	        const mobileCodeFocus = Math.max(
	          mobileFeatureFocus,
	          mobilePhysicalFocus,
	          conclusionHighlight * 0.35
	        );
	        codeFocusScale = 1 + mobileCodeFocus * 0.16;
	        codeFocusX = mobileCodeFocus * -6;

	        const editorPixelHeight = Math.max(editorOverlay.clientHeight, ideFrame.clientHeight - 34, 1);
	        const desiredFeatureY = editorPixelHeight * 0.42;
	        const desiredPhysicalY = editorPixelHeight * 0.5;
	        const featureCenterY = getStageCenterY('feature');
	        const physicalCenterY = getStageCenterY('physical');
	        const featureFocusY = desiredFeatureY - featureCenterY * codeFocusScale;
	        const physicalFocusY = desiredPhysicalY - physicalCenterY * codeFocusScale;
	        codeFocusY = mobileFeatureFocus * featureFocusY + mobilePhysicalFocus * physicalFocusY;

	        const mobileLabelTop = (centerY: number, activeFocus: number) => {
	          const focusedCenterY = centerY * codeFocusScale + codeFocusY * activeFocus;
	          return clamp(focusedCenterY - 40, 46, editorPixelHeight - 58);
	        };

	        featureAnnotationY = `${mobileLabelTop(featureCenterY, mobileFeatureFocus).toFixed(3)}px`;
	        physicalAnnotationY = `${mobileLabelTop(physicalCenterY, mobilePhysicalFocus).toFixed(3)}px`;
	        featureAnnotationTop = 53;
	        featureHighlightY = smoothStep(featurePause.enterStart, featurePause.enterEnd, sectionProgress);
	        physicalHighlightY = smoothStep(physicalPause.enterStart, physicalPause.enterEnd, sectionProgress);
	      }
	      const strikeOne = deadCut;
	      const strikeTwo = deadCut;
	      const strikeThree = deadCut;

      section!.style.setProperty('--ide-dock', dockProgress.toFixed(3));
      section!.style.setProperty('--ide-base-opacity', ideBaseOpacity.toFixed(3));
      section!.style.setProperty('--ide-x', `${ideX.toFixed(3)}px`);
      section!.style.setProperty('--ide-y', `${ideY.toFixed(3)}px`);
      section!.style.setProperty('--ide-scale', ideScale.toFixed(3));
	      section!.style.setProperty('--copy-reveal', copyReveal.toFixed(3));
	      section!.style.setProperty('--copy-blur', `${(10 * (1 - copyReveal)).toFixed(3)}px`);
		      section!.style.setProperty('--copy-y', `${(20 * (1 - copyReveal)).toFixed(3)}px`);
		      section!.style.setProperty('--copy-top-offset', `${copyTopOffset.toFixed(3)}px`);
			      section!.style.setProperty('--base-title', baseTitle.toFixed(3));
			      section!.style.setProperty('--base-title-y', `${baseTitleY.toFixed(3)}px`);
			      section!.style.setProperty('--base-title-blur', `${baseTitleBlur.toFixed(3)}px`);
			      section!.style.setProperty('--feature-title', featureTitle.toFixed(3));
			      section!.style.setProperty('--feature-title-y', `${featureTitleY.toFixed(3)}px`);
			      section!.style.setProperty('--feature-title-blur', `${featureTitleBlur.toFixed(3)}px`);
			      section!.style.setProperty('--physical-title', physicalTitle.toFixed(3));
			      section!.style.setProperty('--physical-title-y', `${physicalTitleY.toFixed(3)}px`);
			      section!.style.setProperty('--physical-title-blur', `${physicalTitleBlur.toFixed(3)}px`);
			      section!.style.setProperty('--service-title', serviceTitle.toFixed(3));
			      section!.style.setProperty('--service-title-y', `${serviceTitleY.toFixed(3)}px`);
			      section!.style.setProperty('--service-title-blur', `${serviceTitleBlur.toFixed(3)}px`);
			      section!.style.setProperty('--feature-annotation', featureAnnotation.toFixed(3));
			      section!.style.setProperty('--physical-annotation', physicalAnnotation.toFixed(3));
			      section!.style.setProperty('--feature-annotation-top', `${featureAnnotationTop.toFixed(3)}%`);
			      section!.style.setProperty('--feature-annotation-y', featureAnnotationY);
			      section!.style.setProperty('--physical-annotation-y', physicalAnnotationY);
			      section!.style.setProperty('--conclusion-title', conclusionTitle.toFixed(3));
			      section!.style.setProperty('--conclusion-blur', `${conclusionBlur.toFixed(3)}px`);
			      section!.style.setProperty('--conclusion-y', `${conclusionY.toFixed(3)}px`);
	      section!.style.setProperty('--editor-left', `${editorLeft.toFixed(3)}%`);
	      section!.style.setProperty('--editor-top', `${editorTop.toFixed(3)}%`);
	      section!.style.setProperty('--editor-width', `${editorWidth.toFixed(3)}%`);
      section!.style.setProperty('--editor-height', `${editorHeight.toFixed(3)}%`);
      section!.style.setProperty('--editor-radius', `${editorRadius.toFixed(3)}px`);
      section!.style.setProperty('--editor-inner-left', `${editorInnerLeft.toFixed(3)}px`);
	      section!.style.setProperty('--code-focus-scale', codeFocusScale.toFixed(3));
	      section!.style.setProperty('--code-focus-x', `${codeFocusX.toFixed(3)}px`);
	      section!.style.setProperty('--code-focus-y', `${codeFocusY.toFixed(3)}px`);
	      section!.style.setProperty('--annotation-target-x', `${codeFocusX.toFixed(3)}px`);
	      section!.style.setProperty('--strike-1', strikeOne.toFixed(3));
		      section!.style.setProperty('--strike-2', strikeTwo.toFixed(3));
		      section!.style.setProperty('--strike-3', strikeThree.toFixed(3));
			      section!.style.setProperty('--feature-highlight', featureHighlight.toFixed(3));
			      section!.style.setProperty('--physical-highlight', physicalHighlight.toFixed(3));
			      section!.style.setProperty('--feature-highlight-rail', featureHighlightRail.toFixed(3));
			      section!.style.setProperty('--physical-highlight-rail', physicalHighlightRail.toFixed(3));
			      section!.style.setProperty('--feature-highlight-glow', featureHighlightGlow.toFixed(3));
			      section!.style.setProperty('--physical-highlight-glow', physicalHighlightGlow.toFixed(3));
				      section!.style.setProperty('--feature-highlight-zoom', featureHighlightZoom.toFixed(3));
				      section!.style.setProperty('--physical-highlight-zoom', physicalHighlightZoom.toFixed(3));
				      section!.style.setProperty('--feature-highlight-y', featureHighlightY.toFixed(3));
				      section!.style.setProperty('--physical-highlight-y', physicalHighlightY.toFixed(3));
		    }

    function getStepScrollProgress(stepIndex: number) {
      const step = choreographySteps[stepIndex] ?? choreographySteps[0];
      const isMobile = window.matchMedia('(max-width: 767px)').matches;
      let progress = step.progress;
      if (isMobile && step.name === 'physical') {
        progress = 0.97;
      }
      return clamp(progress * animationCompleteAt, 0, 0.995);
    }

    const stepTargets = choreographySteps.map((_, index) => getStepScrollProgress(index));
    const lastStepIndex = stepTargets.length - 1;
    let currentStepIndex = 0;
    let stepTween: gsap.core.Tween | null = null;
    let isAnimatingStep = false;
    let isSectionActive = false;
    let activePinDirection: 1 | -1 = 1;
    let wheelGestureLocked = false;
    let wheelGestureUnlockTimer: number | null = null;
    let releaseGestureDirection: 1 | -1 | null = null;
    let releaseGestureUnlockTimer: number | null = null;
    let nativeScrollRaf: number | null = null;
    const isMobileLayout = window.matchMedia('(max-width: 767px)').matches;
    const enterWheelLockMs = isMobileLayout ? 80 : 140;
    const postStepWheelLockMs = isMobileLayout ? 90 : 160;
    const releaseGestureIdleMs = 360;
    const minimumWheelDelta = 1;

    let touchStartY = 0;
    let touchLastY = 0;
    let touchStartTime = 0;
    let touchClaimed = false;
    let touchActiveId: number | null = null;
    const touchSwipeMinDistance = 28;
    const touchSwipeMinVelocity = 0.18;

    function isSnapMode() {
      return !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    }

    function isTouchSnapMode() {
      return isSnapMode() && window.matchMedia('(max-width: 767px)').matches;
    }

    function getScrollY() {
      return window.scrollY || document.documentElement.scrollTop || document.body.scrollTop || 0;
    }

    function getSectionScrollStart() {
      return section!.getBoundingClientRect().top + getScrollY();
    }

    function getSectionScrollLength() {
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
      return Math.max(section!.offsetHeight - viewportHeight, viewportHeight);
    }

    function getSectionScrollEnd() {
      return getSectionScrollStart() + getSectionScrollLength();
    }

    function getNativeScrollProgress() {
      return clamp((getScrollY() - getSectionScrollStart()) / getSectionScrollLength());
    }

    function syncNativeScrollProgress() {
      if (isSnapMode()) return;
      renderScrollProgress(getNativeScrollProgress());
    }

    function getWheelDirection(event: WheelEvent): 1 | -1 | 0 {
      if (event.deltaY > 0) return 1;
      if (event.deltaY < 0) return -1;
      return 0;
    }

    function isInsideSectionRunway(scrollY = getScrollY()) {
      return scrollY >= getSectionScrollStart() - 1 && scrollY <= getSectionScrollEnd() + 1;
    }

    function setControlledProgress(progress: number) {
      progressState.value = clamp(progress);
      renderScrollProgress(progressState.value);
    }

    function withInstantScrollBehavior(callback: () => void) {
      const root = document.documentElement;
      const body = document.body;
      const previousRootScrollBehavior = root.style.scrollBehavior;
      const previousBodyScrollBehavior = body.style.scrollBehavior;

      root.style.setProperty('scroll-behavior', 'auto', 'important');
      body.style.setProperty('scroll-behavior', 'auto', 'important');

      callback();

      requestAnimationFrame(() => {
        root.style.scrollBehavior = previousRootScrollBehavior;
        body.style.scrollBehavior = previousBodyScrollBehavior;
      });
    }

    function forceScrollTo(top: number) {
      withInstantScrollBehavior(() => {
        document.documentElement.scrollTop = top;
        document.body.scrollTop = top;
        window.scrollTo({ top, left: 0, behavior: 'auto' });
      });
    }

    function getPinnedScrollY() {
      return activePinDirection > 0 ? getSectionScrollStart() + 2 : getSectionScrollEnd() - 2;
    }

    function pinViewportToSection() {
      if (!isSectionActive) return;

      const targetY = getPinnedScrollY();
      if (Math.abs(getScrollY() - targetY) > 1) {
        forceScrollTo(targetY);
      }
    }

    function placeViewportAtSectionEdge(direction: 1 | -1) {
      activePinDirection = direction;
      const targetY = direction > 0 ? getSectionScrollStart() + 2 : getSectionScrollEnd() - 2;
      forceScrollTo(targetY);
    }

    function setStep(index: number) {
      currentStepIndex = Math.min(Math.max(index, 0), lastStepIndex);
      setControlledProgress(stepTargets[currentStepIndex]);
    }

    function claimControlledWheel(event: WheelEvent) {
      event.preventDefault();
      event.stopImmediatePropagation();
    }

    function claimScrollOwnership() {
      deadCodeWindow.__ckStepScrollOwner = 'dead-code';
    }

    function releaseScrollOwnership() {
      if (deadCodeWindow.__ckStepScrollOwner === 'dead-code') {
        delete deadCodeWindow.__ckStepScrollOwner;
      }
    }

    function lockWheelGestureTail(durationMs = postStepWheelLockMs) {
      claimScrollOwnership();
      wheelGestureLocked = true;

      if (wheelGestureUnlockTimer !== null) {
        window.clearTimeout(wheelGestureUnlockTimer);
      }

      wheelGestureUnlockTimer = window.setTimeout(() => {
        wheelGestureLocked = false;
        wheelGestureUnlockTimer = null;
      }, durationMs);
    }

    function clearWheelGestureLock() {
      wheelGestureLocked = false;

      if (wheelGestureUnlockTimer !== null) {
        window.clearTimeout(wheelGestureUnlockTimer);
        wheelGestureUnlockTimer = null;
      }
    }

    function lockReleaseGesture(direction: 1 | -1) {
      claimScrollOwnership();
      releaseGestureDirection = direction;

      if (releaseGestureUnlockTimer !== null) {
        window.clearTimeout(releaseGestureUnlockTimer);
      }

      releaseGestureUnlockTimer = window.setTimeout(() => {
        releaseGestureDirection = null;
        releaseGestureUnlockTimer = null;
        releaseScrollOwnership();
      }, releaseGestureIdleMs);
    }

    function clearReleaseGestureLock() {
      releaseGestureDirection = null;

      if (releaseGestureUnlockTimer !== null) {
        window.clearTimeout(releaseGestureUnlockTimer);
        releaseGestureUnlockTimer = null;
      }
    }

    function clearWheelMemory() {
      clearWheelGestureLock();
      clearReleaseGestureLock();
      releaseScrollOwnership();
    }

    let lastDetectedScrollY: number | null = null;

    function detectSectionEntry() {
      if (isSectionActive) return;
      if (releaseGestureDirection !== null) return;
      if (!isTouchSnapMode()) return;

      const currentY = getScrollY();
      const sectionStart = getSectionScrollStart();
      const sectionEnd = getSectionScrollEnd();

      if (currentY >= sectionStart && currentY <= sectionEnd) {
        const direction: 1 | -1 =
          lastDetectedScrollY !== null && lastDetectedScrollY > currentY ? -1 : 1;
        enterSection(direction);
      }

      lastDetectedScrollY = currentY;
    }

    function handleNativeScroll() {
      if (nativeScrollRaf !== null) return;

      nativeScrollRaf = window.requestAnimationFrame(() => {
        nativeScrollRaf = null;
        if (isTouchSnapMode()) {
          detectSectionEntry();
          return;
        }
        if (isSnapMode()) return;
        syncNativeScrollProgress();
      });
    }

    function getStepDuration(fromIndex: number, targetIndex: number) {
      const lowStep = Math.min(fromIndex, targetIndex);
      const highStep = Math.max(fromIndex, targetIndex);
      const mobileScale = isMobileLayout ? 0.78 : 1;

      if (lowStep === 1 && highStep === 2) return (fromIndex > targetIndex ? 0.94 : 1.08) * mobileScale;
      if (lowStep === 0 && highStep === 1) return 0.98 * mobileScale;
      return 0.74 * mobileScale;
    }

    function getStepEase(fromIndex: number, targetIndex: number) {
      const lowStep = Math.min(fromIndex, targetIndex);
      const highStep = Math.max(fromIndex, targetIndex);

      if (lowStep === 1 && highStep === 2) return 'power3.inOut';
      if (lowStep === 0 && highStep === 1) return 'power2.inOut';
      return 'power3.out';
    }

    function animateToStep(index: number, direction: 1 | -1) {
      const targetIndex = Math.min(Math.max(index, 0), lastStepIndex);
      if (targetIndex === currentStepIndex) return;

      const fromIndex = currentStepIndex;
      stepTween?.kill();
      currentStepIndex = targetIndex;
      isAnimatingStep = true;
      const duration = getStepDuration(fromIndex, targetIndex);
      claimScrollOwnership();

      stepTween = gsap.to(progressState, {
        value: stepTargets[targetIndex],
        duration,
        ease: getStepEase(fromIndex, targetIndex),
        overwrite: true,
        onUpdate: () => {
          renderScrollProgress(progressState.value);
          pinViewportToSection();
        },
        onComplete: () => {
          setControlledProgress(stepTargets[targetIndex]);
          pinViewportToSection();
          isAnimatingStep = false;
          stepTween = null;
          lockWheelGestureTail(postStepWheelLockMs);
        },
        onInterrupt: () => {
          isAnimatingStep = false;
        },
      });
    }

    function releaseSection(direction: 1 | -1) {
      isSectionActive = false;
      stepTween?.kill();
      clearWheelGestureLock();
      lockReleaseGesture(direction);

      const exitY = direction > 0 ? getSectionScrollEnd() + 2 : Math.max(0, getSectionScrollStart() - 2);
      forceScrollTo(exitY);
    }

    function enterSection(direction: 1 | -1) {
      isSectionActive = true;
      claimScrollOwnership();
      placeViewportAtSectionEdge(direction);
      setStep(direction > 0 ? 0 : lastStepIndex);
      lockWheelGestureTail(enterWheelLockMs);
    }

    function handleStepIntent(direction: 1 | -1) {
      if (!isSnapMode() || !isSectionActive) return false;

      if (direction < 0 && currentStepIndex === 0) {
        releaseSection(direction);
        return false;
      }

      if (direction > 0 && currentStepIndex === lastStepIndex) {
        releaseSection(direction);
        return false;
      }

      animateToStep(currentStepIndex + direction, direction);
      return true;
    }

    function handleWheel(event: WheelEvent) {
      if (!isSnapMode()) return;

      const direction = getWheelDirection(event);
      if (direction === 0) return;

      const currentY = getScrollY();
      const sectionStart = getSectionScrollStart();
      const sectionEnd = getSectionScrollEnd();
      const delta = Math.abs(event.deltaY);
      const crossesFromAbove = direction > 0 && currentY < sectionStart && currentY + delta >= sectionStart;
      const crossesFromBelow = direction < 0 && currentY > sectionEnd && currentY - delta <= sectionEnd;

      if (releaseGestureDirection !== null) {
        if (direction === releaseGestureDirection) {
          lockReleaseGesture(direction);
          return;
        }

        clearReleaseGestureLock();
      }

      const shouldControl =
        isSectionActive || isInsideSectionRunway(currentY) || crossesFromAbove || crossesFromBelow;

      if (!shouldControl) return;

      if (isSectionActive && !isAnimatingStep && !wheelGestureLocked) {
        if (direction < 0 && currentStepIndex === 0) {
          releaseSection(direction);
          return;
        }

        if (direction > 0 && currentStepIndex === lastStepIndex) {
          releaseSection(direction);
          return;
        }
      }

      claimControlledWheel(event);

      if (isSectionActive) {
        pinViewportToSection();
      }

      if (delta < minimumWheelDelta) {
        return;
      }

      if (isAnimatingStep) {
        pinViewportToSection();
        return;
      }

      if (wheelGestureLocked) {
        pinViewportToSection();
        return;
      }

      if (!isSectionActive) {
        enterSection(direction);
        return;
      }

      handleStepIntent(direction);
    }

    function handleTouchStart(event: TouchEvent) {
      if (!isTouchSnapMode()) return;
      if (event.touches.length !== 1) return;
      if (touchActiveId !== null) return;

      const touch = event.touches[0];
      touchActiveId = touch.identifier;
      touchStartY = touch.clientY;
      touchLastY = touchStartY;
      touchStartTime = performance.now();
      touchClaimed = false;
    }

    function getActiveTouch(event: TouchEvent, list: TouchList) {
      for (let index = 0; index < list.length; index += 1) {
        const touch = list[index];
        if (touch.identifier === touchActiveId) return touch;
      }
      return null;
    }

    function handleTouchMove(event: TouchEvent) {
      if (!isTouchSnapMode() || touchActiveId === null) return;

      const touch = getActiveTouch(event, event.touches);
      if (!touch) return;

      touchLastY = touch.clientY;

      const shouldControl = isSectionActive || isInsideSectionRunway(getScrollY());
      if (!shouldControl) return;

      if (event.cancelable) {
        event.preventDefault();
        event.stopImmediatePropagation();
      }
      touchClaimed = true;
      claimScrollOwnership();
    }

    function handleTouchEnd(event: TouchEvent) {
      if (!isTouchSnapMode() || touchActiveId === null) return;

      const touch = getActiveTouch(event, event.changedTouches);
      const endY = touch ? touch.clientY : touchLastY;
      const deltaY = touchStartY - endY;
      const elapsed = Math.max(performance.now() - touchStartTime, 1);
      const velocity = Math.abs(deltaY) / elapsed;
      const wasClaimed = touchClaimed;

      touchActiveId = null;
      touchClaimed = false;

      if (!wasClaimed) return;

      if (Math.abs(deltaY) < touchSwipeMinDistance && velocity < touchSwipeMinVelocity) {
        if (isSectionActive) pinViewportToSection();
        return;
      }

      const direction: 1 | -1 = deltaY > 0 ? 1 : -1;

      if (releaseGestureDirection !== null) {
        if (direction === releaseGestureDirection) {
          lockReleaseGesture(direction);
          return;
        }
        clearReleaseGestureLock();
      }

      if (isAnimatingStep) {
        pinViewportToSection();
        return;
      }

      if (wheelGestureLocked) {
        pinViewportToSection();
        return;
      }

      if (!isSectionActive) {
        enterSection(direction);
        return;
      }

      if (direction < 0 && currentStepIndex === 0) {
        releaseSection(direction);
        return;
      }

      if (direction > 0 && currentStepIndex === lastStepIndex) {
        releaseSection(direction);
        return;
      }

      animateToStep(currentStepIndex + direction, direction);
    }

    function handleTouchCancel() {
      touchActiveId = null;
      touchClaimed = false;
    }

    const handleResize = () => {
      if (isSnapMode() && isSectionActive) {
        placeViewportAtSectionEdge(activePinDirection);
      }

      if (isSnapMode()) {
        setStep(currentStepIndex);
      } else {
        syncNativeScrollProgress();
      }
    };

    const cleanupDeadCodeScroll = () => {
      window.removeEventListener('resize', handleResize);
      window.removeEventListener('scroll', handleNativeScroll);
      window.removeEventListener('wheel', handleWheel, true);
      window.removeEventListener('touchstart', handleTouchStart, true);
      window.removeEventListener('touchmove', handleTouchMove, true);
      window.removeEventListener('touchend', handleTouchEnd, true);
      window.removeEventListener('touchcancel', handleTouchCancel, true);
      if (nativeScrollRaf !== null) {
        window.cancelAnimationFrame(nativeScrollRaf);
        nativeScrollRaf = null;
      }
      stepTween?.kill();
      clearWheelMemory();
      delete section.dataset.deadCodeScrollBound;

      if (deadCodeWindow.__deadCodeScrollCleanup === cleanupDeadCodeScroll) {
        delete deadCodeWindow.__deadCodeScrollCleanup;
      }
    };

    window.addEventListener('resize', handleResize, { passive: true });
    window.addEventListener('scroll', handleNativeScroll, { passive: true });
    window.addEventListener('wheel', handleWheel, { passive: false, capture: true });
    window.addEventListener('touchstart', handleTouchStart, { passive: true, capture: true });
    window.addEventListener('touchmove', handleTouchMove, { passive: false, capture: true });
    window.addEventListener('touchend', handleTouchEnd, { passive: true, capture: true });
    window.addEventListener('touchcancel', handleTouchCancel, { passive: true, capture: true });
    deadCodeWindow.__deadCodeScrollCleanup = cleanupDeadCodeScroll;
    document.addEventListener('astro:before-swap', cleanupDeadCodeScroll, { once: true });
    if (isSnapMode()) {
      renderScrollProgress(0);
    } else {
      syncNativeScrollProgress();
    }
  }

  initDeadCodeScroll();
  document.addEventListener('DOMContentLoaded', initDeadCodeScroll);
  document.addEventListener('astro:page-load', initDeadCodeScroll);
</script>
