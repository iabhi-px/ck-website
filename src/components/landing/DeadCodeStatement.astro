				      section!.style.setProperty('--feature-highlight-zoom', featureHighlightZoom.toFixed(3));
				      section!.style.setProperty('--physical-highlight-zoom', physicalHighlightZoom.toFixed(3));
				      section!.style.setProperty('--feature-highlight-y', featureHighlightY.toFixed(3));
				      section!.style.setProperty('--physical-highlight-y', physicalHighlightY.toFixed(3));
		    }

	    const tween = gsap.to(progressState, {
	      value: 1,
	      ease: 'none',
	      onUpdate: () => renderScrollProgress(progressState.value),
	      scrollTrigger: {
	        trigger: section,
	        start: 'top top',
	        end: 'bottom bottom',
	        scrub: 0.8,
	        invalidateOnRefresh: true,
	        onRefresh: () => renderScrollProgress(progressState.value),
	      },
	    });

	    window.addEventListener('resize', () => ScrollTrigger.refresh(), { passive: true });
	    document.addEventListener('astro:before-swap', () => tween.kill(), { once: true });
	    renderScrollProgress(0);
	  }

  initDeadCodeScroll();
  document.addEventListener('DOMContentLoaded', initDeadCodeScroll);
  document.addEventListener('astro:page-load', initDeadCodeScroll);
</script>
