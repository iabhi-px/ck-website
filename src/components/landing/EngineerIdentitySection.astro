</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const circleHeadNumbers = [
    100, 14, 126.51, 14, 148, 35.49, 148, 62, 148, 88.51, 126.51, 110, 100, 110,
    73.49, 110, 52, 88.51, 52, 62, 52, 35.49, 73.49, 14, 100, 14,
  ];
  const sparkleHeadNumbers = [
    100, 18, 108, 45, 118, 54, 145, 62, 118, 70, 108, 79, 100, 106, 92, 79, 82,
    70, 55, 62, 82, 54, 92, 45, 100, 18,
  ];

  function clamp(value: number, min = 0, max = 1) {
    return Math.min(Math.max(value, min), max);
  }

  function smoothStep(start: number, end: number, value: number) {
    const progress = clamp((value - start) / (end - start));
    return progress * progress * (3 - 2 * progress);
  }

  function smootherStep(start: number, end: number, value: number) {
    const progress = clamp((value - start) / (end - start));
    return progress * progress * progress * (progress * (progress * 6 - 15) + 10);
  }

  function mixColor(start: [number, number, number], end: [number, number, number], progress: number) {
    const amount = clamp(progress);
    const channels = start.map((value, index) => Math.round(value + (end[index] - value) * amount));
    return `rgb(${channels[0]} ${channels[1]} ${channels[2]})`;
  }

  function getHeadPath(progress: number) {
    const points = circleHeadNumbers.map((start, index) => {
      const end = sparkleHeadNumbers[index];
      return Number((start + (end - start) * progress).toFixed(2));
    });

    return `M${points[0]} ${points[1]}C${points[2]} ${points[3]} ${points[4]} ${points[5]} ${points[6]} ${points[7]}C${points[8]} ${points[9]} ${points[10]} ${points[11]} ${points[12]} ${points[13]}C${points[14]} ${points[15]} ${points[16]} ${points[17]} ${points[18]} ${points[19]}C${points[20]} ${points[21]} ${points[22]} ${points[23]} ${points[24]} ${points[25]}Z`;
  }

  const identityScrollBindingVersion = 'target-step-v6';
  type IdentityWindow = Window & {
    __engineerIdentityScrollCleanup?: () => void;
    __ckStepScrollOwner?: string;
  };

  function initEngineerIdentityScroll() {
    const section = document.getElementById('engineer-identity');
    if (!section) return;

    const identityWindow = window as IdentityWindow;
    if (section.dataset.identityScrollBound === identityScrollBindingVersion) return;

    identityWindow.__engineerIdentityScrollCleanup?.();
    section.dataset.identityScrollBound = identityScrollBindingVersion;

    const headPaths = Array.from(section.querySelectorAll<SVGPathElement>('.identity-head-path'));
    const pillChips = Array.from(section.querySelectorAll<SVGGElement>('.identity-pill-chip'));
    const lineChips = pillChips.filter((chip) => Number(chip.dataset.rowDistance) === 0);
    const maxLineOrder = Math.max(...lineChips.map((chip) => Number(chip.dataset.lineOrder || 0)), 1);
    const maxRowDistance = Math.max(...pillChips.map((chip) => Number(chip.dataset.rowDistance || 0)), 1);
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      headPaths.forEach((path) => {
        path.setAttribute('d', getHeadPath(1));
      });

      section.style.setProperty('--identity-bg-color', '#CDFF52');
      section.style.setProperty('--identity-grid-opacity', '0');
      section.style.setProperty('--identity-icon-color', '#0f0f0f');
      section.style.setProperty('--identity-head-opacity', '1');
      section.style.setProperty('--identity-body-opacity', '0');
      section.style.setProperty('--identity-copy-original-opacity', '0');
      section.style.setProperty('--identity-copy-ai-opacity', '0');
      section.style.setProperty('--identity-center-spark-opacity', '0');
      section.style.setProperty('--identity-pill-opacity', '0');
      section.style.setProperty('--identity-pill-x', '0px');
      section.style.setProperty('--identity-pill-y', '0px');
      section.style.setProperty('--identity-pill-track-scale', '1');
      section.style.setProperty('--identity-pill-text-opacity', '0');
      section.style.setProperty('--identity-copy-final-opacity', '1');
      section.style.setProperty('--identity-copy-final-y', '0px');
      section.style.setProperty('--identity-copy-final-blur', '0px');
      section.style.setProperty('--identity-copy-final-color', '#0f0f0f');
      section.style.setProperty('--identity-final-pointer-events', 'auto');
      return;
    }

    const progressState = { value: 0 };

    function render(sectionProgress: number) {
      sectionProgress = clamp(sectionProgress);
      const originalCopyEnter = 1;
      const headProgress = smootherStep(0.025, 0.24, sectionProgress);
      const bodyOpacity = 1 - smootherStep(0.05, 0.22, sectionProgress);
      const originalCopyExit = smootherStep(0.055, 0.215, sectionProgress);
      const aiCopyEnter = smootherStep(0.115, 0.255, sectionProgress);
      const aiCopyExit = smootherStep(0.3, 0.38, sectionProgress);
      const centerSparkEnter = smootherStep(0.3, 0.39, sectionProgress);
      const centerSparkExpand = smoothStep(0.34, 0.5, sectionProgress);
      const backgroundProgress = smoothStep(0.39, 0.52, sectionProgress);
      const iconColorProgress = smoothStep(0.37, 0.52, sectionProgress);
      const centerLineProgress = smoothStep(0.38, 0.54, sectionProgress);
      const pillRowsProgress = smoothStep(0.5, 0.62, sectionProgress);
      const pillForwardProgress = smoothStep(0.62, 0.8, sectionProgress);
      const centerChipExpand = smoothStep(0.78, 0.9, sectionProgress);
      const pillTextExit = smoothStep(0.84, 0.91, sectionProgress);
      const finalCopyEnter = smoothStep(0.87, 0.93, sectionProgress);
      const pillForwardX = -626 * pillForwardProgress;
      const pillTrackScale = 1 + pillForwardProgress * 0.025 + centerChipExpand * 15.5;

      const headPath = getHeadPath(headProgress);
      headPaths.forEach((path) => {
        path.setAttribute('d', headPath);
      });

      pillChips.forEach((chip) => {
        const rowOffset = Number(chip.dataset.rowOffset || 0);
        const rowDistance = Number(chip.dataset.rowDistance || 0);
        const lineOrder = Number(chip.dataset.lineOrder || 0);
        let chipOpacity = 0;
        let chipParallaxY = 0;

        if (rowDistance === 0) {
          const lineRevealStart = (lineOrder / maxLineOrder) * 0.78;
          chipOpacity = smoothStep(lineRevealStart, lineRevealStart + 0.12, centerLineProgress);
        } else {
          const rowRevealStart = ((rowDistance - 1) / Math.max(maxRowDistance - 1, 1)) * 0.74;
          const rowRevealProgress = smoothStep(rowRevealStart, rowRevealStart + 0.22, pillRowsProgress);
          chipOpacity = rowRevealProgress;
          const parallaxStrength = 16 * Math.sign(rowOffset) * Math.pow(rowDistance / maxRowDistance, 0.85);
          chipParallaxY = parallaxStrength * maxRowDistance * (1 - rowRevealProgress);
        }

        const rowDepth = 1 - Math.min(rowDistance / maxRowDistance, 1);
        const rowParallax = 0.34 + Math.pow(rowDepth, 1.35) * 0.66;
        const rowForwardX = pillForwardX * rowParallax;

        chip.style.opacity = chipOpacity.toFixed(3);
        chip.style.transform = `translateX(${rowForwardX.toFixed(2)}px) translateY(${chipParallaxY.toFixed(2)}px)`;
      });

      const backgroundColor = mixColor([15, 15, 15], [205, 255, 82], backgroundProgress);
      const iconColor = mixColor([255, 255, 255], [15, 15, 15], iconColorProgress);
      const centerSparkOpacity = centerSparkEnter;
      const centerSparkScale = 0.72 + centerSparkExpand * 56;
      const chipFieldOpacity = centerLineProgress > 0.01 ? 1 - finalCopyEnter : 0;

      section!.style.setProperty('--identity-bg-color', backgroundColor);
      section!.style.setProperty('--identity-grid-opacity', String(1 - smoothStep(0.78, 0.9, sectionProgress)));
      section!.style.setProperty('--identity-icon-color', iconColor);
      section!.style.setProperty('--identity-head-opacity', '1');
      section!.style.setProperty('--identity-body-opacity', String(bodyOpacity));
      section!.style.setProperty(
        '--identity-copy-original-opacity',
        String(originalCopyEnter * (1 - originalCopyExit))
      );
      section!.style.setProperty(
        '--identity-copy-original-y',
        `${20 * (1 - originalCopyEnter) - 28 * originalCopyExit}px`
      );
      section!.style.setProperty(
        '--identity-copy-original-blur',
        `${10 * (1 - originalCopyEnter) + 4 * originalCopyExit}px`
      );
      section!.style.setProperty('--identity-copy-ai-opacity', String(aiCopyEnter * (1 - aiCopyExit)));
      section!.style.setProperty('--identity-copy-ai-y', `${28 * (1 - aiCopyEnter) - 20 * aiCopyExit}px`);
      section!.style.setProperty(
        '--identity-copy-ai-blur',
        `${4 * (1 - aiCopyEnter) + 8 * aiCopyExit}px`
      );
      section!.style.setProperty('--identity-center-spark-opacity', String(centerSparkOpacity));
      section!.style.setProperty('--identity-center-spark-scale', centerSparkScale.toFixed(3));
      section!.style.setProperty('--identity-center-spark-fill', '#cdff52');
      section!.style.setProperty('--identity-pill-opacity', String(chipFieldOpacity));
      section!.style.setProperty('--identity-pill-x', '0px');
      section!.style.setProperty('--identity-pill-y', '0px');
      section!.style.setProperty('--identity-pill-track-scale', pillTrackScale.toFixed(3));
      section!.style.setProperty('--identity-pill-text-opacity', String(1 - pillTextExit));
      section!.style.setProperty('--identity-copy-final-opacity', String(finalCopyEnter));
      section!.style.setProperty('--identity-copy-final-y', `${24 * (1 - finalCopyEnter)}px`);
      section!.style.setProperty('--identity-copy-final-blur', `${10 * (1 - finalCopyEnter)}px`);
      section!.style.setProperty('--identity-copy-final-color', '#0f0f0f');
      section!.style.setProperty('--identity-final-pointer-events', finalCopyEnter > 0.98 ? 'auto' : 'none');
    }

    const choreographySteps = [
      { name: 'intro', progress: 0 },
      { name: 'ai', progress: 0.28 },
      { name: 'spark', progress: 0.45 },
      { name: 'pillField', progress: 0.64 },
      { name: 'pillDrift', progress: 0.76 },
      { name: 'final', progress: 0.93 },
    ];
    const stepTargets = choreographySteps.map((step) => step.progress);
    const lastStepIndex = stepTargets.length - 1;
    let currentStepIndex = 0;
    let stepTween: gsap.core.Tween | null = null;
    let mobileTween: gsap.core.Tween | null = null;
    let isSectionActive = false;
    let isAnimatingStep = false;
    let activePinDirection: 1 | -1 = 1;
    let activeStepDirection: 1 | -1 | null = null;
    let lastAcceptedWheelDirection: 1 | -1 | null = null;
    let lastAcceptedWheelAt = 0;
    let sameDirectionLockUntil = 0;
    let suppressWheelUntil = 0;
    const reverseIntentDebounceMs = 110;
    const postAnimationMomentumGuardMs = 70;
    const enterMomentumGuardMs = 0;
    const clickWheelSuppressMs = 80;
    const wheelIntentThreshold = 10;

    function isDesktopSnapMode() {
      return window.matchMedia('(min-width: 768px)').matches;
    }

    function getSectionScrollStart() {
      return section!.getBoundingClientRect().top + window.scrollY;
    }

    function getSectionScrollLength() {
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
      return Math.max(section!.offsetHeight - viewportHeight, viewportHeight);
    }

    function getSectionScrollEnd() {
      return getSectionScrollStart() + getSectionScrollLength();
    }

    function getWheelDirection(event: WheelEvent): 1 | -1 | 0 {
      if (event.deltaY > 0) return 1;
      if (event.deltaY < 0) return -1;
      return 0;
    }

    function isFinalCtaEvent(event: Event) {
      const target = event.target;
      return target instanceof Element && Boolean(target.closest('.identity-final-cta-link'));
    }

    function isInsideSectionRunway(scrollY = window.scrollY) {
      return scrollY >= getSectionScrollStart() - 1 && scrollY <= getSectionScrollEnd() + 1;
    }

    function setControlledProgress(progress: number) {
      progressState.value = clamp(progress);
      render(progressState.value);
    }

    function withInstantScrollBehavior(callback: () => void) {
      const root = document.documentElement;
      const body = document.body;
      const previousRootScrollBehavior = root.style.scrollBehavior;
      const previousBodyScrollBehavior = body.style.scrollBehavior;

      root.style.setProperty('scroll-behavior', 'auto', 'important');
      body.style.setProperty('scroll-behavior', 'auto', 'important');

      callback();

      requestAnimationFrame(() => {
        root.style.scrollBehavior = previousRootScrollBehavior;
        body.style.scrollBehavior = previousBodyScrollBehavior;
      });
    }

    function forceScrollTo(top: number) {
      withInstantScrollBehavior(() => {
        document.documentElement.scrollTop = top;
        document.body.scrollTop = top;
        window.scrollTo({ top, left: 0, behavior: 'auto' });
      });
    }

    function getPinnedScrollY() {
      return activePinDirection > 0 ? getSectionScrollStart() + 2 : getSectionScrollEnd() - 2;
    }

    function pinViewportToSection() {
      if (!isSectionActive) return;

      const targetY = getPinnedScrollY();
      if (Math.abs(window.scrollY - targetY) > 1) {
        forceScrollTo(targetY);
      }
    }

    function placeViewportAtSectionEdge(direction: 1 | -1) {
      activePinDirection = direction;
      const targetY = direction > 0 ? getSectionScrollStart() + 2 : getSectionScrollEnd() - 2;
      forceScrollTo(targetY);
    }

    function setStep(index: number) {
      currentStepIndex = Math.min(Math.max(index, 0), lastStepIndex);
      setControlledProgress(stepTargets[currentStepIndex]);
    }

    function rememberAcceptedWheel(direction: 1 | -1, lockForMs: number) {
      const now = window.performance.now();
      lastAcceptedWheelDirection = direction;
      lastAcceptedWheelAt = now;
      sameDirectionLockUntil = now + lockForMs;
    }

    function clearWheelMemory() {
      activeStepDirection = null;
      lastAcceptedWheelDirection = null;
      lastAcceptedWheelAt = 0;
      sameDirectionLockUntil = 0;

      if (identityWindow.__ckStepScrollOwner === 'engineer-identity') {
        delete identityWindow.__ckStepScrollOwner;
      }
    }

    function animateToStep(index: number, direction: 1 | -1) {
      const targetIndex = Math.min(Math.max(index, 0), lastStepIndex);
      if (targetIndex === currentStepIndex) return;

      stepTween?.kill();
      currentStepIndex = targetIndex;
      isAnimatingStep = true;
      activeStepDirection = direction;
      const duration = targetIndex === lastStepIndex ? 0.68 : 0.56;
      rememberAcceptedWheel(direction, duration * 1000 + postAnimationMomentumGuardMs);

      stepTween = gsap.to(progressState, {
        value: stepTargets[targetIndex],
        duration,
        ease: 'power3.out',
        overwrite: true,
        onUpdate: () => {
          render(progressState.value);
          pinViewportToSection();
        },
        onComplete: () => {
          setControlledProgress(stepTargets[targetIndex]);
          pinViewportToSection();
          isAnimatingStep = false;
          activeStepDirection = null;
          stepTween = null;
        },
        onInterrupt: () => {
          isAnimatingStep = false;
          activeStepDirection = null;
        },
      });
    }

    function releaseSection(direction: 1 | -1) {
      isSectionActive = false;
      stepTween?.kill();
      clearWheelMemory();

      const endY = direction > 0 ? getSectionScrollEnd() + 2 : Math.max(0, getSectionScrollStart() - 2);
      forceScrollTo(endY);
    }

    function enterSection(direction: 1 | -1) {
      isSectionActive = true;
      identityWindow.__ckStepScrollOwner = 'engineer-identity';
      placeViewportAtSectionEdge(direction);
      setStep(direction > 0 ? 0 : lastStepIndex);
      rememberAcceptedWheel(direction, enterMomentumGuardMs);
    }

    function handleStepIntent(direction: 1 | -1) {
      if (!isDesktopSnapMode() || !isSectionActive) return false;

      if (direction < 0 && currentStepIndex === 0) {
        releaseSection(direction);
        return false;
      }

      if (direction > 0 && currentStepIndex === lastStepIndex) {
        releaseSection(direction);
        return false;
      }

      animateToStep(currentStepIndex + direction, direction);
      return true;
    }

    function ensureMobileScrub() {
      if (mobileTween || isDesktopSnapMode()) return;

      mobileTween = gsap.to(progressState, {
        value: 1,
        ease: 'none',
        onUpdate: () => render(progressState.value),
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 0.55,
          anticipatePin: 1,
          invalidateOnRefresh: true,
          onRefresh: () => render(progressState.value),
        },
      });
    }

    function killMobileScrub() {
      mobileTween?.scrollTrigger?.kill();
      mobileTween?.kill();
      mobileTween = null;
    }

    function handleWheel(event: WheelEvent) {
      if (!isDesktopSnapMode()) return;

      const direction = getWheelDirection(event);
      if (direction === 0) return;

      const currentY = window.scrollY;
      const sectionStart = getSectionScrollStart();
      const sectionEnd = getSectionScrollEnd();
      const delta = Math.abs(event.deltaY);
      const crossesFromAbove = direction > 0 && currentY < sectionStart && currentY + delta >= sectionStart;
      const crossesFromBelow = direction < 0 && currentY > sectionEnd && currentY - delta <= sectionEnd;
      const shouldControl =
        isSectionActive || isInsideSectionRunway(currentY) || crossesFromAbove || crossesFromBelow;

      if (!shouldControl) return;

      const now = window.performance.now();

      if (now < suppressWheelUntil) {
        event.preventDefault();
        event.stopImmediatePropagation();
        pinViewportToSection();
        return;
      }

      if (event.buttons !== 0) {
        event.preventDefault();
        event.stopImmediatePropagation();
        pinViewportToSection();
        return;
      }

      if (
        identityWindow.__ckStepScrollOwner &&
        identityWindow.__ckStepScrollOwner !== 'engineer-identity'
      ) {
        isSectionActive = false;
        isAnimatingStep = false;
        activeStepDirection = null;
        stepTween?.kill();
        stepTween = null;
        clearWheelMemory();
        identityWindow.__ckStepScrollOwner = 'engineer-identity';
      }

      event.preventDefault();
      event.stopImmediatePropagation();

      if (isSectionActive) {
        pinViewportToSection();
      }

      if (delta < wheelIntentThreshold) {
        return;
      }

      if (isAnimatingStep) {
        pinViewportToSection();
        if (
          direction !== activeStepDirection &&
          now - lastAcceptedWheelAt >= reverseIntentDebounceMs
        ) {
          handleStepIntent(direction);
        }
        return;
      }

      if (direction === lastAcceptedWheelDirection && now < sameDirectionLockUntil) {
        pinViewportToSection();
        return;
      }

      if (!isSectionActive) {
        const alreadyInsideRunway = isInsideSectionRunway(currentY) && !crossesFromAbove && !crossesFromBelow;
        const runwayProgress = clamp((currentY - sectionStart) / Math.max(sectionEnd - sectionStart, 1));

        killMobileScrub();
        enterSection(direction);

        if (alreadyInsideRunway) {
          setStep(runwayProgress > 0.5 ? lastStepIndex : 0);
          handleStepIntent(direction);
        }

        return;
      }

      handleStepIntent(direction);
    }

    function handleMouseDown(event: MouseEvent) {
      if (!isDesktopSnapMode() || isFinalCtaEvent(event)) return;

      suppressWheelUntil = window.performance.now() + clickWheelSuppressMs;

      if (event.button === 1) {
        event.preventDefault();
        event.stopImmediatePropagation();
      }
    }

    function handleAuxClick(event: MouseEvent) {
      if (!isDesktopSnapMode() || isFinalCtaEvent(event)) return;

      if (event.button === 1) {
        event.preventDefault();
        event.stopImmediatePropagation();
      }
    }

    const handleResize = () => {
      if (!isDesktopSnapMode()) {
        isSectionActive = false;
        stepTween?.kill();
        clearWheelMemory();
        ensureMobileScrub();
        ScrollTrigger.refresh();
        return;
      }

      killMobileScrub();
      if (isSectionActive) {
        placeViewportAtSectionEdge(activePinDirection);
      }
      setStep(currentStepIndex);
    };

    const cleanupEngineerIdentityScroll = () => {
      window.removeEventListener('resize', handleResize);
      window.removeEventListener('wheel', handleWheel, true);
      section.removeEventListener('mousedown', handleMouseDown, true);
      section.removeEventListener('auxclick', handleAuxClick, true);
      stepTween?.kill();
      killMobileScrub();
      clearWheelMemory();
      delete section.dataset.identityScrollBound;

      if (identityWindow.__engineerIdentityScrollCleanup === cleanupEngineerIdentityScroll) {
        delete identityWindow.__engineerIdentityScrollCleanup;
      }
    };

    window.addEventListener('resize', handleResize, { passive: true });
    window.addEventListener('wheel', handleWheel, { passive: false, capture: true });
    section.addEventListener('mousedown', handleMouseDown, { capture: true });
    section.addEventListener('auxclick', handleAuxClick, { capture: true });
    identityWindow.__engineerIdentityScrollCleanup = cleanupEngineerIdentityScroll;
    document.addEventListener('astro:before-swap', cleanupEngineerIdentityScroll, { once: true });
    ensureMobileScrub();
    render(0);
  }

  initEngineerIdentityScroll();
  document.addEventListener('DOMContentLoaded', initEngineerIdentityScroll);
  document.addEventListener('astro:page-load', initEngineerIdentityScroll);
</script>
