---
const iconPositions = [
  [367, 120],
  [805, 120],
  [1243, 120],
  [1681, 120],
  [2119, 120],
  [2557, 120],
  [2995, 120],
  [3433, 120],
  [367, 410],
  [805, 410],
  [1243, 410],
  [1681, 410],
  [2119, 410],
  [2557, 410],
  [2995, 410],
  [3433, 410],
  [367, 745],
  [3433, 745],
  [367, 1080],
  [805, 1080],
  [1243, 1080],
  [2557, 1080],
  [2995, 1080],
  [3433, 1080],
  [367, 1370],
  [805, 1370],
  [1243, 1370],
  [1681, 1370],
  [2119, 1370],
  [2557, 1370],
  [2995, 1370],
  [3433, 1370],
  [367, 1630],
  [805, 1630],
  [1243, 1630],
  [1681, 1630],
  [2119, 1630],
  [2557, 1630],
  [2995, 1630],
  [3433, 1630],
];

const circleHeadPath =
  'M100 14C126.51 14 148 35.49 148 62C148 88.51 126.51 110 100 110C73.49 110 52 88.51 52 62C52 35.49 73.49 14 100 14Z';
const sparkleGlyphPath =
  'M0 -82C12 -34 34 -12 82 0C34 12 12 34 0 82C-12 34 -34 12 -82 0C-34 -12 -12 -34 0 -82Z';

const iconScale = 0.84;
const copyFontSize = 112;
const copyLineGap = 152;

const chipHeight = 118;
const chipGap = 0;
const chipCenterY = 950;
const codeKarmaChipWidth = 396;
const showsChipWidth = 230;
function makeChipRow(rowOffset: number) {
  const rowCenterX = rowOffset === 0 ? 2000 : 2000 + (Math.abs(rowOffset) % 2 === 0 ? 112 : -112);
  const y = chipCenterY + rowOffset * chipHeight - chipHeight / 2;
  const items = [
    {
      label: 'CodeKarma',
      width: codeKarmaChipWidth,
      x: rowCenterX - codeKarmaChipWidth / 2,
      y,
      isCenter: rowOffset === 0,
    },
  ];

  let rightEdge = rowCenterX + codeKarmaChipWidth / 2 + chipGap;
  let leftEdge = rowCenterX - codeKarmaChipWidth / 2 - chipGap;

  for (let index = 0; rightEdge < 4300; index += 1) {
    const label = index % 2 === 0 ? 'shows' : 'CodeKarma';
    const width = label === 'CodeKarma' ? codeKarmaChipWidth : showsChipWidth;
    items.push({
      label,
      width,
      x: rightEdge,
      y,
      isCenter: false,
    });
    rightEdge += width + chipGap;
  }

  for (let index = 0; leftEdge > -300; index += 1) {
    const label = index % 2 === 0 ? 'shows' : 'CodeKarma';
    const width = label === 'CodeKarma' ? codeKarmaChipWidth : showsChipWidth;
    leftEdge -= width;
    items.push({
      label,
      width,
      x: leftEdge,
      y,
      isCenter: false,
    });
    leftEdge -= chipGap;
  }

  const sortedItems = items
    .sort((a, b) => a.x - b.x)
    .map((item, index) => ({
      ...item,
      label: item.label === 'CodeKarma' && item.x < 80 ? 'shows' : item.label,
      lineOrder: index,
    }));

  return {
    rowOffset,
    rowDistance: Math.abs(rowOffset),
    items: sortedItems,
  };
}

const pillRows = Array.from({ length: 21 }, (_, rowIndex) => {
  return makeChipRow(rowIndex - 10);
});
---

<section id="engineer-identity" class="engineer-identity-section relative bg-brand-dark" data-hide-navbar-on-scroll>
