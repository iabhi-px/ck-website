            data-row-distance={row.rowDistance}
          >
            {row.items.map((item) => (
              <g
                class={`identity-pill-chip${item.isCenter ? ' identity-pill-chip-center' : ''}`}
                data-row-offset={row.rowOffset}
                data-row-distance={row.rowDistance}
                data-line-order={item.lineOrder}
                data-center-chip={item.isCenter ? 'true' : 'false'}
              >
                <rect
                  x={item.x}
                  y={item.y}
                  width={item.width}
                  height={chipHeight}
                  rx={chipHeight / 2}
                />
                <text
                  x={item.x + item.width / 2}
                  y={item.y + 77}
                  text-anchor="middle"
                  font-family="Geist, system-ui, sans-serif"
                  font-size="50"
                  font-weight="400"
                  letter-spacing="0"
                >
                  {item.label}
                </text>
              </g>
            ))}
          </g>
        ))}
      </g>

      <g class="identity-copy identity-copy-final">
        <g class="identity-final-logomark" aria-hidden="true" transform="translate(1841 336) scale(1.24)">
          <path
            d="M224 96C224 65.8301 224 50.7452 214.627 41.3726C205.255 32 190.17 32 160 32H96C65.8301 32 50.7452 32 41.3726 41.3726C32 50.7452 32 65.8301 32 96V160C32 190.17 32 205.255 41.3726 214.627C50.7452 224 65.8301 224 96 224H160C190.17 224 205.255 224 214.627 214.627C224 205.255 224 190.17 224 160V96Z"
            fill="#0f0f0f"
          />
          <rect width="144" height="124" rx="24" transform="matrix(-1 0 0 1 208 48)" fill="#cdff52" />
          <path d="M160 80L176 100.513L160 120" stroke="#0f0f0f" stroke-width="14.4" />
          <path d="M128 80L112 100.513L128 120" stroke="#0f0f0f" stroke-width="14.4" />
        </g>
        <text
          x="2000"
          y="855"
          fill="#0f0f0f"
