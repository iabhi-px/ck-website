---
const navLinks = [
  { label: 'Products', href: '/products' },
  { label: 'Solutions', href: '/solutions' },
  { label: 'Blogs', href: '/blog' },
  { label: 'Security', href: '/security' },
  { label: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 py-4 md:pb-0 transition-all duration-300 bg-white border-b border-gray-200"
>
  <div id="navbar-container" class="mx-auto max-w-7xl px-5 md:px-10 lg:px-[88px]">
    <div class="flex items-center justify-between md:h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img src="/assets/Logos/Logo with name (LR)/Colored (for light bg).svg" alt="CodeKarma" class="navbar-logo-light w-auto h-9 md:h-[44px]" />
        <img src="/assets/Logos/Logo with name (LR)/Colored (for dark bg).svg" alt="CodeKarma" class="navbar-logo-dark w-auto hidden h-9 md:h-[44px]" />
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center relative">
        <div id="navbar-links" class="relative flex items-center gap-4" style="transition: opacity 0.3s ease;">
          <!-- Sliding SVG background pill -->
          <svg id="nav-pill" class="absolute top-0 left-0 pointer-events-none" style="opacity: 0;" aria-hidden="true">
            <rect rx="0" ry="0" width="100%" height="100%" fill="#f3f4f6" />
          </svg>
          {navLinks.map((link) => {
            const isActive = currentPath.startsWith(link.href);
            return (
              <a
                href={link.href}
                class={`nav-link relative z-10 text-sm px-3 py-1.5 transition-all duration-[250ms] ease-out ${isActive ? 'text-brand-dark font-semibold' : 'text-gray-500 hover:text-brand-dark'}`}
                data-active={isActive ? 'true' : undefined}
                data-text={link.label}
              >
                {link.label}
              </a>
            );
          })}
        </div>

        <!-- CTAs that appear when hero CTAs scroll out of view -->
        <div id="navbar-ctas" class="absolute right-0 hidden md:flex items-center gap-4 opacity-0 pointer-events-none" style="transition: opacity 0.3s ease;">
          <a
            href="https://cal.com/ananth-vanchi/30min" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-5 py-2 rounded-none bg-brand-dark text-[15px] md:text-sm font-medium hover:bg-brand-primary transition-colors duration-200 hero-btn-primary"
          >
            <span>Schedule Demo</span>
          </a>
          <a
            href="/products"
            class="group inline-flex items-center justify-center gap-1.5 px-5 py-2 text-sm font-medium text-brand-dark hover:bg-gray-100 transition-all duration-200"
          >
            <span>View Platform</span>
            <i class="ph ph-arrow-right text-sm transition-transform duration-200 group-hover:translate-x-1"></i>
          </a>
        </div>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-gray-500 hover:text-brand-dark"
        aria-label="Toggle menu"
      >
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="mobile-menu md:hidden">
      <div class="border border-gray-200 mt-6">
        {navLinks.map((link, i) => {
          const isActive = currentPath.startsWith(link.href);
          const isLast = i === navLinks.length - 1;
          return (
            <a
              href={link.href}
              class={`mobile-nav-link flex items-center px-5 py-4 text-[15px] transition-colors ${!isLast ? 'border-b border-gray-200' : ''} ${isActive ? 'text-brand-dark font-semibold' : 'text-gray-500 hover:text-brand-dark'}`}
            >
              {link.label}
            </a>
          );
        })}
      </div>
      <a
        href="https://cal.com/ananth-vanchi/30min" target="_blank" rel="noopener noreferrer"
        class="w-full inline-flex items-center justify-center px-5 py-3 mt-6 mb-4 rounded-none bg-brand-dark text-[15px] md:text-sm font-medium hover:bg-brand-primary transition-colors duration-200 hero-btn-primary"
      >
        <span>Schedule Demo</span>
      </a>
    </div>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div id="mobile-menu-overlay" class="mobile-menu-overlay fixed inset-0 bg-black/50 z-40 md:hidden pointer-events-none" aria-hidden="true"></div>

<style>
  .mobile-nav-link {
    font-size: 15px !important;
  }

  /* Mobile menu animation */
  .mobile-menu {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease;
  }

  .mobile-menu.open {
    max-height: 100vh;
    opacity: 1;
  }

  #navbar.menu-open {
    background: white !important;
  }

  .mobile-menu-overlay {
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .mobile-menu-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: background-color 0.25s ease-out, color 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .nav-link::after {
    content: attr(data-text);
    font-weight: 600;
    visibility: hidden;
    height: 0;
    overflow: hidden;
    pointer-events: none;
  }

  /* Navbar dark mode */
  #navbar {
    transition: background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  :global(#navbar.navbar-dark) {
    background-color: #0f0f0f !important;
    border-color: rgba(255,255,255,0.1);
  }
  :global(#navbar.navbar-dark) .nav-link {
    color: rgba(255,255,255,0.5);
  }
  :global(#navbar.navbar-dark) .nav-link:hover {
    color: #ffffff;
  }
  :global(#navbar.navbar-dark) .nav-link[data-active] {
    color: #ffffff;
  }
  :global(#navbar.navbar-dark) #nav-pill rect {
    fill: rgba(255,255,255,0.1);
    transition: fill 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  :global(#navbar.navbar-dark) .navbar-logo-light {
    display: none;
  }
  :global(#navbar.navbar-dark) .navbar-logo-dark {
    display: block;
  }
  :global(#navbar.navbar-dark) #mobile-menu-btn {
    color: rgba(255,255,255,0.7);
  }
  :global(#navbar.navbar-dark) .mobile-nav-link {
    color: rgba(255,255,255,0.5) !important;
    border-color: rgba(255,255,255,0.1);
  }
  :global(#navbar.navbar-dark) .mobile-nav-link[class*="font-semibold"] {
    color: #ffffff !important;
  }
  :global(#navbar.navbar-dark.menu-open) {
    background-color: #0f0f0f !important;
  }
  :global(#navbar.navbar-dark) .mobile-menu a.hero-btn-primary {
    background-color: #ffffff !important;
  }
  :global(#navbar.navbar-dark) .mobile-menu a.hero-btn-primary span {
    background: none !important;
    -webkit-text-fill-color: #0f0f0f !important;
  }
</style>

<script is:inline>
  var navCleanup = null;

  function initNavbar() {
    if (navCleanup) navCleanup();

    var navbar = document.getElementById('navbar');
    var navPill = document.getElementById('nav-pill');
    var navLinksContainer = document.getElementById('navbar-links');
    var navLinkEls = navLinksContainer ? navLinksContainer.querySelectorAll('.nav-link') : null;

    if (!navbar || !navPill || !navLinksContainer || !navLinkEls) return;

    var listeners = [];
    function listen(el, evt, fn, opts) {
      el.addEventListener(evt, fn, opts);
      listeners.push([el, evt, fn]);
    }

    // Pill: snap to active link
    var activeLink = navLinksContainer.querySelector('.nav-link[data-active]');
    if (activeLink) {
      var containerRect = navLinksContainer.getBoundingClientRect();
      var linkRect = activeLink.getBoundingClientRect();
      navPill.setAttribute('width', String(linkRect.width));
      navPill.setAttribute('height', String(linkRect.height));
      navPill.style.transform = 'translate(' + (linkRect.left - containerRect.left) + 'px, ' + (linkRect.top - containerRect.top) + 'px)';
      navPill.style.opacity = '1';
    } else {
      navPill.style.opacity = '0';
    }

    // Scroll: hide on scroll down, show on scroll up
    var lastScrollY = window.scrollY;
    navbar.style.transition = 'transform 0.3s ease, background 0.3s ease, box-shadow 0.3s ease';

    function onScroll() {
      var scrollY = window.scrollY;
      var isMobile = window.innerWidth < 768;
      if (scrollY > 80) {
        if (isMobile) {
          navbar.classList.add('bg-white', 'shadow-sm');
        } else {
          navbar.classList.add('bg-white/90', 'backdrop-blur-md', 'shadow-sm');
        }
        navbar.style.transform = scrollY > lastScrollY ? 'translateY(-100%)' : 'translateY(0)';
      } else {
        navbar.classList.remove('bg-white/90', 'bg-white', 'backdrop-blur-md', 'shadow-sm');
        navbar.style.transform = 'translateY(0)';
      }
      lastScrollY = scrollY;
    }
    listen(window, 'scroll', onScroll, { passive: true });

    // CTA swap (homepage only)
    var navbarCtas = document.getElementById('navbar-ctas');
    var navbarLinks = document.getElementById('navbar-links');
    var heroCta = document.getElementById('hero-cta');

    if (navbarCtas && navbarLinks && heroCta) {
      function updateNavbarCtas() {
        var rect = heroCta.getBoundingClientRect();
        var visible = rect.bottom > 0 && rect.top < window.innerHeight;
        navbarLinks.style.opacity = visible ? '1' : '0';
        navbarLinks.style.pointerEvents = visible ? 'auto' : 'none';
        navbarCtas.style.opacity = visible ? '0' : '1';
        navbarCtas.style.pointerEvents = visible ? 'none' : 'auto';
      }
      listen(window, 'scroll', updateNavbarCtas, { passive: true });
      updateNavbarCtas();
    }

    // Mobile menu
    var btn = document.getElementById('mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    var menuIcon = document.getElementById('menu-icon');
    var closeIcon = document.getElementById('close-icon');
    var overlay = document.getElementById('mobile-menu-overlay');

    if (btn && menu && menuIcon && closeIcon) {
      function toggleMenu() {
        menu.classList.toggle('open');
        menuIcon.classList.toggle('hidden');
        closeIcon.classList.toggle('hidden');
        if (overlay) overlay.classList.toggle('open');
        document.body.classList.toggle('overflow-hidden');
        navbar.classList.toggle('menu-open');
      }

      listen(btn, 'click', toggleMenu);
      if (overlay) {
        listen(overlay, 'click', toggleMenu);
      }
    }

    navCleanup = function() {
      listeners.forEach(function(l) { l[0].removeEventListener(l[1], l[2]); });
      listeners.length = 0;
    };
  }

  document.addEventListener('DOMContentLoaded', initNavbar);
</script>

