---
const navLinks = [
  { label: 'Products', href: '#' },
  { label: 'Solutions', href: '#' },
  { label: 'Blogs', href: '/blog' },
  { label: 'Security', href: '#' },
  { label: 'About', href: '#' },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white"
>
  <div id="navbar-container" class="mx-auto max-w-7xl px-[106px]">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="#" class="flex items-center" onclick="event.preventDefault(); window.__scrollingToTop = true; window.scrollTo({ top: 0, behavior: 'smooth' }); const checkDone = () => { if (window.scrollY <= 0) { window.__scrollingToTop = false; } else { requestAnimationFrame(checkDone); } }; requestAnimationFrame(checkDone);">
        <img src="/assets/Logos/Logo with name (LR)/Colored (for light bg).svg" alt="CodeKarma" class="w-auto" style="height: 36px;" />
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center relative">
        <div id="navbar-links" class="flex items-center gap-8" style="transition: opacity 0.3s ease;">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-gray-500 hover:text-brand-dark transition-colors"
            >
              {link.label}
            </a>
          ))}
        </div>

        <!-- CTAs that appear when hero CTAs scroll out of view -->
        <div id="navbar-ctas" class="absolute right-0 flex items-center gap-4 opacity-0 pointer-events-none" style="transition: opacity 0.3s ease;">
          <a
            href="https://google.com"
            class="inline-flex items-center justify-center px-5 py-2 rounded-none bg-brand-dark text-sm font-medium hover:bg-brand-primary transition-colors duration-200 hero-btn-primary"
          >
            <span>Schedule Demo</span>
          </a>
          <a
            href="#"
            class="inline-flex items-center gap-1.5 text-brand-dark text-sm font-medium hover:opacity-70 transition-opacity duration-200"
          >
            View platform
            <i class="ph ph-arrow-right text-base"></i>
          </a>
        </div>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-gray-500 hover:text-brand-dark"
        aria-label="Toggle menu"
      >
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-3 pt-2">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-gray-500 hover:text-brand-dark transition-colors py-1"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>

<script>
  import { gsap, ScrollTrigger } from '../../lib/gsap';

  // Navbar hide on scroll down, show on scroll up
  const navbar = document.getElementById('navbar');
  if (navbar) {
    navbar.style.transition = 'transform 0.3s ease, background 0.3s ease, backdrop-filter 0.3s ease, box-shadow 0.3s ease';

    ScrollTrigger.create({
      start: 'top -80',
      onUpdate: (self) => {
        if (self.scroll() > 80) {
          navbar.classList.add('bg-white/90', 'backdrop-blur-md', 'shadow-sm');
          if (self.direction === 1) {
            navbar.style.transform = 'translateY(-100%)';
          } else {
            navbar.style.transform = 'translateY(0)';
          }
        } else {
          navbar.classList.remove('bg-white/90', 'backdrop-blur-md', 'shadow-sm');
          navbar.style.transform = 'translateY(0)';
        }
      },
    });
  }

  // Show/hide navbar CTAs and nav links based on hero CTA visibility
  const navbarCtas = document.getElementById('navbar-ctas');
  const navbarLinks = document.getElementById('navbar-links');
  const heroCta = document.getElementById('hero-cta');

  if (navbarCtas && navbarLinks && heroCta) {
    function updateNavbarCtas() {
      const heroCtaRect = heroCta.getBoundingClientRect();
      const isHeroCtaVisible = heroCtaRect.bottom > 0 && heroCtaRect.top < window.innerHeight;

      if (!isHeroCtaVisible) {
        // Hero CTAs scrolled out — fade out nav links, fade in CTAs
        navbarLinks.style.opacity = '0';
        navbarLinks.style.pointerEvents = 'none';
        navbarCtas.style.opacity = '1';
        navbarCtas.style.pointerEvents = 'auto';
      } else {
        // Hero CTAs visible — show nav links instantly, hide CTAs
        navbarLinks.style.opacity = '1';
        navbarLinks.style.pointerEvents = 'auto';
        navbarCtas.style.opacity = '0';
        navbarCtas.style.pointerEvents = 'none';
      }
    }

    window.addEventListener('scroll', updateNavbarCtas, { passive: true });
    updateNavbarCtas();
  }

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>

