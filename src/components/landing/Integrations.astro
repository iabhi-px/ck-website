        <svg class="swatch-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M4 6h16v12H4V6zm2 2v8h12V8H6z" opacity=".3"/><path d="M7 11h4l-1.5-1.5M7 13h4l-1.5 1.5" /><path d="M13 11h4l-1.5-1.5M13 13h4l-1.5 1.5" opacity=".5"/></svg>
