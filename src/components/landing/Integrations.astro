---
---

<section id="integrations" class="relative bg-white pt-24 pb-12">
  <!-- Vertical gridlines -->
  <div class="absolute inset-0 mx-auto max-w-7xl px-[106px] pointer-events-none z-0" aria-hidden="true">
    <div class="relative h-full">
      <div class="absolute left-0 top-0 bottom-0 w-px bg-gray-200"></div>
      <div class="absolute right-0 top-0 bottom-0 w-px bg-gray-200"></div>
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-[106px]">
    <!-- Section header -->
    <div class="max-w-3xl mb-16">
      <p class="text-sm font-mono tracking-[0.3em] uppercase text-brand-dark/40 mb-5">Integrations</p>
      <h2 class="text-[40px] sm:text-[48px] tracking-tight text-brand-dark leading-[1.1] font-semibold ml-[-1px]">
        Zero friction.<br /> Any stack. Any cloud.
      </h2>
    </div>

    <!-- Languages & Clouds side by side -->
    <div class="flex gap-8">
      <div class="min-w-0 flex-1 max-w-[50%]">
        <p class="text-lg font-medium text-gray-400">Languages</p>
        <section class="palette" data-palette>
          <div class="swatch" data-icon-id="java" style="--swatch-bg: #B07219; --icon-scale: 1;">
            <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_java.svg" alt="Java" />
            <span class="swatch-name">Java 8+</span></div>
          <div class="swatch" data-icon-id="go" style="--swatch-bg: #00ADD8; --icon-scale: 1.3;">
            <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_go.svg" alt="Go" />
            <span class="swatch-name">Go</span></div>
          <div class="swatch" data-icon-id="python" style="--swatch-bg: #3572A5; --icon-scale: 1;">
            <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_python.svg" alt="Python" />
            <span class="swatch-name">Python</span></div>
          <div class="swatch" data-icon-id="dotnet" style="--swatch-bg: #512BD4; --icon-scale: 1;">
            <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_dotnet.svg" alt=".NET" />
            <span class="swatch-name">.NET</span></div>
        </section>
      </div>
      <div class="min-w-0 flex-1 max-w-[50%]">
        <p class="text-lg font-medium text-gray-400">Clouds</p>
        <section class="palette" data-palette>
          <div class="swatch" data-icon-id="aws" style="--swatch-bg: #FF9900; --icon-scale: 1;">
            <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/AWS.svg" alt="AWS" />
            <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/AWS_hover.svg" alt="AWS" />
            <span class="swatch-name">AWS</span></div>
          <div class="swatch" data-icon-id="gcp" style="--swatch-bg: #4285F4; --icon-scale: 1;">
            <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_gcp.svg" alt="GCP" />
            <span class="swatch-name">GCP</span></div>
          <div class="swatch" data-icon-id="azure" style="--swatch-bg: #0078D4; --icon-scale: 1;">
            <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/Azure.svg" alt="Azure" />
            <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/Azure_hover.svg" alt="Azure" />
            <span class="swatch-name">Azure</span></div>
        </section>
      </div>
    </div>
    <div class="int-line"></div>

    <!-- Databases -->
    <p class="text-lg font-medium text-gray-400 mt-10">Databases</p>
    <section class="palette" data-palette>
      <div class="swatch" data-icon-id="mysql" style="--swatch-bg: #00758F; --icon-scale: 1.3;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_mysql.svg" alt="MySQL" />
        <span class="swatch-name">MySQL</span></div>
      <div class="swatch" data-icon-id="postgres" style="--swatch-bg: #336791; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_postgres.svg" alt="Postgres" />
        <span class="swatch-name">Postgres</span></div>
      <div class="swatch" data-icon-id="mongodb" style="--swatch-bg: #47A248; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_mongodb.svg" alt="MongoDB" />
        <span class="swatch-name">MongoDB</span></div>
      <div class="swatch" data-icon-id="dynamodb" style="--swatch-bg: #4053D6; --icon-scale: 1.3;">
        <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/DynamoDB.svg" alt="DynamoDB" />
        <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/DynamoDB_hover.svg" alt="DynamoDB" />
        <span class="swatch-name">DynamoDB</span></div>
      <div class="swatch" data-icon-id="redis" style="--swatch-bg: #DC382D; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_redis.svg" alt="Redis" />
        <span class="swatch-name">Redis</span></div>
      <div class="swatch" data-icon-id="cosmos" style="--swatch-bg: #0078D4; --icon-scale: 1.3;">
        <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/Cosmos.svg" alt="Cosmos" />
        <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/Cosmos_hover.svg" alt="Cosmos" />
        <span class="swatch-name">Cosmos</span></div>
      <div class="swatch" data-icon-id="mariadb" style="--swatch-bg: #003545; --icon-scale: 1.3;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_mariadb.svg" alt="MariaDB" />
        <span class="swatch-name">MariaDB</span></div>
      <div class="swatch" data-icon-id="hbase" style="--swatch-bg: #C72E49; --icon-scale: 1.3;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_hbase.svg" alt="HBase" />
        <span class="swatch-name">HBase</span></div>
      <div class="swatch" data-icon-id="elastic" style="--swatch-bg: #FEC514; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_elasticsearch.svg" alt="Elastic" />
        <span class="swatch-name">Elastic</span></div>
    </section>
    <div class="int-line"></div>

    <!-- Queues -->
    <p class="text-lg font-medium text-gray-400 mt-10">Queues</p>
    <section class="palette" data-palette>
      <div class="swatch" data-icon-id="kafka" style="--swatch-bg: #231F20; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/kafka.svg" alt="Kafka" />
        <span class="swatch-name">Kafka</span></div>
      <div class="swatch" data-icon-id="pulsar" style="--swatch-bg: #188FFF; --icon-scale: 1.3;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_pulsar.svg" alt="Pulsar" />
        <span class="swatch-name">Pulsar</span></div>
      <div class="swatch" data-icon-id="rabbitmq" style="--swatch-bg: #FF6600; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_rabbitmq.svg" alt="RabbitMQ" />
        <span class="swatch-name">RabbitMQ</span></div>
      <div class="swatch" data-icon-id="sqs" style="--swatch-bg: #FF9900; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/SQS.png" alt="SQS" />
        <span class="swatch-name">SQS</span></div>
      <div class="swatch" data-icon-id="sns" style="--swatch-bg: #D9A741; --icon-scale: 1.3;">
        <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/SNS.svg" alt="SNS" />
        <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/SNS_hover.svg" alt="SNS" />
        <span class="swatch-name">SNS</span></div>
    </section>
    <div class="int-line"></div>

    <!-- Infra & Protocols side by side -->
    <div class="flex gap-8 mt-10">
      <div class="min-w-0 flex-1 max-w-[50%]">
        <p class="text-lg font-medium text-gray-400">Infra</p>
        <section class="palette" data-palette>
          <div class="swatch" data-icon-id="kubernetes" style="--swatch-bg: #326CE5; --icon-scale: 1;">
            <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_kubernetes.svg" alt="Kubernetes" />
            <span class="swatch-name">Kubernetes</span></div>
        </section>
      </div>
      <div class="min-w-0 flex-1 max-w-[50%]">
        <p class="text-lg font-medium text-gray-400">Protocols</p>
        <section class="palette" data-palette>
          <div class="swatch" data-icon-id="https" style="--swatch-bg: #005C9C; --icon-scale: 1;">
            <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/www.svg" alt="HTTP/S" />
            <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/www_hover.svg" alt="HTTP/S" />
            <span class="swatch-name">HTTP/S</span></div>
          <div class="swatch" data-icon-id="grpc" style="--swatch-bg: #244C5A; --icon-scale: 1.3;">
            <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/grpc.svg" alt="gRPC" />
            <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/grpc_hover.svg" alt="gRPC" />
            <span class="swatch-name">gRPC</span></div>
        </section>
      </div>
    </div>
    <div class="int-line"></div>

    <!-- IDEs & AI Tools -->
    <p class="text-lg font-medium text-gray-400 mt-10">IDEs & AI Tools</p>
    <section class="palette" data-palette>
      <div class="swatch" style="--swatch-bg: #000000;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/jetbrains.svg" alt="JetBrains" />
      <span class="swatch-name">JetBrains</span></div>
      <div class="swatch" style="--swatch-bg: #007ACC;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/vscode.svg" alt="VS Code" />
      <span class="swatch-name">VS Code</span></div>
      <div class="swatch" style="--swatch-bg: #1A1A2E;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/cursor.svg" alt="Cursor" />
      <span class="swatch-name">Cursor</span></div>
      <div class="swatch" style="--swatch-bg: #09B6A2;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/windsurf.svg" alt="Windsurf" />
      <span class="swatch-name">Windsurf</span></div>
      <div class="swatch" style="--swatch-bg: #24292e;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/copilot.svg" alt="Copilot" />
      <span class="swatch-name">Copilot</span></div>
      <div class="swatch" style="--swatch-bg: #D4A574;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/claude.svg" alt="Claude" />
      <span class="swatch-name">Claude</span></div>
      <div class="swatch" style="--swatch-bg: #111111;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/copilot.svg" alt="Custom Agents" />
      <span class="swatch-name">Custom Agents</span></div>
    </section>
    <div class="int-line"></div>
  </div>
</section>

<style is:global>
  .palette {
    box-sizing: content-box;
    block-size: 70px;
    display: flex;
    overflow: visible;
    min-inline-size: 0;
    padding: 32px 0 0 0;
    position: relative;
    z-index: 10;
    clip-path: inset(-200px -10px -10px -10px);
  }

  .swatch {
    border-radius: 20px;
    block-size: 220px;
    background-color: #ffffff !important;
    border: 1px solid #e0e0e0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    color: #0d0d0e;
    display: flex;
    flex-basis: 100%;
    font-weight: 500;
    align-items: flex-start;
    justify-content: space-between;
    padding: 16px;
    position: relative;
    will-change: transform;
    --card-color: var(--swatch-bg);
  }

  .swatch.active {
    background-color: var(--swatch-bg, #fafafa) !important;
    color: #ffffff;
    border-color: transparent;
  }

  .swatch.active .swatch-icon {
    color: #ffffff;
    fill: #ffffff;
  }

  .swatch.active .swatch-icon-img:not(.swatch-logo-hover) {
    filter: brightness(0) invert(1);
  }

  /* Unified icon styling: scale from --icon-scale, grey default, white on active */
  .swatch-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    filter: grayscale(1) brightness(0.4);
    transition: filter 0.3s ease, transform 0.3s ease;
    transform: scale(var(--icon-scale, 1));
    transform-origin: center center;
  }

  .swatch.active .swatch-icon {
    filter: brightness(0) invert(1);
  }

  /* Hide hover image variants — CSS filter handles everything */
  .swatch-logo-hover {
    display: none !important;
  }

  .swatch-name {
    font-size: 12px;
    font-weight: 500;
    text-align: right;
    line-height: 1.25;
  }

  .swatch + .swatch {
    margin-inline-start: -20%;
  }

  .int-line {
    height: 1px;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    margin-top: 10px;
    background: linear-gradient(to right, #fafafa, #e5e5e5, #fafafa);
    position: relative;
    z-index: 20;
  }
</style>

<script>
  import { gsap } from '../../lib/gsap';

  function initIntegrations() {
  document.querySelectorAll<HTMLElement>('[data-palette]').forEach((palette) => {
    const swatches = Array.from(palette.querySelectorAll<HTMLElement>('.swatch'));

    function resetAll() {
      swatches.forEach((s) => {
        s.classList.remove('active');
        gsap.to(s, {
          yPercent: 0,
          rotation: 0,
          duration: 0.4,
          ease: 'power3.out',
          overwrite: true,
        });
      });
    }

    swatches.forEach((swatch, i) => {
      swatch.addEventListener('mouseenter', () => {
        swatches.forEach((s) => s.classList.remove('active'));
        swatch.classList.add('active');

        // Hovered card
        gsap.to(swatch, {
          yPercent: -35,
          rotation: -1,
          duration: 0.5,
          ease: 'power3.out',
          overwrite: true,
        });

        // One before
        if (i > 0) {
          gsap.to(swatches[i - 1], {
            yPercent: -12,
            rotation: -0.5,
            duration: 0.5,
            ease: 'power3.out',
            overwrite: true,
          });
        }

        // Two before
        if (i > 1) {
          gsap.to(swatches[i - 2], {
            yPercent: -5,
            rotation: -0.25,
            duration: 0.5,
            ease: 'power3.out',
            overwrite: true,
          });
        }

        // One after
        if (i < swatches.length - 1) {
          gsap.to(swatches[i + 1], {
            yPercent: -5,
            rotation: -0.25,
            duration: 0.5,
            ease: 'power3.out',
            overwrite: true,
          });
        }

        // Two after
        if (i < swatches.length - 2) {
          gsap.to(swatches[i + 2], {
            yPercent: -2,
            rotation: -0.1,
            duration: 0.5,
            ease: 'power3.out',
            overwrite: true,
          });
        }

        // Reset others
        swatches.forEach((s, j) => {
          if (Math.abs(j - i) > 2) {
            gsap.to(s, {
              yPercent: 0,
              rotation: 0,
              duration: 0.5,
              ease: 'power3.out',
              overwrite: true,
            });
          }
        });
      });
    });

    palette.addEventListener('mouseleave', resetAll);
  });
  }

  document.addEventListener('astro:page-load', initIntegrations);
</script>
