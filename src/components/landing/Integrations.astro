---
import IntegrationDialKit from './IntegrationDialKit';
---

<section id="integrations" class="relative bg-white pt-4 md:pt-20 pb-20">
  <!-- Vertical gridlines -->
  <div class="hidden md:block absolute inset-0 mx-auto max-w-7xl px-10 lg:px-[88px] pointer-events-none z-0" aria-hidden="true">
    <div class="relative h-full">
      <div class="absolute left-0 top-0 bottom-0 w-px bg-gray-200"></div>
      <div class="absolute right-0 top-0 bottom-0 w-px bg-gray-200"></div>
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-5 md:px-10 lg:px-[88px]">
    <!-- Section header -->
    <div class="mb-16 text-center">
      <p class="text-sm font-mono tracking-[0.3em] uppercase text-brand-dark/40 mb-5">Integrations</p>
      <h2 class="text-[28px] sm:text-[40px] md:text-[48px] tracking-tight text-brand-dark leading-[1.1] font-semibold">
        Zero friction.<br /> Any stack. Any cloud.
      </h2>
    </div>

    <!-- Desktop: Languages & Clouds side by side -->
    <div class="flex flex-col md:flex-row gap-8">
      <div class="min-w-0 flex-1 max-w-full md:max-w-[50%]">
        <p class="text-[15px] md:text-lg font-medium text-gray-400 pl-0 md:pl-6">Languages</p>
        <section class="palette" data-palette>
          <div class="swatch" data-icon-id="java" style="--swatch-bg: #B07219; --icon-scale: 1.3;">
            <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/Java.svg" alt="Java" />
            <span class="swatch-name">Java 8+</span></div>
          <div class="swatch" data-icon-id="go" style="--swatch-bg: #00ADD8; --icon-scale: 1.3;">
            <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_go.svg" alt="Go" />
            <span class="swatch-name">Go</span></div>
          <div class="swatch" data-icon-id="python" style="--swatch-bg: #3572A5; --icon-scale: 1;">
            <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_python.svg" alt="Python" />
            <span class="swatch-name">Python</span></div>
          <div class="swatch" data-icon-id="dotnet" style="--swatch-bg: #512BD4; --icon-scale: 1.2;">
            <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_dotnet.svg" alt=".NET" />
            <span class="swatch-name">.NET</span></div>
        </section>
      </div>
      <div class="min-w-0 flex-1 max-w-full md:max-w-[50%]">
        <p class="text-[15px] md:text-lg font-medium text-gray-400 pl-0 md:pl-6">Clouds</p>
        <section class="palette" data-palette>
          <div class="swatch" data-icon-id="aws" style="--swatch-bg: #FF9900; --icon-scale: 1.1;">
            <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/AWS.svg" alt="AWS" />
            <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/AWS_hover.svg" alt="AWS" />
            <span class="swatch-name">AWS</span></div>
          <div class="swatch" data-icon-id="gcp" style="--swatch-bg: #4285F4; --icon-scale: 1;">
            <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_gcp.svg" alt="GCP" />
            <span class="swatch-name">GCP</span></div>
          <div class="swatch" data-icon-id="azure" style="--swatch-bg: #0078D4; --icon-scale: 1.1;">
            <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/Azure.svg" alt="Azure" />
            <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/Azure_hover.svg" alt="Azure" />
            <span class="swatch-name">Azure</span></div>
        </section>
      </div>
    </div>
    <div class="palette-line"></div>

    <!-- Databases -->
    <p class="text-[15px] md:text-lg font-medium text-gray-400 mt-[54px] pl-0 md:pl-6">Databases</p>
    <section class="palette" data-palette>
      <div class="swatch" data-icon-id="mysql" style="--swatch-bg: #00758F; --icon-scale: 1.5;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_mysql.svg" alt="MySQL" />
        <span class="swatch-name">MySQL</span></div>
      <div class="swatch" data-icon-id="postgres" style="--swatch-bg: #336791; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/Postgres.svg" alt="Postgres" />
        <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/Postgres_hover.svg" alt="Postgres" />
        <span class="swatch-name">Postgres</span></div>
      <div class="swatch" data-icon-id="mongodb" style="--swatch-bg: #47A248; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_mongodb.svg" alt="MongoDB" />
        <span class="swatch-name">MongoDB</span></div>
      <div class="swatch" data-icon-id="dynamodb" style="--swatch-bg: #4053D6; --icon-scale: 1.2;">
        <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/DynamoDB.svg" alt="DynamoDB" />
        <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/DynamoDB_hover.png" alt="DynamoDB" />
        <span class="swatch-name">DynamoDB</span></div>
      <div class="swatch" data-icon-id="redis" style="--swatch-bg: #DC382D; --icon-scale: 1.1;">
        <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/Redis_default.png" alt="Redis" />
        <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/Redis_hover.svg" alt="Redis" />
        <span class="swatch-name">Redis</span></div>
      <div class="swatch" data-icon-id="cosmos" style="--swatch-bg: #0078D4; --icon-scale: 1.8;">
        <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/Cosmos.svg" alt="Cosmos" />
        <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/Cosmos_hover.svg" alt="Cosmos" />
        <span class="swatch-name">Cosmos</span></div>
      <div class="swatch" data-icon-id="mariadb" style="--swatch-bg: #003545; --icon-scale: 1.4;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_mariadb.svg" alt="MariaDB" />
        <span class="swatch-name">MariaDB</span></div>
      <div class="swatch" data-icon-id="hbase" style="--swatch-bg: #C72E49; --icon-scale: 1.4;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_hbase.svg" alt="HBase" />
        <span class="swatch-name">HBase</span></div>
      <div class="swatch" data-icon-id="elastic" style="--swatch-bg: #FEC514; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_elasticsearch.svg" alt="Elastic" />
        <span class="swatch-name">Elastic</span></div>
    </section>
    <div class="palette-line"></div>

    <!-- Queues -->
    <p class="text-[15px] md:text-lg font-medium text-gray-400 mt-[54px] pl-0 md:pl-6">Queues</p>
    <section class="palette" data-palette>
      <div class="swatch" data-icon-id="kafka" style="--swatch-bg: #231F20; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/kafka.svg" alt="Kafka" />
        <span class="swatch-name">Kafka</span></div>
      <div class="swatch" data-icon-id="pulsar" style="--swatch-bg: #188FFF; --icon-scale: 1.1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_pulsar.svg" alt="Pulsar" />
        <span class="swatch-name">Pulsar</span></div>
      <div class="swatch" data-icon-id="rabbitmq" style="--swatch-bg: #FF6600; --icon-scale: 0.9;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_rabbitmq.svg" alt="RabbitMQ" />
        <span class="swatch-name">RabbitMQ</span></div>
      <div class="swatch" data-icon-id="sqs" style="--swatch-bg: #FF9900; --icon-scale: 1.1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/SQS.png" alt="SQS" />
        <span class="swatch-name">SQS</span></div>
      <div class="swatch" data-icon-id="sns" style="--swatch-bg: #D9A741; --icon-scale: 1.4;">
        <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/SNS.svg" alt="SNS" />
        <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/SNS_hover.svg" alt="SNS" />
        <span class="swatch-name">SNS</span></div>
    </section>
    <div class="palette-line"></div>

    <!-- Infra & Protocols: combined on mobile, side-by-side on desktop -->
    <div class="block md:hidden mt-[54px]">
      <p class="text-[15px] md:text-lg font-medium text-gray-400 pl-0">Infra & Protocols</p>
      <section class="palette" data-palette>
        <div class="swatch swatch-kubernetes" data-icon-id="kubernetes" style="--swatch-bg: #326CE5; --icon-scale: 1;">
          <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_kubernetes.svg" alt="Kubernetes" />
          <span class="swatch-name">Kubernetes</span></div>
        <div class="swatch" data-icon-id="https" style="--swatch-bg: #005C9C; --icon-scale: 1;">
          <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/www.svg" alt="HTTP/S" />
          <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/www_hover.svg" alt="HTTP/S" />
          <span class="swatch-name">HTTP/S</span></div>
        <div class="swatch" data-icon-id="grpc" style="--swatch-bg: #244C5A; --icon-scale: 1.3;">
          <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/gRPC_default.png" alt="gRPC" />
          <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/gRPC_hover.png" alt="gRPC" />
          <span class="swatch-name">gRPC</span></div>
      </section>
    </div>
    <div class="hidden md:flex flex-row gap-8 mt-[54px]">
      <div class="min-w-0 flex-1 max-w-[50%]">
        <p class="text-[15px] md:text-lg font-medium text-gray-400 pl-6">Infra</p>
        <section class="palette" data-palette>
          <div class="swatch swatch-kubernetes" data-icon-id="kubernetes" style="--swatch-bg: #326CE5; --icon-scale: 1;">
            <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/si_kubernetes.svg" alt="Kubernetes" />
            <span class="swatch-name">Kubernetes</span></div>
        </section>
      </div>
      <div class="min-w-0 flex-1 max-w-[50%]">
        <p class="text-[15px] md:text-lg font-medium text-gray-400 pl-6">Protocols</p>
        <section class="palette" data-palette>
          <div class="swatch" data-icon-id="https" style="--swatch-bg: #005C9C; --icon-scale: 1;">
            <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/www.svg" alt="HTTP/S" />
            <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/www_hover.svg" alt="HTTP/S" />
            <span class="swatch-name">HTTP/S</span></div>
          <div class="swatch" data-icon-id="grpc" style="--swatch-bg: #244C5A; --icon-scale: 1.3;">
            <img class="swatch-icon swatch-icon-img swatch-logo-default" src="/assets/integration_logos/gRPC_default.png" alt="gRPC" />
            <img class="swatch-icon swatch-icon-img swatch-logo-hover" src="/assets/integration_logos/gRPC_hover.png" alt="gRPC" />
            <span class="swatch-name">gRPC</span></div>
        </section>
      </div>
    </div>
    <div class="palette-line"></div>

    <!-- IDEs & AI Tools -->
    <p class="text-[15px] md:text-lg font-medium text-gray-400 mt-[54px] pl-0 md:pl-6">IDEs & AI Tools</p>
    <section class="palette" data-palette>
      <div class="swatch" data-icon-id="jetbrains" style="--swatch-bg: #000000; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/jetbrains.svg" alt="JetBrains" />
      <span class="swatch-name">JetBrains</span></div>
      <div class="swatch" data-icon-id="vscode" style="--swatch-bg: #007ACC; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/vscode.svg" alt="VS Code" />
      <span class="swatch-name">VS Code</span></div>
      <div class="swatch" data-icon-id="cursor" style="--swatch-bg: #1A1A2E; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/cursor.svg" alt="Cursor" />
      <span class="swatch-name">Cursor</span></div>
      <div class="swatch" data-icon-id="windsurf" style="--swatch-bg: #09B6A2; --icon-scale: 1.1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/windsurf.svg" alt="Windsurf" />
      <span class="swatch-name">Windsurf</span></div>
      <div class="swatch" data-icon-id="copilot" style="--swatch-bg: #24292e; --icon-scale: 1.1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/copilot.svg" alt="Copilot" />
      <span class="swatch-name">Copilot</span></div>
      <div class="swatch" data-icon-id="claude" style="--swatch-bg: #d97757; --icon-scale: 1;">
        <img class="swatch-icon swatch-icon-filter" src="/assets/integration_logos/claude.svg" alt="Claude" />
      <span class="swatch-name">Claude</span></div>
      <div class="swatch" data-icon-id="customagents" style="--swatch-bg: #111111; --icon-scale: 1.2;">
        <i class="ph ph-robot swatch-icon swatch-icon-filter" style="font-size: 24px; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;"></i>
      <span class="swatch-name">Custom Agents</span></div>
    </section>
    <div class="palette-line"></div>
  </div>
  <!-- <IntegrationDialKit client:load /> -->
</section>

<style is:global>
  .palette {
    box-sizing: content-box;
    block-size: 70px;
    display: flex;
    overflow: visible;
    min-inline-size: 0;
    padding: 16px 24px 0 24px;
    position: relative;
    z-index: 10;
    clip-path: inset(-200px -10px -10px -10px);
  }

  .swatch {
    border-radius: 20px;
    block-size: 220px;
    background-color: #ffffff !important;
    border: 1px solid #e0e0e0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    color: #0d0d0e;
    display: flex;
    flex-basis: 100%;
    font-weight: 500;
    align-items: flex-start;
    justify-content: space-between;
    padding: 16px;
    position: relative;
    will-change: transform;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
    --card-color: var(--swatch-bg);
  }

  .swatch.active {
    background-color: var(--swatch-bg, #fafafa) !important;
    color: #ffffff;
    border-color: transparent;
  }

  .swatch.active .swatch-icon {
    color: #ffffff;
    fill: #ffffff;
  }


  /* Unified icon styling: scale from --icon-scale, grey default, white on active */
  .swatch-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    object-fit: contain;
    filter: grayscale(1) brightness(0.4);
    transition: filter 0.3s ease, transform 0.3s ease;
    transform: scale(var(--icon-scale, 1));
    transform-origin: center center;
  }

  .swatch-icon-img {
    filter: none;
  }

  .swatch.active .swatch-icon {
    filter: brightness(0) invert(1);
  }

  /* Hover image: positioned on top of default, hidden by default */
  .swatch-logo-hover {
    position: absolute;
    top: 16px;
    left: 16px;
    opacity: 0;
  }

  .swatch-name {
    font-size: 12px;
    font-weight: 500;
    text-align: right;
    line-height: 1.25;
  }

  .palette-line {
    height: 1px;
    background: #e5e5e5;
    margin-top: 10px;
    position: relative;
    z-index: 20;
  }

  .swatch + .swatch {
    margin-inline-start: -20%;
  }

  @media (max-width: 640px) {
    /* Hide category labels, lines, and side-by-side layout on mobile */
    .palette-line {
      display: none;
    }

    .palette {
      block-size: auto;
      padding: 10px 0;
      clip-path: none;
      gap: 8px;
      overflow-x: auto;
      overflow-y: visible;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }
    .palette::-webkit-scrollbar {
      display: none;
    }
    .swatch {
      block-size: 100px;
      min-width: 100px;
      max-width: 100px;
      flex-shrink: 0;
      border-radius: 14px;
      padding: 10px;
      flex-direction: column;
      scroll-snap-align: start;
    }
    .swatch + .swatch {
      margin-inline-start: 0;
    }
    .swatch-kubernetes {
      min-width: fit-content;
    }
    .swatch-icon {
      width: 18px;
      height: 18px;
    }
    .swatch-name {
      font-size: 13px;
      text-align: left;
      margin-top: auto;
    }
    .swatch {
      background-color: var(--swatch-bg, #fafafa) !important;
      color: #ffffff;
      border-color: transparent;
      pointer-events: none;
    }
    .swatch .swatch-icon {
      filter: brightness(0) invert(1);
    }
    .swatch .swatch-logo-default {
      opacity: 0;
    }
    .swatch .swatch-logo-hover {
      opacity: 1;
      filter: none;
    }
  }
</style>

<script>
  function initIntegrations() {
    document.querySelectorAll<HTMLElement>('[data-palette]').forEach((palette) => {
      const swatches = Array.from(palette.querySelectorAll<HTMLElement>('.swatch'));

      function applyTransform(el: HTMLElement, yPercent: number, rotation: number) {
        el.style.transform = `translateY(${yPercent}%) rotate(${rotation}deg)`;
      }

      function swapImages(el: HTMLElement, active: boolean) {
        const def = el.querySelector<HTMLElement>('.swatch-logo-default');
        const hov = el.querySelector<HTMLElement>('.swatch-logo-hover');
        if (def && hov) {
          def.style.opacity = active ? '0' : '1';
          def.style.filter = active ? 'none' : '';
          hov.style.opacity = active ? '1' : '0';
          hov.style.filter = 'none';
        }
      }

      function resetAll() {
        swatches.forEach((s) => {
          s.classList.remove('active');
          applyTransform(s, 0, 0);
          swapImages(s, false);
        });
      }

      swatches.forEach((swatch, i) => {
        swatch.addEventListener('mouseenter', () => {
          swatches.forEach((s) => {
            s.classList.remove('active');
            swapImages(s, false);
          });
          swatch.classList.add('active');
          swapImages(swatch, true);

          // Hovered card
          applyTransform(swatch, -35, -1);

          // One before
          if (i > 0) {
            applyTransform(swatches[i - 1], -12, -0.5);
          }

          // Two before
          if (i > 1) {
            applyTransform(swatches[i - 2], -5, -0.25);
          }

          // One after
          if (i < swatches.length - 1) {
            applyTransform(swatches[i + 1], -5, -0.25);
          }

          // Two after
          if (i < swatches.length - 2) {
            applyTransform(swatches[i + 2], -2, -0.1);
          }

          // Reset others
          swatches.forEach((s, j) => {
            if (Math.abs(j - i) > 2) {
              applyTransform(s, 0, 0);
            }
          });
        });
      });

      palette.addEventListener('mouseleave', resetAll);
    });
  }

  document.addEventListener('DOMContentLoaded', initIntegrations);
</script>
