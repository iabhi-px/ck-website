      <div class="swatch" style="--swatch-bg: #C72E49;">
        <svg class="swatch-icon" viewBox="0 0 24 24" fill="white"><rect x="3" y="3" width="7" height="7" rx="1" opacity=".5"/><rect x="14" y="3" width="7" height="7" rx="1" opacity=".5"/><rect x="3" y="14" width="7" height="7" rx="1" opacity=".5"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
