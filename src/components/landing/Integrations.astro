<style is:global>
  .palette {
    box-sizing: content-box;
    block-size: 70px;
    display: flex;
    overflow: visible;
    min-inline-size: 0;
    padding: 32px 0 0 0;
    position: relative;
    z-index: 10;
    clip-path: inset(-200px -10px 0 -10px);
  }

  .swatch {
    border-radius: 20px;
    block-size: 140px;
    background-color: #ffffff !important;
    border: 1px solid #e0e0e0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    color: #0d0d0e;
    display: flex;
    flex-basis: 100%;
    font-weight: 500;
    align-items: flex-start;
    justify-content: space-between;
    padding: 16px;
    position: relative;
    will-change: transform;
    --card-color: var(--swatch-bg);
  }

  .swatch.active {
    background-color: var(--swatch-bg, #fafafa) !important;
    color: #ffffff;
    border-color: transparent;
  }

  .swatch.active .swatch-icon {
    color: #ffffff;
    fill: #ffffff;
  }

  .swatch.active .swatch-icon-img {
    filter: brightness(0) invert(1);
  }

  .swatch-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: #0d0d0e;
    fill: #0d0d0e;
  }

  .swatch-icon-img {
    filter: brightness(0);
    width: 24px;
    height: 24px;
  }

  .swatch-name {
    font-size: 13px;
    font-weight: 500;
    text-align: right;
    line-height: 1.2;
  }

  .swatch + .swatch {
    margin-inline-start: -20%;
  }

  .int-line {
    height: 1px;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    background: linear-gradient(to right, transparent, #d4d4d4 30%, #d4d4d4 70%, transparent);
  }
</style>

<script>
  import { gsap } from '../../lib/gsap';

  document.querySelectorAll<HTMLElement>('[data-palette]').forEach((palette) => {
    const swatches = Array.from(palette.querySelectorAll<HTMLElement>('.swatch'));

    function resetAll() {
      swatches.forEach((s) => {
        s.classList.remove('active');
        gsap.to(s, {
          yPercent: 0,
          rotation: 0,
          duration: 0.4,
          ease: 'power3.out',
          overwrite: true,
        });
      });
    }

    swatches.forEach((swatch, i) => {
      swatch.addEventListener('mouseenter', () => {
        swatches.forEach((s) => s.classList.remove('active'));
        swatch.classList.add('active');

        // Hovered card
        gsap.to(swatch, {
          yPercent: -65,
          rotation: -1.5,
          duration: 0.5,
          ease: 'power3.out',
          overwrite: true,
        });

        // One before
        if (i > 0) {
          gsap.to(swatches[i - 1], {
            yPercent: -20,
            rotation: -1,
            duration: 0.5,
            ease: 'power3.out',
            overwrite: true,
          });
        }

        // Two before
        if (i > 1) {
          gsap.to(swatches[i - 2], {
            yPercent: -8,
            rotation: -0.5,
            duration: 0.5,
            ease: 'power3.out',
            overwrite: true,
          });
        }

        // One after
        if (i < swatches.length - 1) {
          gsap.to(swatches[i + 1], {
            yPercent: -8,
            rotation: -0.5,
            duration: 0.5,
            ease: 'power3.out',
            overwrite: true,
          });
        }

        // Two after
        if (i < swatches.length - 2) {
          gsap.to(swatches[i + 2], {
            yPercent: -3,
            rotation: -0.25,
            duration: 0.5,
            ease: 'power3.out',
            overwrite: true,
          });
        }

        // Reset others
        swatches.forEach((s, j) => {
          if (Math.abs(j - i) > 2) {
            gsap.to(s, {
              yPercent: 0,
              rotation: 0,
              duration: 0.5,
              ease: 'power3.out',
              overwrite: true,
            });
          }
        });
      });
    });

    palette.addEventListener('mouseleave', resetAll);
  });
</script>
