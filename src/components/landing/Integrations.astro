    </section>
    <div class="int-line"></div>

    <!-- Queues -->
    <p class="text-lg font-medium text-gray-400 mt-10">Queues</p>
    <section class="palette" data-palette>
      <div class="swatch" style="--swatch-bg: #231F20;">
        <svg class="swatch-icon" viewBox="0 0 24 24" fill="white"><circle cx="15" cy="7" r="2.5" opacity=".6"/><circle cx="15" cy="17" r="2.5" opacity=".6"/><circle cx="9" cy="12" r="3"/><line x1="11.5" y1="10.5" x2="13" y2="8" stroke="white" stroke-width="1.5"/><line x1="11.5" y1="13.5" x2="13" y2="16" stroke="white" stroke-width="1.5"/></svg>
      <span class="swatch-name">Kafka</span></div>
      <div class="swatch" style="--swatch-bg: #188FFF;">
