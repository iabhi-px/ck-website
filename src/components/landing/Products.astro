---
const products = [
  {
    id: 'karmalens',
    name: 'KarmaLens',
    title: 'KarmaLens',
    description: 'IDE plugin. Dead and dormant code, method-level telemetry, and performance insights — right where you code.',
    link: '/products#karmalens',
    poster: '/assets/Videos/posters/karmalens.webp',
  },
  {
    id: 'karmadomain',
    name: 'KarmaDomain',
    title: 'KarmaDomain',
    description: 'Live system topology. API-level dependencies, fan-outs, and traffic flows in a single graph.',
    link: '/products#karmadomain',
    poster: '/assets/Videos/posters/karmadomain.webp',
  },
  {
    id: 'karmapulse',
    name: 'KarmaPulse',
    title: 'KarmaPulse',
    description: 'Operational action dashboard for leadership. See what\'s broken, what\'s drifting, and what to fix first.',
    link: '/products#karmapulse',
    poster: '/assets/Videos/posters/karmapulse.png',
  },
  {
    id: 'karmaiq',
    name: 'KarmaIQ',
    title: 'KarmaIQ',
    description: 'MCP server for AI agents. Production context for Cursor, Claude, Copilot, and custom agents.',
    link: '/products#karmaiq',
    poster: '/assets/Videos/posters/karmaiq.webp',
  },
];
---

<section id="products-section" class="relative bg-white pt-4 md:pt-20 pb-4 md:pb-20">
  <!-- Vertical gridlines -->
  <div class="hidden md:block absolute inset-0 mx-auto max-w-7xl px-10 lg:px-[88px] pointer-events-none z-0" aria-hidden="true">
    <div class="relative h-full">
      <div class="absolute left-0 top-0 bottom-0 w-px bg-gray-200"></div>
      <div class="absolute right-0 top-0 bottom-0 w-px bg-gray-200"></div>
    </div>
  </div>

  <!-- Section header — normal flow -->
  <div class="relative z-10 mx-auto max-w-7xl px-5 md:px-10 lg:px-[88px]">
    <div class="mb-16">
      <p id="products-label" class="text-sm font-mono tracking-[0.3em] uppercase lg:pl-12 text-brand-dark/40 mb-5">The Platform</p>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-16 items-end">
        <h2 id="products-heading" class="lg:pl-12 text-[28px] sm:text-[40px] md:text-[48px] tracking-tight text-brand-dark leading-[1.1] font-semibold">
          One truth.<br />Four products.
        </h2>
        <p id="products-subtext" class="lg:pl-12 lg:pr-12 text-[15px] md:text-lg text-gray-500 leading-[1.4] md:leading-[1.65] font-normal max-w-lg pb-0 md:pb-2">
          From developers and managers to VPs and AI agents — production intelligence for every role.
        </p>
      </div>
    </div>
  </div>

  <!-- Mobile: Horizontal scroll product cards -->
  <div class="md:hidden relative z-10 mx-auto max-w-7xl px-5">
    <div id="mobile-products-scroll" class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 scroll-smooth" style="-webkit-overflow-scrolling: touch;">
      {products.map((product) => (
        <a href={product.link} class="mobile-product-card snap-center flex-shrink-0 w-[80vw] group" style="transform-origin: center center; will-change: transform, opacity; scroll-snap-stop: always;">
          <!-- Card visual -->
          <div class="relative bg-brand-dark overflow-hidden mb-4">
            <img
              src={product.poster}
              alt={`${product.title} product video snapshot`}
              class="w-full aspect-square object-cover"
              loading="lazy"
              decoding="async"
            />
            <!-- Product name overlay -->
            <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/90 via-black/50 to-transparent">
              <span class="text-[24px] font-semibold text-white">{product.title}</span>
            </div>
          </div>
          <!-- Description below card -->
          <p class="text-[15px] text-gray-600 leading-[1.4] md:leading-[1.5] mb-3">{product.description}</p>
          <span class="inline-flex items-center gap-1.5 text-[15px] font-medium text-brand-dark group-hover:opacity-70 transition-opacity">
            Learn more
            <i class="ph ph-arrow-right text-base"></i>
          </span>
        </a>
      ))}
    </div>
  </div>

  <!-- Desktop: Tabs sticky container — tall to allow scroll room -->
  <div id="products-scroll-area" class="hidden md:block relative z-10 mx-auto max-w-7xl px-5 md:px-10 lg:px-[88px] products-scroll-area">
    <div class="products-tabs-wrapper sticky top-[15vh]" style="transition: margin 0.15s ease, border-radius 0.15s ease;">
      <!-- Tab buttons - folder style -->
      <div class="product-tabs-row">
        {products.map((product, index) => (
          <button
            class="product-tab"
            data-tab={product.id}
            data-index={index}
          >
            <span class="product-tab-label">{product.name}</span>
            <svg class="product-tab-bg" preserveAspectRatio="none" viewBox="0 0 200 50" fill="currentColor">
              <path d="M0 50 L15 50 Q20 50 25 40 L42 5 Q45 0 50 0 L150 0 Q155 0 158 5 L175 40 Q180 50 185 50 L200 50 Z" class="product-tab-path" />
            </svg>
          </button>
        ))}
        <!-- Sliding glider -->
        <div id="product-tab-glider" class="product-tab-glider">
          <svg preserveAspectRatio="none" viewBox="0 0 200 50" style="width: 100%; height: 100%;">
            <path d="M0 50 L15 50 Q20 50 25 40 L42 5 Q45 0 50 0 L150 0 Q155 0 158 5 L175 40 Q180 50 185 50 L200 50 Z" fill="#000000" />
          </svg>
        </div>
      </div>

      <!-- Tab content panels -->
      <div class="product-panels">
        {products.map((product, index) => (
          <div
            class="product-panel"
            data-panel={product.id}
            data-index={index}
          >
            <!-- Content area -->
            <div class="flex flex-col lg:flex-row">
              <!-- Left: Title + Description -->
              <div class="p-5 md:p-8 lg:p-10 flex flex-col justify-center w-full lg:w-[30%]">
                <h3 class="product-title text-[32px] font-semibold text-white mb-4">{product.title}</h3>
                <p class="product-desc text-[16px] md:text-base text-gray-400 leading-[1.65]">{product.description}</p>
                <a
                  href={product.link}
                  class="self-start inline-flex items-center gap-2 font-medium text-[15px] md:text-base hover:opacity-70 transition-opacity duration-200 mt-8"
                  style="color: #cdff52;"
                >
                  Learn more
                  <i class="ph ph-arrow-right text-lg"></i>
                </a>
              </div>
              <!-- Right: Placeholder / Video -->
              <div class="w-full lg:w-[70%]">
                {product.id === 'karmalens' ? (
                  <div class="aspect-video overflow-hidden border rounded-[12px]" style="border-color: #2a2a2a;">
                    <video
                      class="product-video w-full h-full object-cover"
                      data-product="karmalens"
                      muted
                      loop
                      playsinline
                      preload="metadata"
                      poster={product.poster}
                    >
                      <source src="/assets/Videos/karmalens.webm" type="video/webm" />
                      <source src="/assets/Videos/karmalens.mp4" type="video/mp4" />
                    </video>
                  </div>
                ) : product.id === 'karmadomain' ? (
                  <div class="aspect-video overflow-hidden border rounded-[12px]" style="border-color: #2a2a2a;">
                    <video
                      class="product-video w-full h-full object-cover"
                      data-product="karmadomain"
                      muted
                      loop
                      playsinline
                      preload="metadata"
                      poster={product.poster}
                    >
                      <source src="/assets/Videos/karmadomain.webm" type="video/webm" />
                      <source src="/assets/Videos/karmadomain.mp4" type="video/mp4" />
                    </video>
                  </div>
                ) : product.id === 'karmapulse' ? (
                  <div class="aspect-video overflow-hidden border rounded-[12px]" style="border-color: #2a2a2a;">
                    <video
                      class="product-video w-full h-full object-cover"
                      data-product="karmapulse"
                      muted
                      loop
                      playsinline
                      preload="metadata"
                      poster={product.poster}
                    >
                      <source src="/assets/Videos/KarmaPulse.mp4" type="video/mp4" />
                    </video>
                  </div>
                ) : product.id === 'karmaiq' ? (
                  <div class="aspect-video overflow-hidden border rounded-[12px]" style="border-color: #2a2a2a;">
                    <video
                      class="product-video w-full h-full object-cover"
                      data-product="karmaiq"
                      muted
                      loop
                      playsinline
                      preload="metadata"
                      poster={product.poster}
                    >
                      <source src="/assets/Videos/karmaiq.mp4" type="video/mp4" />
                    </video>
                  </div>
                ) : (
                  <div class="product-placeholder aspect-video flex items-center justify-center">
                    <p class="text-gray-600 text-sm">Image / Video placeholder</p>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  type ProductScrollWindow = Window & {
    __productsTabScrollCleanup?: () => void;
    __ckStepScrollOwner?: string;
  };

  function initProductTabs() {
    const tabs = document.querySelectorAll<HTMLElement>('.product-tab');
    const panels = document.querySelectorAll<HTMLElement>('.product-panel');
    const glider = document.getElementById('product-tab-glider');

    function moveGlider(index: number) {
      if (!glider || !tabs[index]) return;
      const tab = tabs[index];
      const offsetLeft = tab.offsetLeft;
      glider.style.transform = `translateX(${offsetLeft}px)`;
    }

    function activateTab(index: number) {
      tabs.forEach((tab, i) => {
        if (i === index) {
          tab.classList.add('active');
        } else {
          tab.classList.remove('active');
        }
      });

      panels.forEach((panel, i) => {
        if (i === index) {
          panel.classList.add('active');
        } else {
          panel.classList.remove('active');
        }
      });

      moveGlider(index);
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const index = parseInt(tab.dataset.index || '0');
        activateTab(index);
      });
    });

    // Activate first tab by default
    activateTab(0);
  }

  // Desktop product tabs: one wheel gesture advances one tab.

  function initScrollTabs() {
    const scrollArea = document.getElementById('products-scroll-area');
    const wrapper = document.querySelector('.products-tabs-wrapper') as HTMLElement;
    const panelsEl = document.querySelector('.product-panels') as HTMLElement;
    const tabs = document.querySelectorAll<HTMLElement>('.product-tab');
    const panels = document.querySelectorAll<HTMLElement>('.product-panel');
    if (!scrollArea || !wrapper || tabs.length === 0) return;

    const productWindow = window as ProductScrollWindow;
    productWindow.__productsTabScrollCleanup?.();

    const numTabs = tabs.length;
    const lastTabIndex = numTabs - 1;
    const defaultMargin = 0;
    const glider = document.getElementById('product-tab-glider');
    const progressState = { value: 0 };
    let currentTabIndex = 0;
    let stepTween: gsap.core.Tween | null = null;
    let isSectionActive = false;
    let isAnimatingStep = false;
    let activePinDirection: 1 | -1 = 1;
    let wheelGestureLocked = false;
    let wheelGestureUnlockTimer: number | null = null;
    let releaseGestureDirection: 1 | -1 | null = null;
    let releaseGestureUnlockTimer: number | null = null;
    let nativeScrollRaf: number | null = null;
    const ownerKey = 'products-tabs';
    const expandEnd = 0.12;
    const shrinkStart = 0.86;
    const wheelGestureIdleMs = 560;
    const releaseGestureIdleMs = 360;
    const minimumWheelDelta = 1;

    const stepTargets = Array.from({ length: numTabs }, (_, index) => getTabProgress(index));

    function activateTab(index: number) {
      currentTabIndex = Math.min(Math.max(index, 0), lastTabIndex);

      tabs.forEach((tab, i) => {
        if (i === currentTabIndex) tab.classList.add('active');
        else tab.classList.remove('active');
      });

      panels.forEach((panel, i) => {
        if (i === currentTabIndex) panel.classList.add('active');
        else panel.classList.remove('active');
      });

      if (glider && tabs[currentTabIndex]) {
        glider.style.transform = `translateX(${tabs[currentTabIndex].offsetLeft}px)`;
      }
    }

    function isDesktopSnapMode() {
      return window.matchMedia('(min-width: 768px)').matches;
    }

    function getScrollY() {
      return window.scrollY || document.documentElement.scrollTop || document.body.scrollTop || 0;
    }

    function withInstantScrollBehavior(callback: () => void) {
      const root = document.documentElement;
      const body = document.body;
      const rootScrollBehavior = root.style.scrollBehavior;
      const bodyScrollBehavior = body.style.scrollBehavior;

      root.style.setProperty('scroll-behavior', 'auto', 'important');
      body.style.setProperty('scroll-behavior', 'auto', 'important');

      callback();

      requestAnimationFrame(() => {
        root.style.scrollBehavior = rootScrollBehavior;
        body.style.scrollBehavior = bodyScrollBehavior;
      });
    }

    function forceScrollTo(top: number) {
      withInstantScrollBehavior(() => {
        document.documentElement.scrollTop = top;
        document.body.scrollTop = top;
        window.scrollTo({ top, left: 0, behavior: 'auto' });
      });
    }

    function getSectionScrollStart() {
      return scrollArea!.getBoundingClientRect().top + getScrollY();
    }

    function getSectionScrollLength() {
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
      return Math.max(scrollArea!.offsetHeight - viewportHeight, viewportHeight);
    }

    function getSectionScrollEnd() {
      return getSectionScrollStart() + getSectionScrollLength();
    }

    function clamp(value: number) {
      return Math.max(0, Math.min(1, value));
    }

    function getProgressForY(scrollY = getScrollY()) {
      return clamp((scrollY - getSectionScrollStart()) / getSectionScrollLength());
    }

    function getTabProgress(index: number) {
      const tabSpan = shrinkStart - expandEnd;
      return expandEnd + tabSpan * ((index + 0.5) / numTabs);
    }

    function getIndexFromProgress(progress: number) {
      if (progress <= expandEnd) return 0;
      if (progress >= shrinkStart) return lastTabIndex;

      const tabProgress = (progress - expandEnd) / (shrinkStart - expandEnd);
      return Math.min(lastTabIndex, Math.max(0, Math.floor(tabProgress * numTabs)));
    }

    function renderForProgress(progress: number) {
      progress = clamp(progress);

      const parentPadding = window.innerWidth < 1024 ? 40 : 106;
      const fullMargin = -(parentPadding + (window.innerWidth - scrollArea!.offsetWidth) / 2);

      if (progress <= expandEnd) {
        const expandProgress = progress / expandEnd;
        const currentMargin = defaultMargin + (fullMargin - defaultMargin) * expandProgress;
        wrapper.style.marginLeft = `${currentMargin}px`;
        wrapper.style.marginRight = `${currentMargin}px`;
        if (panelsEl) panelsEl.style.borderRadius = `${8 * (1 - expandProgress)}px`;
        activateTab(0);
      } else if (progress <= shrinkStart) {
        wrapper.style.marginLeft = `${fullMargin}px`;
        wrapper.style.marginRight = `${fullMargin}px`;
        if (panelsEl) panelsEl.style.borderRadius = '0px';
        activateTab(getIndexFromProgress(progress));
      } else {
        const shrinkProgress = (progress - shrinkStart) / (1 - shrinkStart);
        const currentMargin = fullMargin + (defaultMargin - fullMargin) * shrinkProgress;
        wrapper.style.marginLeft = `${currentMargin}px`;
        wrapper.style.marginRight = `${currentMargin}px`;
        if (panelsEl) panelsEl.style.borderRadius = `${8 * shrinkProgress}px`;
        activateTab(lastTabIndex);
      }
    }

    function setControlledProgress(progress: number) {
      progressState.value = clamp(progress);
      renderForProgress(progressState.value);
    }

    function getPinnedScrollY() {
      return activePinDirection > 0 ? getSectionScrollStart() + 2 : getSectionScrollEnd() - 2;
    }

    function pinViewportToSection() {
      if (!isSectionActive) return;

      const targetY = getPinnedScrollY();
      if (Math.abs(getScrollY() - targetY) > 1) {
        forceScrollTo(targetY);
      }
    }

    function placeViewportAtSectionEdge(direction: 1 | -1) {
      activePinDirection = direction;
      const targetY = direction > 0 ? getSectionScrollStart() + 2 : getSectionScrollEnd() - 2;
      forceScrollTo(targetY);
    }

    function setStep(index: number) {
      const targetIndex = Math.min(Math.max(index, 0), lastTabIndex);
      currentTabIndex = targetIndex;
      setControlledProgress(stepTargets[targetIndex]);
    }

    function claimControlledWheel(event: WheelEvent) {
      event.preventDefault();
      event.stopImmediatePropagation();
    }

    function claimScrollOwnership() {
      productWindow.__ckStepScrollOwner = ownerKey;
    }

    function releaseScrollOwnership() {
      if (productWindow.__ckStepScrollOwner === ownerKey) {
        delete productWindow.__ckStepScrollOwner;
      }
    }

    function lockWheelGestureTail(durationMs = wheelGestureIdleMs) {
      claimScrollOwnership();
      wheelGestureLocked = true;

      if (wheelGestureUnlockTimer !== null) {
        window.clearTimeout(wheelGestureUnlockTimer);
      }

      wheelGestureUnlockTimer = window.setTimeout(() => {
        wheelGestureLocked = false;
        wheelGestureUnlockTimer = null;
      }, durationMs);
    }

    function clearWheelGestureLock() {
      wheelGestureLocked = false;

      if (wheelGestureUnlockTimer !== null) {
        window.clearTimeout(wheelGestureUnlockTimer);
        wheelGestureUnlockTimer = null;
      }
    }

    function lockReleaseGesture(direction: 1 | -1) {
      claimScrollOwnership();
      releaseGestureDirection = direction;

      if (releaseGestureUnlockTimer !== null) {
        window.clearTimeout(releaseGestureUnlockTimer);
      }

      releaseGestureUnlockTimer = window.setTimeout(() => {
        releaseGestureDirection = null;
        releaseGestureUnlockTimer = null;
        releaseScrollOwnership();
      }, releaseGestureIdleMs);
    }

    function clearReleaseGestureLock() {
      releaseGestureDirection = null;

      if (releaseGestureUnlockTimer !== null) {
        window.clearTimeout(releaseGestureUnlockTimer);
        releaseGestureUnlockTimer = null;
      }
    }

    function clearWheelMemory() {
      clearWheelGestureLock();
      clearReleaseGestureLock();
      releaseScrollOwnership();
    }

    function syncNativeScrollProgress() {
      if (isSectionActive || isAnimatingStep) return;

      progressState.value = getProgressForY();
      renderForProgress(progressState.value);
    }

    function handleNativeScroll() {
      if (nativeScrollRaf !== null) return;

      nativeScrollRaf = window.requestAnimationFrame(() => {
        nativeScrollRaf = null;
        if (isDesktopSnapMode()) {
          syncNativeScrollProgress();
        }
      });
    }

    function animateToStep(index: number, direction: 1 | -1) {
      const targetIndex = Math.min(Math.max(index, 0), lastTabIndex);
      if (targetIndex === currentTabIndex) return;

      stepTween?.kill();
      currentTabIndex = targetIndex;
      isAnimatingStep = true;
      activePinDirection = direction;
      claimScrollOwnership();

      stepTween = gsap.to(progressState, {
        value: stepTargets[targetIndex],
        duration: 0.56,
        ease: 'power3.out',
        overwrite: true,
        onUpdate: () => {
          renderForProgress(progressState.value);
          pinViewportToSection();
        },
        onComplete: () => {
          setStep(targetIndex);
          pinViewportToSection();
          isAnimatingStep = false;
          stepTween = null;
          lockWheelGestureTail();
        },
        onInterrupt: () => {
          isAnimatingStep = false;
        },
      });
    }

    function releaseSection(direction: 1 | -1) {
      isSectionActive = false;
      stepTween?.kill();
      clearWheelGestureLock();
      lockReleaseGesture(direction);

      const exitY = direction > 0 ? getSectionScrollEnd() + 2 : Math.max(0, getSectionScrollStart() - 2);
      forceScrollTo(exitY);
    }

    function enterSection(direction: 1 | -1) {
      isSectionActive = true;
      claimScrollOwnership();
      placeViewportAtSectionEdge(direction);
      setStep(direction > 0 ? 0 : lastTabIndex);
      lockWheelGestureTail();
    }

    function handleStepIntent(direction: 1 | -1) {
      if (!isDesktopSnapMode() || !isSectionActive) return false;

      if (direction < 0 && currentTabIndex === 0) {
        releaseSection(direction);
        return false;
      }

      if (direction > 0 && currentTabIndex === lastTabIndex) {
        releaseSection(direction);
        return false;
      }

      animateToStep(currentTabIndex + direction, direction);
      return true;
    }

    function getWheelDirection(event: WheelEvent): 1 | -1 | 0 {
      if (event.deltaY > 0) return 1;
      if (event.deltaY < 0) return -1;
      return 0;
    }

    function isInsideSectionRunway(scrollY = getScrollY()) {
      return scrollY >= getSectionScrollStart() - 1 && scrollY <= getSectionScrollEnd() + 1;
    }

    function handleWheel(event: WheelEvent) {
      if (!isDesktopSnapMode()) return;

      const direction = getWheelDirection(event);
      if (direction === 0) return;

      const currentY = getScrollY();
      const sectionStart = getSectionScrollStart();
      const sectionEnd = getSectionScrollEnd();
      const delta = Math.abs(event.deltaY);
      const crossesFromAbove = direction > 0 && currentY < sectionStart && currentY + delta >= sectionStart;
      const crossesFromBelow = direction < 0 && currentY > sectionEnd && currentY - delta <= sectionEnd;

      if (releaseGestureDirection !== null) {
        if (direction === releaseGestureDirection) {
          lockReleaseGesture(direction);
          return;
        }

        clearReleaseGestureLock();
      }

      const shouldControl =
        isSectionActive || isInsideSectionRunway(currentY) || crossesFromAbove || crossesFromBelow;

      if (!shouldControl) return;

      if (isSectionActive && !isAnimatingStep && !wheelGestureLocked) {
        if (direction < 0 && currentTabIndex === 0) {
          releaseSection(direction);
          return;
        }

        if (direction > 0 && currentTabIndex === lastTabIndex) {
          releaseSection(direction);
          return;
        }
      }

      claimControlledWheel(event);

      if (isSectionActive) {
        pinViewportToSection();
      }

      if (delta < minimumWheelDelta) {
        return;
      }

      if (isAnimatingStep || wheelGestureLocked) {
        pinViewportToSection();
        lockWheelGestureTail();
        return;
      }

      if (!isSectionActive) {
        const alreadyInsideRunway = isInsideSectionRunway(currentY) && !crossesFromAbove && !crossesFromBelow;
        const startingTabIndex = alreadyInsideRunway ? currentTabIndex : direction > 0 ? 0 : lastTabIndex;

      enterSection(direction);
      setStep(startingTabIndex);

      if (alreadyInsideRunway) {
        handleStepIntent(direction);
        }

        return;
      }

      handleStepIntent(direction);
    }

    const handleResize = () => {
      if (isDesktopSnapMode() && isSectionActive) {
        placeViewportAtSectionEdge(activePinDirection);
      }

      if (isDesktopSnapMode()) {
        setStep(currentTabIndex);
      } else {
        isSectionActive = false;
        stepTween?.kill();
        clearWheelMemory();
      }
    };

    const tabClickHandlers = Array.from(tabs, (tab, index) => {
      const handleClick = () => {
        stepTween?.kill();
        isAnimatingStep = false;
        clearWheelMemory();
        setStep(index);
      };

      tab.addEventListener('click', handleClick);
      return handleClick;
    });

    window.addEventListener('scroll', handleNativeScroll, { passive: true });
    window.addEventListener('wheel', handleWheel, { passive: false, capture: true });
    window.addEventListener('resize', handleResize, { passive: true });

    const cleanup = () => {
      window.removeEventListener('scroll', handleNativeScroll);
      window.removeEventListener('wheel', handleWheel, true);
      window.removeEventListener('resize', handleResize);
      tabs.forEach((tab, index) => {
        const handleClick = tabClickHandlers[index];
        if (handleClick) tab.removeEventListener('click', handleClick);
      });
      if (nativeScrollRaf !== null) {
        window.cancelAnimationFrame(nativeScrollRaf);
        nativeScrollRaf = null;
      }
      stepTween?.kill();
      clearWheelMemory();

      if (productWindow.__productsTabScrollCleanup === cleanup) {
        delete productWindow.__productsTabScrollCleanup;
      }
    };

    productWindow.__productsTabScrollCleanup = cleanup;
    document.addEventListener('astro:before-swap', cleanup, { once: true });
    syncNativeScrollProgress();
  }

  function initProductVideos() {
    const productVideos = document.querySelectorAll<HTMLVideoElement>('.product-video');
    if (!productVideos.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const panel = entry.target as HTMLElement;
          const video = panel.querySelector('.product-video') as HTMLVideoElement;
          if (!video) return;
          if (entry.isIntersecting) {
            video.play();
          } else {
            video.pause();
          }
        });
      },
      { threshold: 0.3 }
    );

    document.querySelectorAll<HTMLElement>('.product-panel').forEach((panel) => {
      if (panel.querySelector('.product-video')) {
        observer.observe(panel);
      }
    });
  }

  function initAll() {
    // Reset inline styles that may be stale from previous navigation
    const wrapper = document.querySelector('.products-tabs-wrapper') as HTMLElement;
    if (wrapper) {
      wrapper.style.marginLeft = '';
      wrapper.style.marginRight = '';
    }
    const panelsEl = document.querySelector('.product-panels') as HTMLElement;
    if (panelsEl) {
      panelsEl.style.borderRadius = '';
    }

    initScrollTabs();
    initProductVideos();
    initMobileProductScroll();
  }

  function initMobileProductScroll() {
    const container = document.getElementById('mobile-products-scroll');
    if (!container) return;

    const cards = container.querySelectorAll<HTMLElement>('.mobile-product-card');
    if (!cards.length) return;

    let ticking = false;

    function updateCards() {
      const containerRect = container!.getBoundingClientRect();
      const containerCenter = containerRect.left + containerRect.width / 2;

      cards.forEach((card) => {
        const cardRect = card.getBoundingClientRect();
        const cardCenter = cardRect.left + cardRect.width / 2;
        const distance = Math.abs(containerCenter - cardCenter);
        const maxDistance = containerRect.width * 0.5;
        const progress = Math.max(0, 1 - distance / maxDistance);

        const scale = 0.95 + 0.05 * progress;
        const opacity = 0.5 + 0.5 * progress;

        card.style.transform = `scale(${scale})`;
        card.style.opacity = String(opacity);
      });

      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(updateCards);
        ticking = true;
      }
    }

    container.addEventListener('scroll', onScroll, { passive: true });
    updateCards();
  }

  document.addEventListener('DOMContentLoaded', initAll);
</script>

