---
const features = [
  {
    title: 'Lightning Fast',
    description: 'Built on a modern architecture that delivers sub-second response times. Your users will notice the difference.',
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  },
  {
    title: 'Type-Safe APIs',
    description: 'End-to-end type safety from your database to your frontend. Catch bugs at compile time, not in production.',
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
  },
  {
    title: 'Built-in Auth',
    description: 'Authentication and authorization out of the box. Social logins, magic links, and RBAC ready in minutes.',
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>`,
  },
  {
    title: 'Real-time Sync',
    description: 'Collaborative features powered by WebSockets. Build multiplayer experiences with just a few lines of code.',
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
  },
  {
    title: 'Edge Deployment',
    description: 'Deploy to 300+ edge locations worldwide. Automatic scaling, zero cold starts, and global low latency.',
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: 'Developer Experience',
    description: 'Beautiful CLI, VS Code extension, and comprehensive docs. Everything you need to stay in flow.',
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
  },
];
---

<section id="features" class="py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Everything you need to ship
      </h2>
      <p class="mt-4 text-lg text-gray-400">
        A complete toolkit designed for modern teams. Stop gluing services together and start building.
      </p>
    </div>

    <div id="features-grid" class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <div class="feature-card group relative rounded-2xl border border-gray-800 bg-gray-900/50 p-8 transition-all hover:border-brand-primary/50 hover:bg-gray-900">
          <div class="mb-4 inline-flex rounded-lg bg-brand-primary/10 p-3 text-brand-primary">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{feature.title}</h3>
          <p class="text-sm text-gray-400 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { staggerReveal } from '../../lib/gsap';

  staggerReveal('#features-grid', '.feature-card', 0.1);
</script>
