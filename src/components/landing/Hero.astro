---
---

<section id="hero-section" class="relative bg-white overflow-visible pt-44 pb-[200px] lg:pt-[240px] lg:pb-[200px]">

  <!-- Vertical gridlines aligned with content edges -->
  <div id="hero-gridlines-container" class="hidden md:block absolute inset-0 mx-auto max-w-7xl px-10 lg:px-[88px] pointer-events-none z-0" aria-hidden="true">
    <div class="relative h-full">
      <div class="absolute left-0 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, #fafafa, #e5e5e5);"></div>
      <div class="absolute right-0 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, #fafafa, #e5e5e5);"></div>
    </div>
  </div>

  <div id="hero-content-container" class="relative z-10 mx-auto max-w-7xl px-5 md:px-10 lg:px-[88px]">
    <!-- Top content area: two columns -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16">
      <!-- Left: Headline -->
      <div id="hero-left">
        <h1 id="hero-heading" class="text-[48px] md:text-[56px] lg:text-[64px] tracking-tight leading-[1.2] bg-gradient-to-b from-[#3b4049] via-[#2a2e35] via-[50%] to-[#0f0f0f] bg-clip-text text-transparent lg:pl-12">
          <span class="font-semibold">Production</span><br />
          <span class="font-mono font-semibold" style="letter-spacing: -0.03em;">Intelligence</span><br />
          <span class="font-semibold">for the AI Era</span>
        </h1>
      </div>

      <!-- Right: Description + CTAs -->
      <div id="hero-right" class="flex flex-col justify-between md:pt-4 md:pb-4 lg:pr-12">
        <p id="hero-body" class="text-[18px] text-gray-600 leading-[1.45] md:leading-[1.65] max-w-lg font-normal">
          Writing code is no longer the bottleneck.
          Understanding how systems actually behave in production is.
          CodeKarma maps production behavior directly to code.
        </p>

        <div id="hero-cta" class="hidden md:flex flex-wrap items-center gap-2">
          <a
            id="hero-btn-primary"
            href="https://cal.com/ananth-vanchi/30min" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-2 md:px-10 md:py-3 rounded-none bg-brand-dark font-medium text-[15px] md:text-lg hover:bg-brand-primary transition-colors duration-200 hero-btn-primary"
          >
            <span>Schedule Demo</span>
          </a>
          <a
            href="/products"
            class="group inline-flex items-center justify-center gap-1.5 px-6 py-2 md:px-10 md:py-3 font-medium text-[15px] md:text-lg text-brand-dark hover:bg-gray-100 transition-all duration-200"
          >
            <span>View Platform</span>
            <i class="ph ph-arrow-right text-lg transition-transform duration-200 group-hover:translate-x-1"></i>
          </a>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  function syncHero() {
    const left = document.getElementById('hero-left');
    const right = document.getElementById('hero-right');
    const section = document.getElementById('hero-section');
    const btn = document.getElementById('hero-btn-primary');
    const lineTop = document.getElementById('hero-line-top');
    const lineBottom = document.getElementById('hero-line-bottom');

    if (left && right) {
      // Only sync height on desktop (lg+) where columns are side-by-side
      if (window.innerWidth >= 1024) {
        right.style.height = `${left.offsetHeight}px`;
      } else {
        right.style.height = '';
      }
    }

    if (section && btn && lineTop && lineBottom) {
      const sectionRect = section.getBoundingClientRect();
      const btnRect = btn.getBoundingClientRect();
      lineTop.style.top = `${btnRect.top - sectionRect.top}px`;
      lineBottom.style.top = `${btnRect.bottom - sectionRect.top}px`;
    }
  }

  // Track cleanup references
  let resizeHandler: (() => void) | null = null;
  let observers: MutationObserver[] = [];

  function initHero() {
    // Clean up previous listeners/observers
    if (resizeHandler) window.removeEventListener('resize', resizeHandler);
    observers.forEach((o) => o.disconnect());
    observers = [];

    // Wait a frame for layout to settle after View Transitions
    requestAnimationFrame(() => {
      syncHero();

      resizeHandler = syncHero;
      window.addEventListener('resize', syncHero);

      const heading = document.getElementById('hero-heading');
      const btn = document.getElementById('hero-btn-primary');
      if (heading) {
        const mo1 = new MutationObserver(syncHero);
        mo1.observe(heading, { attributes: true, attributeFilter: ['style'] });
        observers.push(mo1);
      }
      if (btn) {
        const mo2 = new MutationObserver(syncHero);
        mo2.observe(btn, { attributes: true, attributeFilter: ['style'] });
        observers.push(mo2);
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initHero);
</script>
