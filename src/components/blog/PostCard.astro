---
interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  slug: string;
  tags?: string[];
  coverImage?: string;
  featured?: boolean;
}

const { title, description, publishedAt, slug, tags = [], coverImage, featured = false } = Astro.props;

const formattedDate = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class="group block post-card border border-gray-200 transition-all"
  data-tags={tags.join(',')}
>
  <div class="flex flex-col">
    <!-- Top: Image -->
    {coverImage ? (
      <div class="w-full aspect-[16/9] overflow-hidden">
        <img src={coverImage} alt={title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" loading="lazy" />
      </div>
    ) : (
      <div class="post-placeholder w-full aspect-[16/9]"></div>
    )}
    <!-- Bottom: Content -->
    <div class="p-6 lg:p-7 flex flex-col justify-between flex-1 border-t border-gray-200">
      <div>
        <div class="flex items-start justify-between gap-4 mb-3">
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="text-xs font-mono tracking-wider uppercase text-brand-dark/40">
                {tag}
              </span>
            ))}
          </div>
          <time class="text-sm text-gray-400 font-normal whitespace-nowrap flex-shrink-0" datetime={publishedAt.toISOString()}>
            {formattedDate}
          </time>
        </div>
        <h3 class="text-lg lg:text-[22px] font-semibold text-brand-dark tracking-tight leading-[1.25] mb-2 group-hover:text-brand-dark/70 transition-colors">
          {title}
        </h3>
        <p class="text-[15px] text-gray-500 leading-[1.65] font-normal line-clamp-2">
          {description}
        </p>
      </div>
      <div class="flex items-center justify-between mt-5 pt-4 border-t border-gray-100">
        <span class="text-sm font-medium text-brand-dark group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
          Read
          <i class="ph ph-arrow-right text-base"></i>
        </span>
      </div>
    </div>
  </div>
</a>

<style>
  .post-placeholder {
    background-image: radial-gradient(circle, #d1d5db 1px, transparent 1px);
    background-size: 16px 16px;
    background-color: #f5f5f0;
  }

  .post-card {
    position: relative;
    overflow: hidden;
  }

  .post-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(205, 255, 82, 0.08) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 0;
    pointer-events: none;
  }

  .post-card:hover::before {
    opacity: 1;
  }

  .post-card > * {
    position: relative;
    z-index: 1;
  }
</style>
