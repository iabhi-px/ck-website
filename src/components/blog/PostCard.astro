---
interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  slug: string;
  tags?: string[];
}

const { title, description, publishedAt, slug, tags = [] } = Astro.props;

const formattedDate = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class="group block rounded-2xl border border-gray-800 bg-gray-900/50 p-6 transition-all hover:border-brand-primary/50 hover:bg-gray-900"
>
  <div class="flex flex-wrap gap-2 mb-3">
    {tags.map((tag) => (
      <span class="rounded-full bg-brand-primary/10 px-2.5 py-0.5 text-xs font-medium text-brand-primary">
        {tag}
      </span>
    ))}
  </div>
  <h3 class="text-lg font-semibold text-white group-hover:text-brand-primary transition-colors mb-2">
    {title}
  </h3>
  <p class="text-sm text-gray-400 leading-relaxed mb-4">{description}</p>
  <time class="text-xs text-gray-500" datetime={publishedAt.toISOString()}>
    {formattedDate}
  </time>
</a>
