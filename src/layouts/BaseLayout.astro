---
import SEO from '../components/shared/SEO.astro';
import Navbar from '../components/landing/Navbar.astro';
import Dials from '../components/shared/Dials.tsx';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Build faster with the modern developer platform.',
  ogImage,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css" />
    <SEO title={title} description={description} ogImage={ogImage} />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Dials client:only="react" />
  </body>
</html>
