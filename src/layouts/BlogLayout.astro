---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  coverImage?: string;
  tags?: string[];
}

const { title, description, publishedAt, coverImage, tags = [] } = Astro.props;

const formattedDate = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — CodeKarma Blog`} description={description} ogImage={coverImage}>
  <article class="relative bg-white pt-32 pb-20 overflow-hidden">
    <!-- Vertical gridlines (matching homepage) -->
    <div class="hidden md:block absolute inset-0 mx-auto max-w-7xl px-10 lg:px-[88px] pointer-events-none z-0" aria-hidden="true">
      <div class="relative h-full">
        <div class="absolute left-0 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, #fafafa, #e5e5e5);"></div>
        <div class="absolute right-0 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, #fafafa, #e5e5e5);"></div>
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-5 md:px-10 lg:px-[88px]">
      <!-- Back link -->
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-brand-dark transition-colors mb-12"
      >
        <i class="ph ph-arrow-left text-base"></i>
        Back to blog
      </a>

      <!-- Article header -->
      <header class="max-w-3xl mx-auto mb-12">
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-3 mb-5">
            {tags.map((tag) => (
              <span class="text-xs font-mono tracking-[0.3em] uppercase text-brand-dark/40">
                {tag}
              </span>
            ))}
          </div>
        )}

        <h1 class="text-[28px] sm:text-[40px] md:text-[48px] tracking-tight leading-[1.1] font-semibold pl-5 md:pl-8 lg:pl-12 bg-gradient-to-b from-[#3b4049] via-[#2a2e35] via-[50%] to-[#0f0f0f] bg-clip-text text-transparent mb-6">
          {title}
        </h1>

        <div class="flex items-center gap-4 text-sm text-gray-400 font-normal">
          <time datetime={publishedAt.toISOString()}>{formattedDate}</time>
        </div>
      </header>

      <!-- Hero image -->
      <div class="mb-12">
        <div class="border border-gray-200 overflow-hidden">
          {coverImage ? (
            <img
              src={coverImage}
              alt={title}
              class="w-full aspect-[2/1] object-cover"
            />
          ) : (
            <div class="blog-hero-placeholder w-full aspect-[2/1]"></div>
          )}
        </div>
      </div>

      <!-- Article content -->
      <div class="blog-prose max-w-3xl mx-auto">
        <slot />
      </div>

      <!-- Back to blog -->
      <div class="max-w-3xl mx-auto mt-12">
        <a
          href="/blog"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-dark hover:opacity-70 transition-opacity"
        >
          <i class="ph ph-arrow-left text-base"></i>
          All articles
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-prose :global(h1),
  .blog-prose :global(h2),
  .blog-prose :global(h3),
  .blog-prose :global(h4),
  .blog-prose :global(h5),
  .blog-prose :global(h6) {
    color: #0f0f0f;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .blog-prose :global(h2) {
    font-size: 2rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .blog-prose :global(h3) {
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .blog-prose :global(p) {
    color: #6b7280;
    line-height: 1.65;
    margin-bottom: 1.25rem;
    font-weight: 400;
  }

  .blog-prose :global(a) {
    color: #0f0f0f;
    text-decoration: underline;
    text-decoration-color: #cdff52;
    text-underline-offset: 3px;
    text-decoration-thickness: 2px;
    transition: text-decoration-color 0.2s;
  }

  .blog-prose :global(a:hover) {
    text-decoration-color: #0f0f0f;
  }

  .blog-prose :global(strong) {
    color: #0f0f0f;
    font-weight: 600;
  }

  .blog-prose :global(ul),
  .blog-prose :global(ol) {
    color: #6b7280;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    font-weight: 400;
  }

  .blog-prose :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.65;
  }

  .blog-prose :global(ul > li) {
    list-style-type: disc;
  }

  .blog-prose :global(ol > li) {
    list-style-type: decimal;
  }

  .blog-prose :global(blockquote) {
    border-left: 3px solid #cdff52;
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
  }

  .blog-prose :global(blockquote p) {
    color: #4b5563;
  }

  .blog-prose :global(code) {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.875em;
    color: #0f0f0f;
    background: #f5f5f0;
    padding: 0.15em 0.4em;
    border-radius: 2px;
  }

  .blog-prose :global(pre) {
    background: #0f0f0f;
    border: 1px solid #e5e7eb;
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.65;
  }

  .blog-prose :global(pre code) {
    background: none;
    color: #e5e7eb;
    padding: 0;
    font-size: inherit;
  }

  .blog-prose :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(to right, #fafafa, #e5e5e5, #fafafa);
    margin: 2.5rem 0;
  }

  .blog-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }

  .blog-prose :global(th) {
    text-align: left;
    font-weight: 600;
    color: #0f0f0f;
    padding: 0.75rem 1rem;
    border-bottom: 1.5px solid #e5e5e5;
  }

  .blog-prose :global(td) {
    padding: 0.75rem 1rem;
    color: #6b7280;
    border-bottom: 1px solid #f3f4f6;
  }

  .blog-prose :global(img) {
    border: 1px solid #e5e7eb;
    margin: 1.5rem 0;
  }

  .blog-prose > :global(*:first-child) {
    margin-top: 0;
  }

  .blog-hero-placeholder {
    background-image: radial-gradient(circle, #d1d5db 1px, transparent 1px);
    background-size: 16px 16px;
    background-color: #f5f5f0;
  }

  .blog-prose :global(.blog-img-placeholder) {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-image: radial-gradient(circle, #d1d5db 1px, transparent 1px);
    background-size: 16px 16px;
    background-color: #f5f5f0;
    border: 1px solid #e5e7eb;
    margin: 1.5rem 0;
  }
</style>
